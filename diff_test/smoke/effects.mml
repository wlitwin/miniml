-- Differential smoke: effect handlers, mutable state, multishot resume,
-- and `return` escaping through a for-in body.
-- All backends must agree on the full observable output.

effect Choice =
  choose : unit -> bool
end

effect State =
  get : unit -> int
  put : int -> unit
end

let rec append xs ys = match xs with
  | [] -> ys
  | x :: rest -> x :: append rest ys
;;

-- State handler over a mutable cell
let mut st = 10;;
let state_result = handle
  let a = perform get () in
  perform put (a + 5);
  perform get ()
with
| return v -> v
| get () k -> resume k st
| put v k -> st := v; resume k ()
in
print state_result;;

-- Multishot: explore all four branches of two binary choices
let multishot_result = handle
  let x = perform choose () in
  let y = perform choose () in
  if x && y do 1 else 0
with
| return x -> [x]
| choose () k ->
  let k2 = copy_continuation k in
  let a = resume k true in
  let b = resume k2 false in
  append a b
in
print multishot_result;;

-- `return` inside a for-in body returns from the enclosing function
let find_first_even xs =
  for x in xs do
    if x mod 2 = 0 do return Some x else ()
  end;
  None
;;

[find_first_even [1; 3; 4; 5]; find_first_even [1; 3]]
