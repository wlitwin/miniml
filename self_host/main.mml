-- The `compiler` binary entry. The compiler itself lives in self_host/driver.mml
-- (module Driver) so it can be reused by the all-in-one tool (self_host/mml.mml);
-- this file is just the thin CLI shim that hands argv to Driver.run_cli. Keeping
-- it separate is what lets mml.mml link the driver WITHOUT also running this
-- entry. (Path B, roadmap #16/#24.)
module Main =
  let () = Driver.run_cli (Sys.args ())
end
