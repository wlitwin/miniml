  pub let rstrip s =
    let n = Ref.create (String.length s) in
    for ((Ref.get n) > 0) && (((String.get s ((Ref.get n) - 1)) = #20) || (((String.get s ((Ref.get n) - 1)) = #09) || ((String.get s ((Ref.get n) - 1)) = #0d))) do
      Ref.set n (Ref.get n - 1)
    end;
    String.sub s 0 (Ref.get n)

  pub let scan_trivia abs cnext (s : string) : comment list =
    let n = String.length s in
    let out = Ref.create [] in
    let i = Ref.create 0 in
    let nl = Ref.create false in
    for (Ref.get i) < n do
      let c = String.get s (Ref.get i) in
      if c = #0a do
        Ref.set nl true;
        Ref.set i (Ref.get i + 1)
      else if (c = #20) || ((c = #09) || (c = #0d)) do
        Ref.set i (Ref.get i + 1)
      else if (c = #28) && ((((Ref.get i) + 1) < n) && ((String.get s ((Ref.get i) + 1)) = #2a)) do
        let start = Ref.get i in
        Ref.set i ((Ref.get i) + 2);
        let depth = Ref.create 1 in
        for ((Ref.get depth) > 0) && ((Ref.get i) < n) do
          if (((Ref.get i) + 1) < n) && (((String.get s (Ref.get i)) = #28) && ((String.get s ((Ref.get i) + 1)) = #2a)) do
            Ref.set depth ((Ref.get depth) + 1);
            Ref.set i ((Ref.get i) + 2)
          else if (((Ref.get i) + 1) < n) && (((String.get s (Ref.get i)) = #2a) && ((String.get s ((Ref.get i) + 1)) = #29)) do
            Ref.set depth ((Ref.get depth) - 1);
            Ref.set i ((Ref.get i) + 2)
          else
            Ref.set i (Ref.get i + 1)
        end;
        Ref.set out ({cs = abs + start; ce = abs + (Ref.get i); cnext; ctext = String.sub s start ((Ref.get i) - start); cown = Ref.get nl} :: Ref.get out);
        Ref.set nl false
      else if (c = #2d) && ((((Ref.get i) + 1) < n) && ((String.get s ((Ref.get i) + 1)) = #2d)) do
        let start = Ref.get i in
        for ((Ref.get i) < n) && ((String.get s (Ref.get i)) <> #0a) do
          Ref.set i (Ref.get i + 1)
        end;
        Ref.set out ({cs = abs + start; ce = abs + (Ref.get i); cnext; ctext = rstrip (String.sub s start ((Ref.get i) - start)); cown = Ref.get nl} :: Ref.get out);
        Ref.set nl false
      else
        Ref.set i (Ref.get i + 1)
    end;
    List.rev (Ref.get out)

  pub let all_comments (src : string) : comment list =
    let prev = Ref.create 0 in
    List.concat_map (fn (p : Cst.piece) -> let abs = Ref.get prev in
    Ref.set prev p.token.end_offset;
    scan_trivia abs p.token.loc.offset p.leading) (Cst.of_source src)

  pub let node_span (node : Cst.tree) : int * int =
    match Cst.leaves node with
    | [] -> perform reanchor_bail ()
    | ls -> 
      let first = List.hd ls in
      let last = List.nth ls ((List.length ls) - 1) in
      (first.token.loc.offset, last.token.end_offset)


  pub let is_module_node (node : Cst.tree) : bool =
    let rec first =
      fn
        | (p : Cst.piece) :: rest -> 
          do
            match p.token.kind with
            | (Token.PUB | Token.OPAQUE) -> first rest
            | k -> k = Token.MODULE

          end
        | [] -> false
     in
    first (Cst.leaves node)

  pub let rec leaf_spans (t : Cst.tree) : (int * int) list =
    match t with
    | Cst.Node ((Cst.Decl, children)) -> 
      if is_module_node t do
        List.concat_map leaf_spans children
      else
        node_span t :: []
    | Cst.Node ((_, children)) -> List.concat_map leaf_spans children
    | Cst.Leaf _ -> []


  pub let child_decl_nodes (node : Cst.tree) : Cst.tree array =
    match node with
    | Cst.Node ((_, children)) -> Array.of_list (List.filter (fn
      | Cst.Node ((Cst.Decl, _)) -> true
      | _ -> false
    ) children)
    | _ -> #[]


  pub let module_body_range (node : Cst.tree) : int * int =
    match node with
    | Cst.Node ((_, children)) -> 
      let rec find_lo before =
        fn
          | Cst.Node ((Cst.Decl, _)) :: _ -> before
          | Cst.Leaf p :: rest -> find_lo p.token.end_offset rest
          | _ :: rest -> find_lo before rest
          | [] -> before
       in
      let lo = find_lo 0 children in
      let ls = Cst.leaves node in
      let hi = (List.nth ls ((List.length ls) - 1)).token.loc.offset in
      (lo, hi)
    | _ -> perform reanchor_bail ()


  pub let decls_in_slice top (src : string) ((s, e) : int * int) : int =
    let slice = String.sub src s (e - s) in
    if top do
      List.length (Parser.parse_program (Lexer.tokenize slice))
    else
      match Parser.parse_program (Lexer.tokenize ("module Fmt__Wrap =\n" ^ (slice ^ "\nend"))) with
      | Ast.DModule ((_, items)) :: [] -> List.length items
      | _ -> perform reanchor_bail ()


  pub let segment (counts : int list) (items : 'a list) : 'a list list =
    let rec take k xs acc =
      if k = 0 do
        (List.rev acc, xs)
      else
        match xs with
        | [] -> perform reanchor_bail ()
        | x :: r -> take (k - 1) r (x :: acc)
     in
    let rec go counts items acc =
      match counts with
      | [] -> 
        if items <> [] do
          perform reanchor_bail ()
        else
          List.rev acc
      | k :: rest -> 
        let (g, items') = take k items [] in
        go rest items' (g :: acc)
     in
    go counts items []

  pub let doc_comment (c : comment) : doc =
    match comment_lines c with
    | [] -> Nil
    | first :: conts -> __op_5e5e (text first) (concat (List.map (fn l -> __op_5e5e (line) (text l)) conts))


  pub let rec doc_level top (src : string) (nodes : Cst.tree array) (groups : Ast.module_decl list array) (comments : comment list) lo hi : doc =
    let n = Array.length nodes in
    let spans = Array.map node_span nodes in
    let inside cs = Array.exists (fn (s, e) -> (s <= cs) && (cs < e)) spans in
    let slot_of cs =
      let c = Ref.create 0 in
      Array.iter (fn (_, e) -> if e <= cs do
        Ref.set c (Ref.get c + 1)
      end) spans;
      Ref.get c in
    let slots = Array.make (n + 1) [] in
    List.iter (fn c -> if (c.cs >= lo) && ((c.cs < hi) && (not (inside c.cs))) do
      Array.set slots (slot_of c.cs) (c :: Array.get slots (slot_of c.cs))
    end) comments;
    Array.iteri (fn i l -> Array.set slots i (List.rev l)) slots;
    let leading = Array.make (max n 1) [] in
    let trailing = Array.make (max n 1) None in
    let tail = Ref.create [] in
    Array.iteri (fn i cs -> let (cs, tr) =
      match cs with
      | first :: rest when (i >= 1) && (not first.cown) -> (rest, Some first)
      | _ -> (cs, None)
     in
    do
      match tr with
      | Some c -> Array.set trailing (i - 1) (Some c)
      | None -> ()

    end;
    if i < n do
      Array.set leading i cs
    else
      Ref.set tail cs) slots;
    let trail_doc i =
      match Array.get trailing i with
      | Some c -> __op_5e5e (text " ") (doc_comment c)
      | None -> Nil
     in
    if top do
      let frag i =
        let lead = concat (List.map (fn c -> __op_5e5e (doc_comment c) (line)) (Array.get leading i)) in
        let body = sepby (__op_5e5e (text ";;") (__op_5e5e (line) (line))) (List.map (doc_module_decl_c src (Array.get nodes i) comments) (Array.get groups i)) in
        let sep_after =
          if i < (n - 1) do
            text ";;"
          else
            Nil in
        let gap =
          if i < (n - 1) do
            __op_5e5e (line) (line)
          else
            Nil in
        __op_5e5e (lead) (__op_5e5e (body) (__op_5e5e (sep_after) (__op_5e5e (trail_doc i) (gap)))) in
      let all = concat (List.init n frag) in
      let tail_doc = concat (List.mapi (fn j c -> __op_5e5e (if (j > 0) || (n > 0) do
        line
      else
        Nil) (doc_comment c)) (Ref.get tail)) in
      __op_5e5e (all) (tail_doc)
    else do
      let frag i =
        let lead = concat (List.map (fn c -> __op_5e5e (line) (doc_comment c)) (Array.get leading i)) in
        let items = Array.get groups i in
        let last = (List.length items) - 1 in
        concat (List.mapi (fn j md -> __op_5e5e (if j = 0 do
          lead
        else
          Nil) (__op_5e5e (line) (__op_5e5e (doc_module_decl_c src (Array.get nodes i) comments md) (__op_5e5e (text ";;") (if j = last do
          trail_doc i
        else
          Nil))))) items) in
      let all = concat (List.init n frag) in
      let tail_doc = concat (List.map (fn c -> __op_5e5e (line) (doc_comment c)) (Ref.get tail)) in
      __op_5e5e (all) (tail_doc)
    end
  and doc_module_decl_c (src : string) (node : Cst.tree) (comments : comment list) (md : Ast.module_decl) : doc =
    let vis =
      match md.vis with
      | Ast.Public -> "pub "
      | Ast.Private -> ""
      | Ast.Opaque -> "opaque "
     in
    match md.decl with
    | Ast.DModule ((name, inner_items)) -> 
      let inner_nodes = child_decl_nodes node in
      let (lo, hi) = module_body_range node in
      let counts = Array.to_list (Array.map (fn nd -> decls_in_slice false src (node_span nd)) inner_nodes) in
      let groups = Array.of_list (segment counts inner_items) in
      if (Array.length groups) <> (Array.length inner_nodes) do
        perform reanchor_bail ()
      end;
      __op_5e5e (text vis) (__op_5e5e (text ("module " ^ (name ^ " ="))) (__op_5e5e (nest (doc_level false src inner_nodes groups comments lo hi)) (__op_5e5e (line) (text "end"))))
    | Ast.DClass {methods; _} -> member_decl vis node (List.length methods) md.decl
    | Ast.DInstance {inst_methods; _} -> member_decl vis node (List.length inst_methods) md.decl
    | Ast.DEffect ((_, _, ops)) -> member_decl vis node (List.length ops) md.decl
    | _ -> __op_5e5e (text vis) (doc_decl md.decl)

  and member_decl vis (node : Cst.tree) (n_members : int) (decl : Ast.decl) : doc =
    let mnodes = child_decl_nodes node in
    if (Array.length mnodes) = n_members do
      Ref.set member_marks (Some (Array.map (fn nd -> fst (node_span nd)) mnodes))
    end;
    let body = doc_decl decl in
    Ref.set member_marks None;
    __op_5e5e (text vis) (body)

  pub let format_source_with_comments (src : string) (prog : Ast.program) : string =
    let tree = Cst_build.cst_of_source src in
    let top_nodes =
      match tree with
      | Cst.Node ((Cst.SourceFile, _)) -> child_decl_nodes tree
      | _ -> perform reanchor_bail ()
     in
    let comments = all_comments src in
    let counts = Array.to_list (Array.map (fn nd -> decls_in_slice true src (node_span nd)) top_nodes) in
    let items = List.map (fn d -> {vis = Private; decl = d}) prog in
    let groups = Array.of_list (segment counts items) in
    if (Array.length groups) <> (Array.length top_nodes) do
      perform reanchor_bail ()
    end;
    let leaves = leaf_spans tree in
    Ref.set render_pending (List.filter (fn c -> List.exists (fn (s, e) -> (s <= c.cs) && (c.cs < e)) leaves) comments);
    let result = (render (doc_level true src top_nodes groups comments 0 (String.length src))) ^ "\n" in
    Ref.set render_pending [];
    result

  pub let format_source (src : string) : string =
    let tokens = Lexer.tokenize src in
    let prog = Parser.parse_program tokens in
    do try
      format_source_with_comments src prog
    with
    | reanchor_bail -> format_program prog
    end

  pub let norm_param (p : Ast.param) : Ast.param = {p with is_generated = false}

  pub let rec strip_e (e : Ast.expr) : Ast.expr =
    match e with
    | Ast.ELoc ((_, e)) -> strip_e e
    | ((((((((Ast.EInt _ | Ast.EFloat _) | Ast.EBool _) | Ast.EString _) | Ast.EByte _) | Ast.ERune _) | Ast.EUnit) | Ast.EVar _) | Ast.ENil) -> e
    | Ast.ELet ((n, a, b)) -> Ast.ELet (n, strip_e a, strip_e b)
    | Ast.ELetRec ((n, ps, a, b)) -> Ast.ELetRec (n, ps, strip_e a, strip_e b)
    | Ast.EFun ((p, b)) -> Ast.EFun (norm_param p, strip_e b)
    | Ast.EApp ((f, x)) -> Ast.EApp (strip_e f, strip_e x)
    | Ast.EIf ((c, t, f)) -> Ast.EIf (strip_e c, strip_e t, strip_e f)
    | Ast.EBinop ((op, l, r)) -> Ast.EBinop (op, strip_e l, strip_e r)
    | Ast.EUnop ((op, e)) -> Ast.EUnop (op, strip_e e)
    | Ast.ETuple es -> Ast.ETuple (List.map strip_e es)
    | Ast.ERecord fs -> Ast.ERecord (List.map (fn (n, e) -> (n, strip_e e)) fs)
    | Ast.ERecordUpdate ((b, fs)) -> Ast.ERecordUpdate (strip_e b, List.map (fn (n, e) -> (n, strip_e e)) fs)
    | Ast.EField ((e, f)) -> Ast.EField (strip_e e, f)
    | Ast.EIndex ((e, i)) -> Ast.EIndex (strip_e e, strip_e i)
    | Ast.ECons ((a, b)) -> Ast.ECons (strip_e a, strip_e b)
    | Ast.EList es -> Ast.EList (List.map strip_e es)
    | Ast.EArray es -> Ast.EArray (List.map strip_e es)
    | Ast.EConstruct ((n, eo)) -> Ast.EConstruct (n, Option.map strip_e eo)
    | Ast.EMatch ((s, arms, k)) -> Ast.EMatch (strip_e s, List.map (fn (p, g, b) -> (p, Option.map strip_e g, strip_e b)) arms, k)
    | Ast.ELetMut ((n, a, b)) -> Ast.ELetMut (n, strip_e a, strip_e b)
    | Ast.EAssign ((n, e)) -> Ast.EAssign (n, strip_e e)
    | Ast.EFieldAssign ((o, f, e)) -> Ast.EFieldAssign (strip_e o, f, strip_e e)
    | Ast.ESeq _ -> 
      let rec flatten e =
        match e with
        | Ast.ELoc ((_, e)) -> flatten e
        | Ast.ESeq ((a, b)) -> List.concat (flatten a) (flatten b)
        | e -> strip_e e :: []
       in
      let rec rebuild =
        fn
          | [] -> Ast.EUnit
          | x :: [] -> x
          | x :: rest -> Ast.ESeq (x, rebuild rest)
       in
      rebuild (flatten e)
    | Ast.EAnnot ((e, t)) -> Ast.EAnnot (strip_e e, t)
    | Ast.EWhile {while_cond; while_body} -> Ast.EWhile {while_cond = strip_e while_cond; while_body = strip_e while_body}
    | Ast.EFor r -> Ast.EFor {r with for_iter = strip_e r.for_iter; for_body = strip_e r.for_body}
    | Ast.EForFold r -> Ast.EForFold {r with loop_iter = strip_e r.loop_iter; accum_init = strip_e r.accum_init; fold_body = strip_e r.fold_body}
    | Ast.EWhileLet ((p, e, b)) -> Ast.EWhileLet (p, strip_e e, strip_e b)
    | Ast.EForNumeric r -> Ast.EForNumeric {r with fn_init = strip_e r.fn_init; fn_cond = strip_e r.fn_cond; fn_step = strip_e r.fn_step; fn_body = strip_e r.fn_body}
    | Ast.EBreak eo -> Ast.EBreak (Option.map strip_e eo)
    | Ast.EContinueLoop eo -> Ast.EContinueLoop (Option.map strip_e eo)
    | Ast.EReturn e -> Ast.EReturn (strip_e e)
    | Ast.ELetRecAnd ((bs, b)) -> Ast.ELetRecAnd (List.map (fn (n, ps, e) -> (n, ps, strip_e e)) bs, strip_e b)
    | Ast.EPerform ((op, e)) -> Ast.EPerform (op, strip_e e)
    | Ast.EHandle ((b, arms)) -> Ast.EHandle (strip_e b, List.map (fn
      | Ast.HReturn ((n, e)) -> Ast.HReturn (n, strip_e e)
      | Ast.HOp r -> Ast.HOp {r with body = strip_e r.body}
    ) arms)
    | Ast.EResume ((k, v)) -> Ast.EResume (strip_e k, strip_e v)
    | Ast.EMap ps -> Ast.EMap (List.map (fn (k, v) -> (strip_e k, strip_e v)) ps)
    | Ast.EMapTyped ((t, ps)) -> Ast.EMapTyped (t, List.map (fn (k, v) -> (strip_e k, strip_e v)) ps)
    | Ast.ESet es -> Ast.ESet (List.map strip_e es)
    | Ast.ECollTyped ((t, es)) -> Ast.ECollTyped (t, List.map strip_e es)
    | Ast.EPolyVariant ((tag, eo)) -> Ast.EPolyVariant (tag, Option.map strip_e eo)
    | Ast.ECoerce ((e, t)) -> Ast.ECoerce (strip_e e, t)
    | Ast.ELocalOpen ((m, e)) -> Ast.ELocalOpen (m, strip_e e)


  pub let strip_letrec (b : Ast.letrec_binding) : Ast.letrec_binding = {b with params = List.map norm_param b.params; body = strip_e b.body}

  pub let rec strip_decl (d : Ast.decl) : Ast.decl =
    match d with
    | Ast.DLet r -> Ast.DLet {r with params = List.map norm_param r.params; body = strip_e r.body}
    | Ast.DLetMut ((n, e)) -> Ast.DLetMut (n, strip_e e)
    | Ast.DLetRec b -> Ast.DLetRec (strip_letrec b)
    | Ast.DLetRecAnd bs -> Ast.DLetRecAnd (List.map strip_letrec bs)
    | Ast.DExpr e -> Ast.DExpr (strip_e e)
    | Ast.DInstance r -> Ast.DInstance {r with inst_methods = List.map (fn (n, ps, e) -> (n, List.map norm_param ps, strip_e e)) r.inst_methods}
    | Ast.DModule ((n, items)) -> Ast.DModule (n, List.map (fn (md : Ast.module_decl) -> {md with decl = strip_decl md.decl}) items)
    | ((((((Ast.DType _ | Ast.DTypeAnd _) | Ast.DClass _) | Ast.DEffect _) | Ast.DExtern _) | Ast.DFfi _) | Ast.DOpen _) as d -> d


  pub let strip_program (p : Ast.program) : Ast.program = List.map strip_decl p

end
