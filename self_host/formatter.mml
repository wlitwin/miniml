module Formatter =
  effect UnsupportedExn =
    unsupported : string -> 'a
  end

  effect Reanchor_bailExn =
    reanchor_bail : unit -> 'a
  end

  pub type comment = {
    cs: int;
    ce: int;
    cnext: int;
    ctext: string;
    cown: bool
  }

  pub let render_pending = Ref.create []

  pub let member_marks = Ref.create None

  pub let comment_lines (c : comment) : string list =
    let lead l =
      let n = Ref.create 0 in
      for ((Ref.get n) < (String.length l)) && (((String.get l (Ref.get n)) = #20) || ((String.get l (Ref.get n)) = #09)) do
        Ref.set n (Ref.get n + 1)
      end;
      Ref.get n in
    match String.split "\n" c.ctext with
    | ([] | _ :: []) as ls -> ls
    | first :: rest -> 
      let nonblank = List.filter (fn l -> (String.trim l) <> "") rest in
      let minlead =
        match nonblank with
        | [] -> 0
        | hd :: tl -> List.fold (fn m l -> min m (lead l)) (lead hd) tl
       in
      let fix l =
        if (String.trim l) = "" do
          ""
        else do
          let li = lead l in
          (String.make (li - minlead) #20) ^ (String.sub l li ((String.length l) - li))
        end in
      first :: List.map fix rest


  pub type doc =
    | Nil
    | Text of string
    | Line
    | GLine
    | GSoft
    | Cat of doc * doc
    | Nest of int * doc
    | Group of doc
    | Mark of int


  pub let __op_5e5e a b = Cat (a, b)

  pub let text s = Text s

  pub let line = Line

  pub let concat ds = List.fold __op_5e5e Nil ds

  pub let rec sepby sep =
    fn
      | [] -> Nil
      | d :: [] -> d
      | d :: rest -> __op_5e5e (d) (__op_5e5e (sep) (sepby sep rest))


  pub let max_width = 80

  pub let render (d : doc) : string =
    let buf = Buffer.create 1024 in
    let newline indent =
      Buffer.add_byte buf #0a;
      let mut _loop_var = 1 in
      for _loop_var <= indent do
        Buffer.add_byte buf #20;
        _loop_var := _loop_var + 1
      end in
    let will_flush off = List.exists (fn c -> c.cnext = off) (Ref.get render_pending) in
    let rec forces_break =
      fn
        | Line -> true
        | Mark off -> will_flush off
        | Cat ((a, b)) -> (forces_break a) || (forces_break b)
        | (Nest ((_, a)) | Group a) -> forces_break a
        | _ -> false
     in
    let rec fits rem items =
      if rem < 0 do
        false
      else
        match items with
        | [] -> true
        | (i, flat, d) :: rest -> 
          do
            match d with
            | Nil -> fits rem rest
            | Text s -> fits (rem - (String.length s)) rest
            | Cat ((a, b)) -> fits rem ((i, flat, a) :: (i, flat, b) :: rest)
            | Nest ((n, a)) -> fits rem ((i + n, flat, a) :: rest)
            | Group a -> fits rem ((i, true, a) :: rest)
            | Line -> true
            | GLine -> 
              if flat do
                fits (rem - 1) rest
              else
                true
            | GSoft -> 
              if flat do
                fits rem rest
              else
                true
            | Mark off -> 
              if will_flush off do
                true
              else
                fits rem rest

          end
     in
    let rec go col stack =
      match stack with
      | [] -> ()
      | (i, flat, d) :: rest -> 
        do
          match d with
          | Nil -> go col rest
          | Text s -> 
            Buffer.add_string buf s;
            go (col + (String.length s)) rest
          | Cat ((a, b)) -> go col ((i, flat, a) :: (i, flat, b) :: rest)
          | Nest ((n, a)) -> go col ((i + n, flat, a) :: rest)
          | Line -> 
            newline i;
            go i rest
          | GLine -> 
            if flat do
              Buffer.add_byte buf #20;
              go (col + 1) rest
            else do
              newline i;
              go i rest
            end
          | GSoft -> 
            if flat do
              go col rest
            else do
              newline i;
              go i rest
            end
          | Group a -> 
            let flat' = (not (forces_break a)) && (fits (max_width - col) ((i, true, a) :: rest)) in
            go col ((i, flat', a) :: rest)
          | Mark off -> 
            let flushed = Ref.create false in
            Ref.set render_pending (List.filter (fn c -> if c.cnext = off do
              do
                match comment_lines c with
                | [] -> ()
                | first :: conts -> 
                  Buffer.add_string buf first;
                  List.iter (fn l -> newline i;
                  Buffer.add_string buf l) conts

              end;
              newline i;
              Ref.set flushed true;
              false
            else
              true) (Ref.get render_pending));
            go (if Ref.get flushed do
              i
            else
              col) rest

        end
     in
    go 0 ((0, false, d) :: []);
    Buffer.contents buf

  pub let indent_width = 2

  pub let nest d = Nest (indent_width, d)

  pub let parens d = __op_5e5e (text "(") (__op_5e5e (d) (text ")"))

  pub let group d = Group d

  pub let wrap op cl pad sep (items : doc list) : doc =
    match items with
    | [] -> __op_5e5e (text op) (text cl)
    | _ -> 
      let edge =
        if pad do
          GLine
        else
          GSoft in
      group (__op_5e5e (text op) (__op_5e5e (nest (__op_5e5e (edge) (sepby (__op_5e5e (text sep) (GLine)) items))) (__op_5e5e (edge) (text cl))))


  pub let string_lit s =
    let buf = Buffer.create ((String.length s) + 2) in
    Buffer.add_byte buf #22;
    let n = String.length s in
    let rec go i =
      if i < n do
        do
          match String.get s i with
          | _c when _c = #22 -> Buffer.add_string buf "\\\""
          | _c when _c = #5c -> Buffer.add_string buf "\\\\"
          | _c when _c = #0a -> Buffer.add_string buf "\\n"
          | _c when _c = #09 -> Buffer.add_string buf "\\t"
          | c -> Buffer.add_byte buf c

        end;
        go (i + 1)
      end in
    go 0;
    Buffer.add_byte buf #22;
    Buffer.contents buf

  pub let rune_lit cp =
    let body =
      match cp with
      | 10 -> "\\n"
      | 9 -> "\\t"
      | 92 -> "\\\\"
      | 39 -> "\\'"
      | 0 -> "\\0"
      | _ when (cp >= 32) && (cp < 127) -> String.make 1 (Byte.of_int cp)
      | _ -> Utf8.rune_to_string cp
     in
    "'" ^ (body ^ "'")

  pub let float_lit f =
    let lexes_to s =
      match Lexer.tokenize s with
      | {kind = Token.FLOAT g; _} :: {kind = Token.EOF; _} :: [] -> g = f
      | _ -> false
     in
    let has_exp s = (String.contains "e" s) || (String.contains "E" s) in
    let rec try_g p =
      if p > 17 do
        None
      else do
        let s = $"{__fmt_float_g p f}" in
        if has_exp s do
          try_g (p + 1)
        else do
          let s =
            if String.contains "." s do
              s
            else
              s ^ ".0" in
          if lexes_to s do
            Some s
          else
            try_g (p + 1)
        end
      end in
    match try_g 1 with
    | Some s -> s
    | None -> 
      let rec try_f p =
        if p > 30 do
          $"{f:.17f}"
        else do
          let s = $"{__fmt_float p f}" in
          if lexes_to s do
            s
          else
            try_f (p + 1)
        end in
      try_f 1


  pub let rec doc_ty (t : Ast.ty_annot) : doc =
    match t with
    | Ast.TyName s -> text s
    | Ast.TyVar s -> text ("'" ^ s)
    | Ast.TyList t -> __op_5e5e (doc_ty_atom t) (text " list")
    | Ast.TyArray t -> __op_5e5e (doc_ty_atom t) (text " array")
    | Ast.TyArrow ((a, b, eff)) -> 
      do
        let base = __op_5e5e (doc_ty_atom a) (__op_5e5e (text " -> ") (doc_ty b)) in
        match eff with
        | None -> base
        | Some e -> __op_5e5e (base) (__op_5e5e (text " / ") (doc_eff_bare e))

      end
    | Ast.TyTuple ts -> sepby (text " * ") (List.map doc_ty_atom ts)
    | Ast.TyApp ((args, name)) -> 
      do
        match args with
        | [] -> text name
        | a :: [] -> __op_5e5e (doc_ty_atom a) (__op_5e5e (text " ") (text name))
        | _ -> __op_5e5e (parens (sepby (text ", ") (List.map doc_ty args))) (__op_5e5e (text " ") (text name))

      end
    | Ast.TyQualified ((path, name)) -> text ((String.concat "." path) ^ ("." ^ name))
    | Ast.TyRecord ((fields, is_open)) -> 
      let fs = List.concat (List.map (fn (n, t) -> __op_5e5e (text (n ^ " : ")) (doc_ty t)) fields) (if is_open do
        text ".." :: []
      else
        []) in
      __op_5e5e (text "{ ") (__op_5e5e (sepby (text "; ") fs) (text " }"))
    | Ast.TyWithEffect ((t, e)) -> __op_5e5e (doc_ty t) (__op_5e5e (text " / ") (doc_eff_bare e))
    | Ast.TyPolyVariant ((kind, tags)) -> 
      let open_marker =
        match kind with
        | Ast.PVExact -> ""
        | Ast.PVLower -> "> "
        | Ast.PVUpper -> "< "
       in
      let tag (name, payload) =
        match payload with
        | None -> text ("`" ^ name)
        | Some t -> __op_5e5e (text ("`" ^ (name ^ " of "))) (doc_ty t)
       in
      __op_5e5e (text ("[" ^ open_marker)) (__op_5e5e (sepby (text " | ") (List.map tag tags)) (text "]"))

  and doc_eff (e : Ast.eff_annot) : doc =
    match e with
    | Ast.EffAnnotPure -> Nil
    | Ast.EffAnnotRow _ -> doc_eff_bare e

  and doc_eff_bare (e : Ast.eff_annot) : doc =
    match e with
    | Ast.EffAnnotPure -> text "pure"
    | Ast.EffAnnotRow items -> sepby (text ", ") (List.map (fn
      | Ast.EffLabel ((n, [])) -> text n
      | Ast.EffLabel ((n, args)) -> __op_5e5e (text n) (__op_5e5e (text " ") (sepby (text " ") (List.map doc_ty_atom args)))
      | Ast.EffVar v -> text ("'" ^ v)
    ) items)

  and doc_ty_atom (t : Ast.ty_annot) : doc =
    match t with
    | ((((Ast.TyName _ | Ast.TyVar _) | Ast.TyQualified _) | Ast.TyRecord _) | Ast.TyPolyVariant _) -> doc_ty t
    | _ -> parens (doc_ty t)


  pub let rec doc_pat (p : Ast.pattern) : doc =
    match p with
    | Ast.PatWild -> text "_"
    | Ast.PatVar s -> text s
    | Ast.PatInt n -> text (string_of_int n)
    | Ast.PatFloat f -> text (float_lit f)
    | Ast.PatBool b -> text (if b do
      "true"
    else
      "false")
    | Ast.PatString s -> text (string_lit s)
    | Ast.PatUnit -> text "()"
    | Ast.PatNil -> text "[]"
    | Ast.PatTuple ps -> parens (sepby (text ", ") (List.map doc_pat ps))
    | Ast.PatCons ((a, b)) -> __op_5e5e (doc_pat_atom a) (__op_5e5e (text " :: ") (doc_pat_atom b))
    | Ast.PatConstruct ((name, None)) -> text name
    | Ast.PatConstruct ((name, Some arg)) -> __op_5e5e (text name) (__op_5e5e (text " ") (doc_pat_atom arg))
    | Ast.PatRecord fields -> __op_5e5e (text "{ ") (__op_5e5e (sepby (text "; ") (List.map (fn (n, p) -> __op_5e5e (text (n ^ " = ")) (doc_pat p)) fields)) (text " }"))
    | Ast.PatAs ((p, name)) -> __op_5e5e (doc_pat_atom p) (text (" as " ^ name))
    | Ast.PatOr ((a, b)) -> __op_5e5e (doc_pat a) (__op_5e5e (text " | ") (doc_pat b))
    | Ast.PatArray ps -> __op_5e5e (text "#[") (__op_5e5e (sepby (text "; ") (List.map doc_pat ps)) (text "]"))
    | Ast.PatPolyVariant ((tag, None)) -> text ("`" ^ tag)
    | Ast.PatPolyVariant ((tag, Some p)) -> __op_5e5e (text ("`" ^ (tag ^ " "))) (doc_pat_atom p)
    | Ast.PatPin name -> text ("^" ^ name)
    | Ast.PatAnnot ((p, t)) -> parens (__op_5e5e (doc_pat p) (__op_5e5e (text " : ") (doc_ty t)))
    | Ast.PatMap entries -> __op_5e5e (text "#{") (__op_5e5e (sepby (text "; ") (List.map (fn (k, v) -> __op_5e5e (doc_pat k) (__op_5e5e (text ": ") (doc_pat v))) entries)) (text "}"))
    | Ast.PatSet elems -> __op_5e5e (text "#{") (__op_5e5e (sepby (text "; ") (List.map doc_pat elems)) (text "}"))

  and doc_pat_atom (p : Ast.pattern) : doc =
    match p with
    | (((((((((((((((Ast.PatWild | Ast.PatVar _) | Ast.PatInt _) | Ast.PatFloat _) | Ast.PatBool _) | Ast.PatString _) | Ast.PatUnit) | Ast.PatNil) | Ast.PatTuple _) | Ast.PatRecord _) | Ast.PatArray _) | Ast.PatConstruct ((_, None))) | Ast.PatPolyVariant ((_, None))) | Ast.PatPin _) | Ast.PatMap _) | Ast.PatSet _) -> doc_pat p
    | _ -> parens (doc_pat p)


  pub let binop_str =
    fn
      | Ast.Add -> "+"
      | Ast.Sub -> "-"
      | Ast.Mul -> "*"
      | Ast.Div -> "/"
      | Ast.Mod -> "mod"
      | Ast.Eq -> "="
      | Ast.Neq -> "<>"
      | Ast.Lt -> "<"
      | Ast.Gt -> ">"
      | Ast.Le -> "<="
      | Ast.Ge -> ">="
      | Ast.And -> "&&"
      | Ast.Or -> "||"
      | Ast.Concat -> "^"
      | Ast.Land -> "land"
      | Ast.Lor -> "lor"
      | Ast.Lxor -> "lxor"
      | Ast.Lsl -> "lsl"
      | Ast.Lsr -> "lsr"
      | Ast.Pipe -> "|>"


  pub let unop_str =
    fn
      | Ast.Neg -> "-"
      | Ast.Not -> "not "
      | Ast.Lnot -> "lnot "


  pub let is_keyword_operator =
    fn
      | ((((((("land" | "lor") | "lxor") | "lsl") | "lsr") | "lnot") | "mod") | "not") -> true
      | _ -> false


  pub let is_operator_name s = (s <> "") && (let c = String.get s 0 in
  (not (((c >= #61) && (c <= #7a)) || (((c >= #41) && (c <= #5a)) || (c = #5f)))) || (is_keyword_operator s))

  -- Surface name of a C type (cty), round-tripping through the FFI parser.
  let cty_str (c : Ast.cty) : string =
    match c with
    | Ast.CI8 -> "i8" | Ast.CI16 -> "i16" | Ast.CI32 -> "i32" | Ast.CI64 -> "i64"
    | Ast.CU8 -> "u8" | Ast.CU16 -> "u16" | Ast.CU32 -> "u32" | Ast.CU64 -> "u64"
    | Ast.CF32 -> "f32" | Ast.CF64 -> "f64"
    | Ast.CStr -> "cstr" | Ast.CPtr -> "ptr" | Ast.CBool -> "bool" | Ast.CVoid -> "unit"
    | Ast.CNamed name -> name

  pub let doc_var s =
    match String.rindex_opt s #2e with
    | Some i when (i > 0) && (i < ((String.length s) - 1)) -> 
      let modpath = String.sub s 0 i in
      let last = String.sub s (i + 1) (((String.length s) - i) - 1) in
      if is_operator_name last do
        text (modpath ^ (".(" ^ (last ^ ")")))
      else
        text s
    | _ -> 
      if is_operator_name s do
        text ("(" ^ (s ^ ")"))
      else
        text s


  pub let tp_clause =
    fn
      | [] -> Nil
      | tps -> __op_5e5e (text " (type ") (__op_5e5e (sepby (text " ") (List.map (fn t -> text ("'" ^ t)) tps)) (text ")"))


  pub let rec strip_loc (e : Ast.expr) : Ast.expr =
    match e with
    | Ast.ELoc ((_, e)) -> strip_loc e
    | e -> e


  pub let is_atom (e : Ast.expr) : bool =
    match strip_loc e with
    | ((((((((((((((((((Ast.EInt _ | Ast.EFloat _) | Ast.EBool _) | Ast.EString _) | Ast.EByte _) | Ast.ERune _) | Ast.EUnit) | Ast.EVar _) | Ast.ENil) | Ast.ETuple _) | Ast.EList _) | Ast.EArray _) | Ast.ERecord _) | Ast.EMap _) | Ast.ESet _) | Ast.EConstruct ((_, None))) | Ast.EPolyVariant ((_, None))) | Ast.EField _) | Ast.EIndex _) -> true
    | _ -> false


  pub let body_stays_inline (e : Ast.expr) : bool =
    match strip_loc e with
    | ((((((((((((Ast.ELet _ | Ast.ELetMut _) | Ast.ELetRec _) | Ast.ELetRecAnd _) | Ast.ESeq _) | Ast.EMatch _) | Ast.EHandle _) | Ast.EIf _) | Ast.EWhile _) | Ast.EFor _) | Ast.EForFold _) | Ast.EForNumeric _) | Ast.EWhileLet _) -> true
    | _ -> false


  pub let binop_prec =
    fn
      | Ast.Pipe -> 1
      | Ast.Or -> 2
      | Ast.And -> 3
      | (((((Ast.Eq | Ast.Neq) | Ast.Lt) | Ast.Gt) | Ast.Le) | Ast.Ge) -> 4
      | ((((Ast.Add | Ast.Sub) | Ast.Concat) | Ast.Lor) | Ast.Lxor) -> 7
      | (((((Ast.Mul | Ast.Div) | Ast.Mod) | Ast.Land) | Ast.Lsl) | Ast.Lsr) -> 8


  pub let cons_prec = 6

  pub type operand_kind =
    | Tight
    | OpK of int
    | Loose


  pub let operand_kind (e : Ast.expr) : operand_kind =
    match strip_loc e with
    | Ast.EBinop ((op, _, _)) -> OpK (binop_prec op)
    | Ast.ECons _ -> OpK cons_prec
    | ((((((((((((((((((((Ast.EInt _ | Ast.EFloat _) | Ast.EBool _) | Ast.EString _) | Ast.EByte _) | Ast.ERune _) | Ast.EUnit) | Ast.EVar _) | Ast.ENil) | Ast.ETuple _) | Ast.EList _) | Ast.EArray _) | Ast.ERecord _) | Ast.ERecordUpdate _) | Ast.EMap _) | Ast.ESet _) | Ast.EConstruct ((_, None))) | Ast.EPolyVariant ((_, None))) | Ast.EField _) | Ast.EIndex _) | Ast.EApp _) -> Tight
    | _ -> Loose


  pub let rec flatten_binop prec (e : Ast.expr) : Ast.expr * (Ast.binop * Ast.expr) list =
    match strip_loc e with
    | Ast.EBinop ((op, l, r)) when (binop_prec op) = prec -> 
      let (first, rest) = flatten_binop prec l in
      (first, List.concat rest ((op, r) :: []))
    | _ -> (e, [])


  pub let is_destructure_pat (p : Ast.pattern) : bool =
    match p with
    | (Ast.PatTuple _ | Ast.PatRecord _) -> true
    | _ -> false


  pub let rec absorbs_semicolon (e : Ast.expr) : bool =
    match strip_loc e with
    | ((((((Ast.EFun _ | Ast.EMatch _) | Ast.EHandle _) | Ast.ELet _) | Ast.ELetRec _) | Ast.ELetMut _) | Ast.ELetRecAnd _) -> true
    | Ast.ESeq ((_, b)) -> absorbs_semicolon b
    | Ast.EIf ((_, _, f)) -> 
      do
        match strip_loc f with
        | Ast.EUnit -> false
        | _ -> absorbs_semicolon f

      end
    | _ -> false


  pub let rec absorbs_pipe (e : Ast.expr) : bool =
    match strip_loc e with
    | (Ast.EMatch _ | Ast.EHandle _) -> true
    | ((Ast.ELet ((_, _, b)) | Ast.ELetMut ((_, _, b))) | Ast.ELetRec ((_, _, _, b))) -> absorbs_pipe b
    | (Ast.ELetRecAnd ((_, b)) | Ast.EFun ((_, b))) -> absorbs_pipe b
    | Ast.EIf ((_, _, f)) -> 
      do
        match strip_loc f with
        | Ast.EUnit -> false
        | _ -> absorbs_pipe f

      end
    | Ast.ESeq ((_, b)) -> absorbs_pipe b
    | _ -> false


  pub let rec start_offset (e : Ast.expr) : int option =
    match e with
    | Ast.ELoc ((loc, _)) -> Some (loc.offset)
    | (((((Ast.ESeq ((a, _)) | Ast.EBinop ((_, a, _))) | Ast.ECons ((a, _))) | Ast.EApp ((a, _))) | Ast.EField ((a, _))) | Ast.EIndex ((a, _))) -> start_offset a
    | _ -> None


  pub let mark (e : Ast.expr) : doc =
    match start_offset e with
    | Some o -> Mark o
    | None -> Nil


  pub let member_mark i : doc =
    match Ref.get member_marks with
    | Some arr when i < (Array.length arr) -> Mark (Array.get arr i)
    | _ -> Nil


  pub let rec doc_expr (e : Ast.expr) : doc = __op_5e5e (mark e) (doc_expr_body e)
  and doc_expr_body (e : Ast.expr) : doc =
    match strip_loc e with
    | Ast.EInt n -> text (string_of_int n)
    | Ast.EFloat f -> text (float_lit f)
    | Ast.EBool b -> text (if b do
      "true"
    else
      "false")
    | Ast.EString s -> text (string_lit s)
    | Ast.EByte n -> text ($"#{n:02x}")
    | Ast.ERune n -> text (rune_lit n)
    | Ast.EUnit -> text "()"
    | Ast.EVar s -> doc_var s
    | Ast.ENil -> text "[]"
    | Ast.ETuple es -> wrap "(" ")" false "," (List.map doc_expr es)
    | Ast.EList es -> wrap "[" "]" false ";" (List.map doc_expr es)
    | Ast.EArray es -> wrap "#[" "]" false ";" (List.map doc_expr es)
    | Ast.ERecord fields -> doc_record_fields fields
    | Ast.ERecordUpdate ((base, fields)) -> __op_5e5e (text "{ ") (__op_5e5e (doc_atom base) (__op_5e5e (text " with ") (__op_5e5e (sepby (text "; ") (List.map (fn (n, e) -> __op_5e5e (text (n ^ " = ")) (doc_expr e)) fields)) (text " }"))))
    | Ast.EField ((e, f)) -> __op_5e5e (doc_atom e) (text ("." ^ f))
    | Ast.EIndex ((e, i)) -> __op_5e5e (doc_atom e) (__op_5e5e (text ".[") (__op_5e5e (doc_expr i) (text "]")))
    | Ast.EConstruct ((name, None)) -> text name
    | Ast.EConstruct ((name, Some arg)) -> __op_5e5e (text name) (__op_5e5e (text " ") (doc_arg arg))
    | Ast.EPolyVariant ((tag, None)) -> text ("`" ^ tag)
    | Ast.EPolyVariant ((tag, Some arg)) -> __op_5e5e (text ("`" ^ (tag ^ " "))) (doc_arg arg)
    | Ast.ECons ((a, b)) -> __op_5e5e (doc_oper cons_prec true true a) (__op_5e5e (text " :: ") (doc_oper cons_prec true false b))
    | Ast.EBinop ((op, _, _)) -> 
      let p = binop_prec op in
      let (first, steps) = flatten_binop p (strip_loc e) in
      group (__op_5e5e (doc_oper p false true first) (concat (List.map (fn (o, operand) -> __op_5e5e (GLine) (__op_5e5e (text ((binop_str o) ^ " ")) (doc_oper p false false operand))) steps)))
    | Ast.EUnop ((op, e)) -> __op_5e5e (text (unop_str op)) (doc_atom e)
    | Ast.EApp _ as app -> doc_app app
    | Ast.EAnnot ((e, t)) -> parens (__op_5e5e (doc_expr e) (__op_5e5e (text " : ") (doc_ty t)))
    | Ast.ECoerce ((e, t)) -> parens (__op_5e5e (doc_expr e) (__op_5e5e (text " :> ") (doc_ty t)))
    | Ast.EAssign ((name, e)) -> __op_5e5e (text (name ^ " := ")) (doc_seq_lhs e)
