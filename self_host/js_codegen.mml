    | _ -> None

  and compile_cps_form_arg ctx a =
    let already_cps_form =
      match a.expr with
      | Typechecker.TEVar name -> 
        let jsn = lookup_var ctx name in
        (Hashtbl.has ctx.cps_form_vars jsn) || ((Hashtbl.has ctx.twinnable jsn) || (Hashtbl.has ctx.local_twins jsn))
      | _ -> false
