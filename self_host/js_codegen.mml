    let param_types ty =
      let rec go ty =
        match Types.repr ty with
        | (Types.TArrow ((a, _, r)) | Types.TCont ((a, _, r))) -> a :: go r
        | _ -> []
       in
      go ty in
    let flags_of ptys = Some (List.init nargs (fn i ->
