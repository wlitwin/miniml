      List.iter (fn (name, js_name, te) -> bind_var ctx name js_name;
      if ((List.length ctx.scopes) = 1) && (is_exportable_name name) do
        ctx.top_level_exports := (name, js_name) :: ctx.top_level_exports
      end;
