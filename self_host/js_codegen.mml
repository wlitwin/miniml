    end
  and compile_dict_record ctx js_name methods =
    let sorted = List.sort (fn (a, _) (b, _) -> String.compare a b) methods in
    let fields = List.concat_map (fn (mname, mexpr) -> let v = compile_non_tail ctx mexpr in
    let jn = mangle_name mname in
    let base_field =
