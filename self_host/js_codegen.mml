  pub let compile_program type_env (program : Typechecker.tprogram) : string =
    let ctx = create_ctx type_env in
    emit ctx js_runtime;
    emit ctx js_builtins;
    emit ctx "// --- Compiled MiniML ---\n";
    emit ctx "let _last_val;\n";
    emit ctx "let _last_ty = null;\n";
    emit ctx "let _last_shape = null;\n";
    List.iter (compile_decl ctx) program;
    drain_cps_twins ctx;
    emit ctx "{ const _r = _last_ty === \"float\" ? __display_float(_last_val) : _last_ty === \"byte\" ? __show_byte(_last_val) : _pp(_last_val, _last_shape); if (!(_output_count > 0 && _r === \"()\")) println(_r); }\n";
