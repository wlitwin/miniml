      let raw = compile_non_tail ctx a in
      let arity =
        match count_arrows a.ty with
        | Some n when n > 0 -> n
        | _ -> 1
       in
      let params = List.init arity (fn _ -> fresh_tmp ctx) in
      let k_param = "$k" in
      let fn_name = fresh_tmp ctx in
      emit_line ctx ($"function {fn_name}({String.concat ", " (List.concat params (k_param :: []))}) \{");
      ctx.indent := ctx.indent + 1;
      emit_line ctx ($"return _bounce(function() \{ return {k_param}(_call({raw}, [{String.concat ", " params}])); \});");
      ctx.indent := ctx.indent - 1;
      emit_line ctx "}";
