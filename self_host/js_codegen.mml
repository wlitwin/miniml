  emit_line ctx ($"const {js_nm} = {js_expr};")) bindings;
  do
    match guard with
    | Some g -> 
      let guard_js = compile_non_tail ctx g in
      emit_line ctx ($"if ({guard_js}) \{");
      ctx.indent := ctx.indent + 1;
      emit_line ctx ($"{matched} = true;");
      compile_cps ctx body cont;
      ctx.indent := ctx.indent - 1;
      emit_line ctx "}"
    | None -> 
      emit_line ctx ($"{matched} = true;");
      compile_cps ctx body cont

