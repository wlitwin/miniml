  and compile_app_cps ctx te fn_ arg cont =
    let rec collect_args expr acc =
      match expr.expr with
      | Typechecker.TEApp ((inner_fn, inner_arg)) -> collect_args inner_fn (inner_arg :: acc)
      | _ -> (expr, acc)
     in
    let (base_fn, all_args) = collect_args fn_ (arg :: []) in
    if is_twin_call ctx te do
      let fn_cps = compile_cps_value ctx base_fn in
      let cps_flags = twin_cps_arg_flags ctx base_fn (List.length all_args) in
      let args_js = List.mapi (fn i a -> let expects_cps =
        match cps_flags with
        | Some fl -> 
          do
            match List.nth_opt fl i with
            | Some b -> b
            | None -> false

          end
        | None -> needs_cps a.ty
       in
      if expects_cps do
        compile_cps_form_arg ctx a
      else
