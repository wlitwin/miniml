      add_extern ctx "mml_string_lowercase" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_lowercase" (("i64", a) :: [])
    | "String.to_byte_array" -> 
      let a = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_string_to_byte_array" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_to_byte_array" (("i64", a) :: [])
    | "String.of_byte_array" -> 
      let a = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_string_of_byte_array" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_of_byte_array" (("i64", a) :: [])
    | "String.make" -> 
      let n = emit_expr ctx (List.nth args 0) in
      let ch = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_string_make" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_make" (("i64", n) :: ("i64", ch) :: [])
    | "String.index_opt" -> 
      let str = emit_expr ctx (List.nth args 0) in
      let sub = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_string_index_opt" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_index_opt" (("i64", str) :: ("i64", sub) :: [])
    | "String.rindex_opt" -> 
      let str = emit_expr ctx (List.nth args 0) in
      let sub = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_string_rindex_opt" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_rindex_opt" (("i64", str) :: ("i64", sub) :: [])
    | "String.concat" -> 
      let sep = emit_expr ctx (List.nth args 0) in
      let lst = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_string_concat_list" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_concat_list" (("i64", sep) :: ("i64", lst) :: [])
    | "String.compare" -> 
      let a = emit_expr ctx (List.nth args 0) in
      let b = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_string_compare_str" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_compare_str" (("i64", a) :: ("i64", b) :: [])
    | "Array.sub" -> 
      let arr = emit_expr ctx (List.nth args 0) in
      let start = emit_expr ctx (List.nth args 1) in
      let len = emit_expr ctx (List.nth args 2) in
      add_extern ctx "mml_array_sub" "i64" ("i64" :: "i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_array_sub" (("i64", arr) :: ("i64", start) :: ("i64", len) :: [])
    -- a saturated typed-FFI call: marshal MiniML args/return per the cty signature
    | _ when Hashtbl.has ctx.ffi_externs name ->
      let (c_symbol, c_params, c_ret) = Hashtbl.find ctx.ffi_externs name in
      let arg_vals = List.map (fn a -> emit_expr ctx a) args in
      emit_ffi_call ctx c_symbol c_params c_ret arg_vals
    | _ when Hashtbl.has ctx.module_externs name ->
      let c_name = c_name_of_module_extern name in
      let arg_vals = List.map (emit_expr ctx) args in
      add_extern ctx c_name "i64" (List.map (fn _ -> "i64") arg_vals);
      Ir_emit.emit_call ctx.ir "i64" c_name (List.map (fn v -> ("i64", v)) arg_vals)
    | _ -> 
      do
        match lookup_var ctx name with
        | (Some (Func ((llvm_name, arity))) | Some (FuncLocal ((llvm_name, arity, _)))) -> 
          let n_args = List.length args in
          if n_args = arity do
            let arg_vals = List.map (emit_expr ctx) args in
            let arg_pairs = List.map (fn v -> ("i64", v)) arg_vals in
            Ir_emit.emit_call ctx.ir "i64" llvm_name arg_pairs
          else do
            let closure_val = emit_var ctx name f_expr.ty in
            let arg_vals = List.map (emit_expr ctx) args in
            emit_closure_apply ctx closure_val arg_vals
          end
        | Some ((((Local _ | MutLocal _) | MutRefCell _) | Global _) | MutGlobal _) -> 
          let closure_val = emit_var ctx name f_expr.ty in
          let arg_vals = List.map (emit_expr ctx) args in
          emit_closure_apply ctx closure_val arg_vals
        | None -> 
          do
            match emit_builtin_as_value ctx name f_expr.ty with
            | Some closure_val -> 
              let arg_vals = List.map (emit_expr ctx) args in
              emit_closure_apply ctx closure_val arg_vals
            | None -> failwith ($"native codegen: unbound function {name} (not yet implemented)")

          end

      end

  and emit_func_wrapper ctx wrapper_name real_name arity = with_fresh_ir ctx (fn fn_ir -> if arity <= 8 do
    let params = ("ptr", "%env") :: List.init arity (fn i -> ("i64", $"%a{i}")) in
    Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_name params;
    Ir_emit.emit_label fn_ir "entry";
    let call_args = List.init arity (fn i -> ("i64", $"%a{i}")) in
    let result = Ir_emit.emit_call fn_ir "i64" real_name call_args in
    Ir_emit.emit_ret fn_ir "i64" result
  else do
    let params = ("ptr", "%env") :: ("ptr", "%args") :: [] in
    Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_name params;
    Ir_emit.emit_label fn_ir "entry";
    let call_args = List.init arity (fn i -> let ptr = Ir_emit.emit_gep fn_ir "i64" "%args" i in
    let v = Ir_emit.emit_load fn_ir "i64" ptr in
    ("i64", v)) in
    let result = Ir_emit.emit_call fn_ir "i64" real_name call_args in
    Ir_emit.emit_ret fn_ir "i64" result
  end;
  Ir_emit.emit_define_end fn_ir)
  and emit_func_as_closure ctx llvm_name arity =
    let wrapper_name = $"{llvm_name}_wrap" in
    if not (Hashtbl.has ctx.generated_wrappers wrapper_name) do
      Hashtbl.set ctx.generated_wrappers wrapper_name ();
      emit_func_wrapper ctx wrapper_name llvm_name arity
    end;
    emit_make_closure ctx wrapper_name arity []
  and emit_lambda_as_closure ctx (expr : Typechecker.texpr) =
    let (params, body) = flatten_fun expr in
    let arity = List.length params in
    if arity = 0 do
      failwith "native codegen: zero-arity lambda"
    end;
    let fn_name = $"mml_anon_{ctx.unit_prefix}{ctx.fn_counter}" in
    ctx.fn_counter := ctx.fn_counter + 1;
    let free = free_vars_of_fun (Some ctx) params body in
    if free = [] do
      emit_closure_function ctx fn_name params body [];
      emit_make_closure ctx fn_name arity []
    else do
      let free_with_info = List.map (fn name ->
        do
          match lookup_var ctx name with
          | Some info -> (name, info)
          | None -> failwith ($"native codegen: free var {name} not found")

        end) free in
      emit_closure_function ctx fn_name params body free_with_info;
      let captures = List.map (fn (name, info) -> emit_capture_value ctx name info) free_with_info in
      emit_make_closure ctx fn_name arity captures
    end
  and emit_capture_value ctx _name info =
    match info with
    | Local ptr -> Ir_emit.emit_load ctx.ir "i64" ptr
    | MutLocal ptr -> Ir_emit.emit_load ctx.ir "i64" ptr
    | MutRefCell alloca_ptr -> Ir_emit.emit_load ctx.ir "i64" alloca_ptr
    | Global gname -> Ir_emit.emit_load ctx.ir "i64" ($"@{gname}")
    | MutGlobal gname -> Ir_emit.emit_load ctx.ir "i64" ($"@{gname}")
    | Func ((llvm_name, arity)) -> emit_func_as_closure ctx llvm_name arity
    | FuncLocal ((_, _, alloca_ptr)) -> Ir_emit.emit_load ctx.ir "i64" alloca_ptr

  and emit_closure_function ctx fn_name params body free_with_info =
    let do_fold_guard = ctx.fold_guard_pending in
    ctx.fold_guard_pending := false;
    with_fresh_ir ctx (fn fn_ir -> let outer_scopes = ctx.scopes in
    let arity = List.length params in
    let high_arity = arity > 8 in
    let seen = Hashtbl.create 8 in
    let unique_params = List.map (fn p -> let base = sanitize_name p in
    if Hashtbl.has seen base do
      let n = Hashtbl.find seen base in
      Hashtbl.set seen base (n + 1);
      (p, $"param_{base}_{n}")
    else do
      Hashtbl.set seen base 1;
      (p, $"param_{base}")
    end) params in
    let all_params =
      if high_arity do
        ("ptr", "%env") :: ("ptr", "%args") :: []
      else
        ("ptr", "%env") :: List.map (fn (_, llvm_p) -> ("i64", $"%{llvm_p}")) unique_params in
    Ir_emit.emit_define_start fn_ir "i64" fn_name all_params;
    Ir_emit.emit_label fn_ir "entry";
    ctx.current_label := "entry";
    ctx.loop_stack := [];
    let fn_scope = Hashtbl.create 16 in
    List.iter (fn scope -> Hashtbl.iter (fn name info ->
      do
        match info with
        | (((Func _ | FuncLocal _) | Global _) | MutGlobal _) -> 
          if not (Hashtbl.has fn_scope name) do
            Hashtbl.set fn_scope name info
          end
        | ((Local _ | MutLocal _) | MutRefCell _) -> ()

      end) scope) outer_scopes;
    ctx.scopes := fn_scope :: [];
    List.iteri (fn i (name, info) -> let env_slot = Ir_emit.emit_gep fn_ir "i64" "%env" (3 + i) in
    let cap_val = Ir_emit.emit_load fn_ir "i64" env_slot in
    match info with
    | ((MutLocal _ | MutRefCell _) | MutGlobal _) -> 
      let alloca_ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" cap_val alloca_ptr;
      bind_var ctx name (MutRefCell alloca_ptr)
    | _ -> 
      let ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" cap_val ptr;
      bind_var ctx name (Local ptr)
    ) free_with_info;
    if high_arity do
      List.iteri (fn i (p, _) -> let arg_ptr = Ir_emit.emit_gep fn_ir "i64" "%args" i in
      let arg_val = Ir_emit.emit_load fn_ir "i64" arg_ptr in
      let ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" arg_val ptr;
      bind_var ctx p (Local ptr)) unique_params
    else
      List.iter (fn (p, llvm_p) -> let ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" ($"%{llvm_p}") ptr;
      bind_var ctx p (Local ptr)) unique_params;
    if do_fold_guard && ((not high_arity) && (unique_params <> [])) do
      let acc_ssa = $"%{snd (List.hd unique_params)}" in
      add_extern ctx "mml_check_fold_broken" "i64" [];
      add_extern ctx "mml_check_early_return" "i64" [];
      let broken = Ir_emit.emit_call ctx.ir "i64" "mml_check_fold_broken" [] in
      let b1 = Ir_emit.emit_icmp ctx.ir "ne" "i64" broken "0" in
      let ret_lbl = fresh_label ctx "fold_guard_ret" in
      let chk2 = fresh_label ctx "fold_guard_chk2" in
      let cont = fresh_label ctx "fold_guard_cont" in
      Ir_emit.emit_condbr ctx.ir b1 ret_lbl chk2;
      Ir_emit.emit_label ctx.ir chk2;
      ctx.current_label := chk2;
      let early = Ir_emit.emit_call ctx.ir "i64" "mml_check_early_return" [] in
      let b2 = Ir_emit.emit_icmp ctx.ir "ne" "i64" early "0" in
      Ir_emit.emit_condbr ctx.ir b2 ret_lbl cont;
      Ir_emit.emit_label ctx.ir ret_lbl;
      ctx.current_label := ret_lbl;
      emit_ctl_ret ctx acc_ssa;
      Ir_emit.emit_label ctx.ir cont;
      ctx.current_label := cont
    end;
    setup_handler_mark ctx body;
    let body_result = emit_expr ctx body in
    Ir_emit.emit_ret fn_ir "i64" body_result;
    Ir_emit.emit_define_end fn_ir)
  and emit_rt_unary_wrapper ctx wrapper_name rt_fn_name = with_fresh_ir ctx (fn fn_ir -> let params = ("ptr", "%env") :: ("i64", "%a0") :: [] in
  Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_name params;
  Ir_emit.emit_label fn_ir "entry";
  add_extern ctx rt_fn_name "i64" ("i64" :: []);
  let result = Ir_emit.emit_call fn_ir "i64" rt_fn_name (("i64", "%a0") :: []) in
  Ir_emit.emit_ret fn_ir "i64" result;
  Ir_emit.emit_define_end fn_ir)
  and emit_rt_binary_wrapper ctx wrapper_name rt_fn_name = with_fresh_ir ctx (fn fn_ir -> let params = ("ptr", "%env") :: ("i64", "%a0") :: ("i64", "%a1") :: [] in
  Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_name params;
  Ir_emit.emit_label fn_ir "entry";
  add_extern ctx rt_fn_name "i64" ("i64" :: "i64" :: []);
  let result = Ir_emit.emit_call fn_ir "i64" rt_fn_name (("i64", "%a0") :: ("i64", "%a1") :: []) in
  Ir_emit.emit_ret fn_ir "i64" result;
  Ir_emit.emit_define_end fn_ir)
  and emit_rt_ternary_wrapper ctx wrapper_name rt_fn_name = with_fresh_ir ctx (fn fn_ir -> let params = ("ptr", "%env") :: ("i64", "%a0") :: ("i64", "%a1") :: ("i64", "%a2") :: [] in
  Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_name params;
  Ir_emit.emit_label fn_ir "entry";
  add_extern ctx rt_fn_name "i64" ("i64" :: "i64" :: "i64" :: []);
  let result = Ir_emit.emit_call fn_ir "i64" rt_fn_name (("i64", "%a0") :: ("i64", "%a1") :: ("i64", "%a2") :: []) in
  Ir_emit.emit_ret fn_ir "i64" result;
  Ir_emit.emit_define_end fn_ir)
  and emit_show_closure ctx ty =
    let arg_ty =
      match ty with
      | Types.TArrow ((arg, _, _)) -> Types.repr arg
      | _ -> Types.TUnit
     in
    match arg_ty with
    | Types.TList elem_ty -> 
      let show_elem = emit_show_closure ctx (Types.TArrow (elem_ty, Types.EffEmpty, Types.TString)) in
      let fn_id = ctx.fn_counter in
      ctx.fn_counter := ctx.fn_counter + 1;
      let wrapper_name = $"mml_op_show_list_{ctx.unit_prefix}{fn_id}" in
      emit_show_compound_wrapper ctx wrapper_name "mml_show_list" 1;
      emit_make_closure ctx wrapper_name 1 (show_elem :: [])
    | Types.TArray elem_ty -> 
      let show_elem = emit_show_closure ctx (Types.TArrow (elem_ty, Types.EffEmpty, Types.TString)) in
      let fn_id = ctx.fn_counter in
      ctx.fn_counter := ctx.fn_counter + 1;
      let wrapper_name = $"mml_op_show_array_{ctx.unit_prefix}{fn_id}" in
      emit_show_compound_wrapper ctx wrapper_name "mml_show_array" 1;
      emit_make_closure ctx wrapper_name 1 (show_elem :: [])
    | Types.TTuple tys -> 
      let show_fns_list = List.fold_right (fn ety acc -> let show_fn = emit_show_closure ctx (Types.TArrow (Types.repr ety, Types.EffEmpty, Types.TString)) in
      let cell_ptr = emit_alloc ctx 16 (make_header 0 mml_hdr_cons) in
      Ir_emit.emit_store ctx.ir "i64" show_fn (Ir_emit.emit_gep ctx.ir "i64" cell_ptr 0);
      Ir_emit.emit_store ctx.ir "i64" acc (Ir_emit.emit_gep ctx.ir "i64" cell_ptr 1);
      Ir_emit.emit_ptrtoint ctx.ir cell_ptr) tys (tag_int 0) in
      let fn_id = ctx.fn_counter in
      ctx.fn_counter := ctx.fn_counter + 1;
      let wrapper_name = $"mml_op_show_tuple_{ctx.unit_prefix}{fn_id}" in
      emit_show_compound_wrapper ctx wrapper_name "mml_show_tuple" 1;
      emit_make_closure ctx wrapper_name 1 (show_fns_list :: [])
    | Types.TVariant ((type_name, ty_args)) -> 
      do
        match List.assoc_opt type_name ctx.variant_defs with
        | None -> 
          let wrapper_key = "mml_op_show_generic" in
          if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
            Hashtbl.set ctx.generated_wrappers wrapper_key ();
            emit_rt_unary_wrapper ctx wrapper_key "mml_show_value"
          end;
          add_extern ctx "mml_show_value" "i64" ("i64" :: []);
          emit_make_closure ctx wrapper_key 1 []
        | Some vdef -> 
          let instantiate_ty ty =
            let args = Array.of_list ty_args in
            let rec go t =
              match Types.repr t with
              | Types.TGen i when i < (Array.length args) -> Array.get args i
              | Types.TTuple ts -> Types.TTuple (List.map go ts)
              | Types.TVariant ((n, ts)) -> Types.TVariant (n, List.map go ts)
              | Types.TList t' -> Types.TList (go t')
              | Types.TArray t' -> Types.TArray (go t')
              | _ -> t
             in
            go ty in
          let ctors_list = List.fold_right (fn (i, (ctor_name, payload_ty)) acc -> let tag_val = tag_int i in
          let name_str = emit_expr ctx {expr = TEString ctor_name; ty = Types.TString; loc = Token.dummy_loc} in
          let show_fn =
            match payload_ty with
            | None -> unit_value
            | Some pty -> 
              let pty' = instantiate_ty (Types.repr pty) in
              emit_show_closure ctx (Types.TArrow (pty', Types.EffEmpty, Types.TString))
           in
          let triple_ptr = emit_alloc ctx 24 (make_header 3 mml_hdr_tuple) in
          Ir_emit.emit_store ctx.ir "i64" tag_val (Ir_emit.emit_gep ctx.ir "i64" triple_ptr 0);
          Ir_emit.emit_store ctx.ir "i64" name_str (Ir_emit.emit_gep ctx.ir "i64" triple_ptr 1);
          Ir_emit.emit_store ctx.ir "i64" show_fn (Ir_emit.emit_gep ctx.ir "i64" triple_ptr 2);
          let triple_val = Ir_emit.emit_ptrtoint ctx.ir triple_ptr in
          let cell_ptr = emit_alloc ctx 16 (make_header 0 mml_hdr_cons) in
          Ir_emit.emit_store ctx.ir "i64" triple_val (Ir_emit.emit_gep ctx.ir "i64" cell_ptr 0);
          Ir_emit.emit_store ctx.ir "i64" acc (Ir_emit.emit_gep ctx.ir "i64" cell_ptr 1);
          Ir_emit.emit_ptrtoint ctx.ir cell_ptr) (List.mapi (fn i c -> (i, c)) vdef) (tag_int 0) in
          let fn_id = ctx.fn_counter in
          ctx.fn_counter := ctx.fn_counter + 1;
          let wrapper_name = $"mml_op_show_variant_{ctx.unit_prefix}{fn_id}" in
          emit_show_compound_wrapper ctx wrapper_name "mml_show_variant" 1;
          emit_make_closure ctx wrapper_name 1 (ctors_list :: [])

      end
    | Types.TRecord row -> 
      let fields = Types.record_row_to_fields row in
      let sorted = List.sort (fn (a, _) (b, _) -> String.compare a b) fields in
      let fields_list = List.fold_right (fn (fname, fty) acc -> let name_str = emit_expr ctx {expr = TEString fname; ty = Types.TString; loc = Token.dummy_loc} in
      let show_fn = emit_show_closure ctx (Types.TArrow (Types.repr fty, Types.EffEmpty, Types.TString)) in
      let pair_ptr = emit_alloc ctx 16 (make_header 0 mml_hdr_pair) in
      Ir_emit.emit_store ctx.ir "i64" name_str (Ir_emit.emit_gep ctx.ir "i64" pair_ptr 0);
      Ir_emit.emit_store ctx.ir "i64" show_fn (Ir_emit.emit_gep ctx.ir "i64" pair_ptr 1);
      let pair_val = Ir_emit.emit_ptrtoint ctx.ir pair_ptr in
      let cell_ptr = emit_alloc ctx 16 (make_header 0 mml_hdr_cons) in
      Ir_emit.emit_store ctx.ir "i64" pair_val (Ir_emit.emit_gep ctx.ir "i64" cell_ptr 0);
      Ir_emit.emit_store ctx.ir "i64" acc (Ir_emit.emit_gep ctx.ir "i64" cell_ptr 1);
      Ir_emit.emit_ptrtoint ctx.ir cell_ptr) sorted (tag_int 0) in
      let fn_id = ctx.fn_counter in
      ctx.fn_counter := ctx.fn_counter + 1;
      let wrapper_name = $"mml_op_show_record_{ctx.unit_prefix}{fn_id}" in
      emit_show_compound_wrapper ctx wrapper_name "mml_show_record" 1;
      emit_make_closure ctx wrapper_name 1 (fields_list :: [])
    | Types.TPolyVariant row -> 
      let rec collect_tags acc =
        fn
          | Types.PVRow ((name, payload_ty, rest)) -> 
            let tag = Types.polyvar_tag name in
            collect_tags ((tag, name, payload_ty) :: acc) rest
          | Types.PVVar {contents = Types.PVLink r} -> collect_tags acc r
          | _ -> List.rev acc
       in
      let tags = collect_tags [] row in
      let names_list = List.fold_right (fn (tag, name, _) acc -> let name_str = emit_expr ctx {expr = TEString name; ty = Types.TString; loc = Token.dummy_loc} in
      let hash_val = tag_int tag in
      let pair_ptr = emit_alloc ctx 16 (make_header 0 mml_hdr_pair) in
      Ir_emit.emit_store ctx.ir "i64" hash_val (Ir_emit.emit_gep ctx.ir "i64" pair_ptr 0);
      Ir_emit.emit_store ctx.ir "i64" name_str (Ir_emit.emit_gep ctx.ir "i64" pair_ptr 1);
      let pair_val = Ir_emit.emit_ptrtoint ctx.ir pair_ptr in
      let cell_ptr = emit_alloc ctx 16 (make_header 0 mml_hdr_cons) in
      Ir_emit.emit_store ctx.ir "i64" pair_val (Ir_emit.emit_gep ctx.ir "i64" cell_ptr 0);
      Ir_emit.emit_store ctx.ir "i64" acc (Ir_emit.emit_gep ctx.ir "i64" cell_ptr 1);
      Ir_emit.emit_ptrtoint ctx.ir cell_ptr) tags (tag_int 0) in
      let payload_tys = List.filter_map (fn (_, _, pty) -> pty) tags in
      let payload_ty =
        match payload_tys with
        | ty :: [] -> Types.repr ty
        | _ -> Types.TUnit
       in
      let show_payload =
        if (payload_ty = Types.TUnit) && (payload_tys <> []) do
          let wrapper_key = "mml_op_show_generic" in
          if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
            Hashtbl.set ctx.generated_wrappers wrapper_key ();
            emit_rt_unary_wrapper ctx wrapper_key "mml_show_value"
          end;
          add_extern ctx "mml_show_value" "i64" ("i64" :: []);
          emit_make_closure ctx wrapper_key 1 []
        else
          emit_show_closure ctx (Types.TArrow (payload_ty, Types.EffEmpty, Types.TString)) in
      let fn_id = ctx.fn_counter in
      ctx.fn_counter := ctx.fn_counter + 1;
      let wrapper_name = $"mml_op_show_pv_{ctx.unit_prefix}{fn_id}" in
      emit_show_compound_wrapper ctx wrapper_name "mml_show_polyvariant" 2;
      emit_make_closure ctx wrapper_name 1 (names_list :: show_payload :: [])
    | _ -> 
      let (rt_fn, wrapper_key) =
        match arg_ty with
        | Types.TInt -> ("mml_string_of_int", "mml_op_show_int")
        | Types.TFloat -> ("mml_string_of_float", "mml_op_show_float")
        | Types.TBool -> ("mml_string_of_bool", "mml_op_show_bool")
        | Types.TString -> ("mml_identity", "mml_op_show_string")
        | Types.TUnit -> ("mml_show_unit", "mml_op_show_unit")
        | Types.TByte -> ("mml_show_byte", "mml_op_show_byte")
        | Types.TRune -> ("mml_show_rune", "mml_op_show_rune")
        | _ -> ("mml_show_value", "mml_op_show_generic")
       in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_rt_unary_wrapper ctx wrapper_key rt_fn
      end;
      emit_make_closure ctx wrapper_key 1 []

  and emit_show_compound_wrapper ctx wrapper_name rt_fn_name n_captures = with_fresh_ir ctx (fn fn_ir -> let params = ("ptr", "%env") :: ("i64", "%a0") :: [] in
  Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_name params;
  Ir_emit.emit_label fn_ir "entry";
  let cap_vals = List.init n_captures (fn i -> let cap_ptr = Ir_emit.emit_gep fn_ir "i64" "%env" (3 + i) in
  Ir_emit.emit_load fn_ir "i64" cap_ptr) in
  let all_tys = List.init (n_captures + 1) (fn _ -> "i64") in
  add_extern ctx rt_fn_name "i64" all_tys;
  let args = List.concat (List.map (fn v -> ("i64", v)) cap_vals) (("i64", "%a0") :: []) in
  let result = Ir_emit.emit_call fn_ir "i64" rt_fn_name args in
  Ir_emit.emit_ret fn_ir "i64" result;
  Ir_emit.emit_define_end fn_ir)
  and emit_fold_closure ctx ty =
    let coll_ty =
      match ty with
      | Types.TArrow ((_, _, Types.TArrow ((_, _, Types.TArrow ((ct, _, _)))))) -> Types.repr ct
      | _ -> Types.TUnit
     in
    let (rt_fn, wrapper_key) =
      match coll_ty with
      | Types.TArray _ -> ("mml_array_fold_breakable", "mml_op_fold_array")
      | _ -> ("mml_list_fold_breakable", "mml_op_fold_list")
     in
    if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
      Hashtbl.set ctx.generated_wrappers wrapper_key ();
      emit_rt_ternary_wrapper ctx wrapper_key rt_fn
    end;
    emit_make_closure ctx wrapper_key 3 []
  and emit_at_closure ctx ty =
    let coll_ty =
      match ty with
      | Types.TArrow ((_, _, Types.TArrow ((ct, _, _)))) -> Types.repr ct
      | _ -> Types.TUnit
     in
    let is_map_index =
      match coll_ty with
      | Types.TVariant (("map", _)) -> true
      | _ -> false
     in
    let (rt_fn, wrapper_key) =
      match coll_ty with
      | _ when is_map_index -> ("mml_assoc_get", "mml_op_at_map")
      | Types.TArray _ -> ("mml_array_get", "mml_op_at_array")
      | Types.TList _ -> ("mml_list_nth", "mml_op_at_list")
      | Types.TString -> ("mml_string_get_byte", "mml_op_at_string")
      | _ -> ("mml_list_nth", "mml_op_at_generic")
     in
    if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
      Hashtbl.set ctx.generated_wrappers wrapper_key ();
      emit_rt_binary_wrapper ctx wrapper_key rt_fn
    end;
    emit_make_closure ctx wrapper_key 2 []
  and operator_closure_supported op_name =
    match op_name with
    | (("fold" | "at") | "show") -> true
    | (((((((((((((((((("+" | "-") | "*") | "/") | "mod") | "neg") | "not") | "<") | ">") | "<=") | ">=") | "=") | "<>") | "land") | "lor") | "lxor") | "lsl") | "lsr") | "lnot") -> true
    | _ -> false

  and emit_operator_closure ctx op_name expr_ty =
    let ty = Types.repr expr_ty in
    if op_name = "fold" do
      emit_fold_closure ctx ty
    else if op_name = "at" do
      emit_at_closure ctx ty
    else if op_name = "show" do
      emit_show_closure ctx ty
    else do
      let is_float =
        match ty with
        | Types.TArrow ((Types.TFloat, _, _)) -> true
        | Types.TArrow ((_, _, Types.TArrow ((Types.TFloat, _, _)))) -> true
        | _ -> 
          do
            match ty with
            | Types.TArrow ((arg_ty, _, _)) -> 
              do
                match Types.repr arg_ty with
                | Types.TFloat -> true
                | _ -> false

              end
            | _ -> false

          end
       in
      let op_suffix =
        match op_name with
        | "+" -> "add"
        | "-" -> "sub"
        | "*" -> "mul"
        | "/" -> "div"
        | "mod" -> "mod"
        | "neg" -> "neg"
        | "not" -> "not"
        | "<" -> "lt"
        | ">" -> "gt"
        | "<=" -> "lte"
        | ">=" -> "gte"
        | "=" -> "eq"
        | "<>" -> "neq"
        | "land" -> "land"
        | "lor" -> "lor"
        | "lxor" -> "lxor"
        | "lsl" -> "lsl"
        | "lsr" -> "lsr"
        | "lnot" -> "lnot"
        | s -> sanitize_name s
       in
      let is_structural_cmp =
        match op_name with
        | ((((("<" | ">") | "<=") | ">=") | "=") | "<>") -> 
          do
            match ty with
            | Types.TArrow ((arg_ty, _, _)) -> 
              do
                match Types.repr arg_ty with
                | (((((Types.TInt | Types.TBool) | Types.TByte) | Types.TRune) | Types.TUnit) | Types.TFloat) -> false
                | _ -> true

              end
            | _ -> false

          end
        | _ -> false
       in
      let wrapper_key =
        if is_structural_cmp do
          $"mml_op_struct_{op_suffix}"
        else
          $"mml_op_{if is_float do
  "float"
else
  "int"}_{op_suffix}" in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        if is_structural_cmp do
          emit_structural_cmp_wrapper ctx wrapper_key op_name
        else
          emit_operator_wrapper ctx wrapper_key op_name is_float
      end;
      let arity =
        match op_name with
        | (("not" | "neg") | "lnot") -> 1
        | _ -> 2
       in
      emit_make_closure ctx wrapper_key arity []
    end
  and emit_structural_op_value ctx op_name =
    let op_suffix =
      match op_name with
      | "<" -> "lt"
      | ">" -> "gt"
      | "<=" -> "lte"
      | ">=" -> "gte"
      | "=" -> "eq"
      | "<>" -> "neq"
      | _ -> failwith ("emit_structural_op_value: " ^ op_name)
     in
    let wrapper_key = $"mml_op_struct_{op_suffix}" in
    if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
      Hashtbl.set ctx.generated_wrappers wrapper_key ();
      emit_structural_cmp_wrapper ctx wrapper_key op_name
    end;
    emit_make_closure ctx wrapper_key 2 []
  and emit_structural_cmp_wrapper ctx wrapper_name op_name = with_fresh_ir ctx (fn fn_ir -> let params = ("ptr", "%env") :: ("i64", "%a0") :: ("i64", "%a1") :: [] in
  Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_name params;
  Ir_emit.emit_label fn_ir "entry";
  let result =
    match op_name with
    | ("=" | "<>") -> 
      add_extern ctx "mml_structural_eq" "i64" ("i64" :: "i64" :: []);
      let eq = Ir_emit.emit_call fn_ir "i64" "mml_structural_eq" (("i64", "%a0") :: ("i64", "%a1") :: []) in
      if op_name = "=" do
        eq
      else do
        let cmp = Ir_emit.emit_icmp fn_ir "eq" "i64" eq true_value in
        Ir_emit.emit_select fn_ir cmp "i64" false_value true_value
      end
    | _ -> 
      let icmp_op =
        match op_name with
        | "<" -> "slt"
        | ">" -> "sgt"
        | "<=" -> "sle"
        | _ -> "sge"
       in
      add_extern ctx "mml_structural_compare" "i64" ("i64" :: "i64" :: []);
      let r = Ir_emit.emit_call fn_ir "i64" "mml_structural_compare" (("i64", "%a0") :: ("i64", "%a1") :: []) in
      let cmp = Ir_emit.emit_icmp fn_ir icmp_op "i64" r (tag_int 0) in
      Ir_emit.emit_select fn_ir cmp "i64" true_value false_value
   in
  Ir_emit.emit_ret fn_ir "i64" result;
  Ir_emit.emit_define_end fn_ir)
  and emit_operator_wrapper ctx wrapper_name op_name is_float = with_fresh_ir ctx (fn fn_ir -> let arity =
    match op_name with
    | (("not" | "neg") | "lnot") -> 1
    | _ -> 2
   in
  let params = ("ptr", "%env") :: List.init arity (fn i -> ("i64", $"%a{i}")) in
  Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_name params;
  Ir_emit.emit_label fn_ir "entry";
  let result =
    if arity = 1 do
      do
        match op_name with
        | "not" -> Ir_emit.emit_binop fn_ir "xor" "i64" "%a0" "2"
        | "neg" when is_float -> 
          let d = Ir_emit.emit_call fn_ir "double" "mml_unbox_float" (("i64", "%a0") :: []) in
          let neg_d = Ir_emit.emit_float_binop fn_ir "fsub" "0.0" d in
          add_extern ctx "mml_box_float" "i64" ("double" :: []);
          Ir_emit.emit_call fn_ir "i64" "mml_box_float" (("double", neg_d) :: [])
        | "neg" -> 
          let untagged = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
          let negated = Ir_emit.emit_binop fn_ir "sub" "i64" "0" untagged in
          let shifted = Ir_emit.emit_binop fn_ir "shl" "i64" negated "1" in
          Ir_emit.emit_binop fn_ir "or" "i64" shifted "1"
        | "lnot" -> 
          let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
          let r = Ir_emit.emit_binop fn_ir "xor" "i64" ua "-1" in
          let s = Ir_emit.emit_binop fn_ir "shl" "i64" r "1" in
          Ir_emit.emit_binop fn_ir "or" "i64" s "1"
        | _ -> failwith ($"native codegen: unknown unary operator {op_name}")

      end
    else if is_float do
      let da = emit_unbox_float ctx "%a0" in
      let db = emit_unbox_float ctx "%a1" in
      let (fop, is_cmp) =
        match op_name with
        | "+" -> ("fadd", false)
        | "-" -> ("fsub", false)
        | "*" -> ("fmul", false)
        | "/" -> ("fdiv", false)
        | "<" -> ("olt", true)
        | ">" -> ("ogt", true)
        | "<=" -> ("ole", true)
        | ">=" -> ("oge", true)
        | "=" -> ("oeq", true)
        | "<>" -> ("one", true)
        | _ -> failwith ($"native codegen: unknown float operator {op_name}")
       in
      if is_cmp do
        let cmp = Ir_emit.emit_fcmp fn_ir fop da db in
        Ir_emit.emit_select fn_ir cmp "i64" true_value false_value
      else do
        let r = Ir_emit.emit_float_binop fn_ir fop da db in
        emit_box_float ctx r
      end
    else
      match op_name with
      | "+" -> 
        let sum = Ir_emit.emit_binop fn_ir "add" "i64" "%a0" "%a1" in
        Ir_emit.emit_binop fn_ir "sub" "i64" sum "1"
      | "-" -> 
        let diff = Ir_emit.emit_binop fn_ir "sub" "i64" "%a0" "%a1" in
        Ir_emit.emit_binop fn_ir "add" "i64" diff "1"
      | "*" -> 
        let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
        let ub = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a1" "1" in
        let prod = Ir_emit.emit_binop fn_ir "mul" "i64" ua ub in
        let shifted = Ir_emit.emit_binop fn_ir "shl" "i64" prod "1" in
        Ir_emit.emit_binop fn_ir "or" "i64" shifted "1"
      | "/" -> 
        let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
        let ub = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a1" "1" in
        emit_divmod_zero_check_ir ctx fn_ir ub;
        let quot = Ir_emit.emit_binop fn_ir "sdiv" "i64" ua ub in
        let shifted = Ir_emit.emit_binop fn_ir "shl" "i64" quot "1" in
        Ir_emit.emit_binop fn_ir "or" "i64" shifted "1"
      | "mod" -> 
        let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
        let ub = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a1" "1" in
        emit_divmod_zero_check_ir ctx fn_ir ub;
        let rem = Ir_emit.emit_binop fn_ir "srem" "i64" ua ub in
        let shifted = Ir_emit.emit_binop fn_ir "shl" "i64" rem "1" in
        Ir_emit.emit_binop fn_ir "or" "i64" shifted "1"
      | "<" -> 
        let cmp = Ir_emit.emit_icmp fn_ir "slt" "i64" "%a0" "%a1" in
        Ir_emit.emit_select fn_ir cmp "i64" true_value false_value
      | ">" -> 
        let cmp = Ir_emit.emit_icmp fn_ir "sgt" "i64" "%a0" "%a1" in
        Ir_emit.emit_select fn_ir cmp "i64" true_value false_value
      | "<=" -> 
        let cmp = Ir_emit.emit_icmp fn_ir "sle" "i64" "%a0" "%a1" in
        Ir_emit.emit_select fn_ir cmp "i64" true_value false_value
      | ">=" -> 
        let cmp = Ir_emit.emit_icmp fn_ir "sge" "i64" "%a0" "%a1" in
        Ir_emit.emit_select fn_ir cmp "i64" true_value false_value
      | "=" -> 
        add_extern ctx "mml_structural_eq" "i64" ("i64" :: "i64" :: []);
        Ir_emit.emit_call fn_ir "i64" "mml_structural_eq" (("i64", "%a0") :: ("i64", "%a1") :: [])
      | "<>" -> 
        add_extern ctx "mml_structural_eq" "i64" ("i64" :: "i64" :: []);
        let eq = Ir_emit.emit_call fn_ir "i64" "mml_structural_eq" (("i64", "%a0") :: ("i64", "%a1") :: []) in
        let cmp = Ir_emit.emit_icmp fn_ir "eq" "i64" eq true_value in
        Ir_emit.emit_select fn_ir cmp "i64" false_value true_value
      | "land" -> 
        let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
        let ub = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a1" "1" in
        let r = Ir_emit.emit_binop fn_ir "and" "i64" ua ub in
        let s = Ir_emit.emit_binop fn_ir "shl" "i64" r "1" in
        Ir_emit.emit_binop fn_ir "or" "i64" s "1"
      | "lor" -> 
        let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
        let ub = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a1" "1" in
        let r = Ir_emit.emit_binop fn_ir "or" "i64" ua ub in
        let s = Ir_emit.emit_binop fn_ir "shl" "i64" r "1" in
        Ir_emit.emit_binop fn_ir "or" "i64" s "1"
      | "lxor" -> 
        let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
        let ub = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a1" "1" in
        let r = Ir_emit.emit_binop fn_ir "xor" "i64" ua ub in
        let s = Ir_emit.emit_binop fn_ir "shl" "i64" r "1" in
        Ir_emit.emit_binop fn_ir "or" "i64" s "1"
      | "lsl" -> 
        let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
        let ub = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a1" "1" in
        let r = Ir_emit.emit_binop fn_ir "shl" "i64" ua ub in
        let s = Ir_emit.emit_binop fn_ir "shl" "i64" r "1" in
        Ir_emit.emit_binop fn_ir "or" "i64" s "1"
      | "lsr" -> 
        let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
        let ub = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a1" "1" in
        let r = Ir_emit.emit_binop fn_ir "lshr" "i64" ua ub in
        let s = Ir_emit.emit_binop fn_ir "shl" "i64" r "1" in
        Ir_emit.emit_binop fn_ir "or" "i64" s "1"
      | "lnot" -> 
        let ua = Ir_emit.emit_binop fn_ir "ashr" "i64" "%a0" "1" in
        let r = Ir_emit.emit_binop fn_ir "xor" "i64" ua "-1" in
        let s = Ir_emit.emit_binop fn_ir "shl" "i64" r "1" in
        Ir_emit.emit_binop fn_ir "or" "i64" s "1"
      | _ -> failwith ($"native codegen: unknown int operator {op_name}")
   in
  Ir_emit.emit_ret fn_ir "i64" result;
  Ir_emit.emit_define_end fn_ir)
  and emit_builtin_as_value ctx name expr_ty =
    match name with
    | _ when Hashtbl.has ctx.module_externs name -> 
      let arity = Hashtbl.find ctx.module_externs name in
      let c_name = c_name_of_module_extern name in
      let wrapper_key = "mml_op_" ^ c_name in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_func_wrapper ctx wrapper_key c_name arity
      end;
      add_extern ctx c_name "i64" (List.init arity (fn _ -> "i64"));
      Some (emit_make_closure ctx wrapper_key arity [])
    | "not" -> 
      let wrapper_key = "mml_op_int_not" in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_operator_wrapper ctx wrapper_key "not" false
      end;
      Some (emit_make_closure ctx wrapper_key 1 [])
    | "^" -> 
      let wrapper_key = "mml_op_concat" in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_concat_wrapper ctx wrapper_key
      end;
      Some (emit_make_closure ctx wrapper_key 2 [])
    | ("print" | "Stdlib.print") -> Some (emit_print_closure ctx expr_ty)
    | ("string_of_int" | "Stdlib.string_of_int") -> 
      let wrapper_key = "mml_op_string_of_int" in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_func_wrapper ctx wrapper_key "mml_string_of_int" 1
      end;
      add_extern ctx "mml_string_of_int" "i64" ("i64" :: []);
      Some (emit_make_closure ctx wrapper_key 1 [])
    | ("string_of_float" | "Stdlib.string_of_float") -> 
      let wrapper_key = "mml_op_string_of_float" in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_func_wrapper ctx wrapper_key "mml_string_of_float" 1
      end;
      add_extern ctx "mml_string_of_float" "i64" ("i64" :: []);
      Some (emit_make_closure ctx wrapper_key 1 [])
    | ("string_of_bool" | "Stdlib.string_of_bool") -> 
      let wrapper_key = "mml_op_string_of_bool" in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_func_wrapper ctx wrapper_key "mml_string_of_bool" 1
      end;
      add_extern ctx "mml_string_of_bool" "i64" ("i64" :: []);
      Some (emit_make_closure ctx wrapper_key 1 [])
    | ("float_of_int" | "Stdlib.float_of_int") -> 
      let wrapper_key = "mml_op_float_of_int" in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_func_wrapper ctx wrapper_key "mml_float_of_int" 1
      end;
      add_extern ctx "mml_float_of_int" "i64" ("i64" :: []);
      Some (emit_make_closure ctx wrapper_key 1 [])
    | ("int_of_float" | "Stdlib.int_of_float") -> 
      let wrapper_key = "mml_op_int_of_float" in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_func_wrapper ctx wrapper_key "mml_int_of_float" 1
      end;
      add_extern ctx "mml_int_of_float" "i64" ("i64" :: []);
      Some (emit_make_closure ctx wrapper_key 1 [])
    | "__show_value" -> 
      do
        match Types.repr expr_ty with
        | Types.TArrow _ -> Some (emit_show_closure ctx expr_ty)
        | _ -> 
          let wrapper_key = "mml_op_show_value" in
          if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
            Hashtbl.set ctx.generated_wrappers wrapper_key ();
            emit_rt_unary_wrapper ctx wrapper_key "mml_show_value"
          end;
          add_extern ctx "mml_show_value" "i64" ("i64" :: []);
          Some (emit_make_closure ctx wrapper_key 1 [])

      end
    | "show" -> Some (emit_show_closure ctx expr_ty)
    | ("__num_add_int" | "__num_add_float") -> Some (emit_operator_closure ctx "+" expr_ty)
    | ("__num_sub_int" | "__num_sub_float") -> Some (emit_operator_closure ctx "-" expr_ty)
    | ("__num_mul_int" | "__num_mul_float") -> Some (emit_operator_closure ctx "*" expr_ty)
    | ("__num_div_int" | "__num_div_float") -> Some (emit_operator_closure ctx "/" expr_ty)
    | ("__num_neg_int" | "__num_neg_float") -> Some (emit_operator_closure ctx "neg" expr_ty)
    | ((((("__eq_int" | "__eq_float") | "__eq_string") | "__eq_bool") | "__eq_byte") | "__eq_rune") -> Some (emit_operator_closure ctx "=" expr_ty)
    | ((((("__neq_int" | "__neq_float") | "__neq_string") | "__neq_bool") | "__neq_byte") | "__neq_rune") -> Some (emit_operator_closure ctx "<>" expr_ty)
    | (((("__lt_int" | "__lt_float") | "__lt_string") | "__lt_byte") | "__lt_rune") -> Some (emit_operator_closure ctx "<" expr_ty)
    | (((("__gt_int" | "__gt_float") | "__gt_string") | "__gt_byte") | "__gt_rune") -> Some (emit_operator_closure ctx ">" expr_ty)
    | (((("__le_int" | "__le_float") | "__le_string") | "__le_byte") | "__le_rune") -> Some (emit_operator_closure ctx "<=" expr_ty)
    | (((("__ge_int" | "__ge_float") | "__ge_string") | "__ge_byte") | "__ge_rune") -> Some (emit_operator_closure ctx ">=" expr_ty)
    | "__band_int" -> Some (emit_operator_closure ctx "land" expr_ty)
    | "__bor_int" -> Some (emit_operator_closure ctx "lor" expr_ty)
    | "__bxor_int" -> Some (emit_operator_closure ctx "lxor" expr_ty)
    | "__bshl_int" -> Some (emit_operator_closure ctx "lsl" expr_ty)
    | "__bshr_int" -> Some (emit_operator_closure ctx "lsr" expr_ty)
    | "__bnot_int" -> Some (emit_operator_closure ctx "lnot" expr_ty)
    | (((((("__show_int" | "__show_float") | "__show_bool") | "__show_string") | "__show_unit") | "__show_byte") | "__show_rune") -> Some (emit_operator_closure ctx "show" expr_ty)
    | ("__index_at_array" | "__index_at_string") -> Some (emit_operator_closure ctx "at" expr_ty)
    | "__poly_hash" -> 
      let wrapper_key = "mml_op_poly_hash" in
      if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
        Hashtbl.set ctx.generated_wrappers wrapper_key ();
        emit_rt_unary_wrapper ctx wrapper_key "mml_poly_hash"
      end;
      add_extern ctx "mml_poly_hash" "i64" ("i64" :: []);
      Some (emit_make_closure ctx wrapper_key 1 [])
    | "__structural_eq" -> Some (emit_structural_op_value ctx "=")
    | "__structural_neq" -> Some (emit_structural_op_value ctx "<>")
    | "__structural_lt" -> Some (emit_structural_op_value ctx "<")
    | "__structural_gt" -> Some (emit_structural_op_value ctx ">")
    | "__structural_le" -> Some (emit_structural_op_value ctx "<=")
    | "__structural_ge" -> Some (emit_structural_op_value ctx ">=")
    | _ -> None

  and emit_concat_wrapper ctx wrapper_name = with_fresh_ir ctx (fn fn_ir -> Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_name (("ptr", "%env") :: ("i64", "%a0") :: ("i64", "%a1") :: []);
  Ir_emit.emit_label fn_ir "entry";
  add_extern ctx "mml_string_concat" "i64" ("i64" :: "i64" :: []);
  let result = Ir_emit.emit_call fn_ir "i64" "mml_string_concat" (("i64", "%a0") :: ("i64", "%a1") :: []) in
  Ir_emit.emit_ret fn_ir "i64" result;
  Ir_emit.emit_define_end fn_ir)
  and emit_print_closure ctx expr_ty =
    let arg_ty =
      match Types.repr expr_ty with
      | Types.TArrow ((arg, _, _)) -> Types.repr arg
      | _ -> Types.TUnit
     in
    let (print_fn, wrapper_key) =
      match arg_ty with
      | Types.TInt -> ("mml_print_int", "mml_op_print_int")
      | Types.TBool -> ("mml_print_bool", "mml_op_print_bool")
      | Types.TString -> ("mml_print_string", "mml_op_print_string")
      | Types.TFloat -> ("mml_print_float", "mml_op_print_float")
      | Types.TUnit -> ("mml_print_unit", "mml_op_print_unit")
      | _ -> ("mml_print_value", "mml_op_print")
     in
    if not (Hashtbl.has ctx.generated_wrappers wrapper_key) do
      Hashtbl.set ctx.generated_wrappers wrapper_key ();
      with_fresh_ir ctx (fn fn_ir -> Ir_emit.emit_define_start_gen fn_ir "linkonce_odr" "i64" wrapper_key (("ptr", "%env") :: ("i64", "%a0") :: []);
      Ir_emit.emit_label fn_ir "entry";
      add_extern ctx print_fn "i64" ("i64" :: []);
      let result = Ir_emit.emit_call fn_ir "i64" print_fn (("i64", "%a0") :: []) in
      Ir_emit.emit_ret fn_ir "i64" result;
      Ir_emit.emit_define_end fn_ir)
    end;
    ctx.has_print_output := true;
    emit_make_closure ctx wrapper_key 1 []
  and flatten_fun (expr : Typechecker.texpr) : string list * Typechecker.texpr =
    let rec collect params e =
      match e.expr with
      | TEFun ((param, body, _is_gen)) -> collect (param :: params) body
      | _ -> (List.rev params, e)
     in
    collect [] expr
  and sanitize_name name = String.map (fn c -> if ((c >= #61) && (c <= #7a)) || (((c >= #41) && (c <= #5a)) || (((c >= #30) && (c <= #39)) || (c = #5f))) do
    c
  else
    #5f) name
  and c_name_of_module_extern name = "mml_" ^ (String.lowercase (sanitize_name name))
  and is_builtin_name =
    fn
      | (((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((((("string_of_float" | "Stdlib.string_of_float") | "string_of_bool") | "Stdlib.string_of_bool") | "string_of_int") | "Stdlib.string_of_int") | "float_of_int") | "Stdlib.float_of_int") | "int_of_float") | "Stdlib.int_of_float") | "String.length") | "String.of_byte") | "String.get") | "String.sub") | "String.contains") | "String.to_list") | "String.rune_length") | "String.of_bytes") | "String.of_runes") | "String.get_rune") | "String.to_bytes") | "String.to_runes") | "String.split") | "String.trim") | "String.starts_with") | "String.replace") | "String.to_int") | "String.to_float") | "String.uppercase") | "String.lowercase") | "String.to_byte_array") | "String.of_byte_array") | "String.make") | "String.index_opt") | "String.rindex_opt") | "String.concat") | "String.compare") | "Byte.of_int") | "Byte.to_int") | "Byte.to_string") | "__byte_of_int") | "__byte_to_int") | "__byte_to_string") | "Ref.create") | "Ref.get") | "Ref.set") | "List.hd") | "List.tl") | "List.rev") | "List.length") | "List.map") | "List.fold") | "List.fold_left") | "List.filter") | "List.find") | "List.find_map") | "List.exists") | "List.forall") | "List.iter") | "List.mapi") | "List.concat") | "List.flatten") | "List.sort") | "List.fold_right") | "List.init") | "List.map2") | "List.iter2") | "array_get") | "array_set") | "array_length") | "Array.length") | "Array.get") | "Array.set") | "Array.make") | "Array.of_list") | "Array.to_list") | "Array.sub") | "Array.copy") | "Array.init") | "Array.map") | "Array.mapi") | "Array.iter") | "Array.fold") | "Rune.to_int") | "Rune.of_int") | "__rune_to_int") | "__rune_of_int") | "__rune_to_string") | "__math_pow") | "__math_sqrt") | "__math_floor") | "__math_ceil") | "__math_round") | "__float_bits_hex") | "__fmt_float") | "__fmt_float_g") | "__fmt_hex") | "__fmt_hex_upper") | "__fmt_oct") | "__fmt_bin") | "__fmt_zero_pad") | "__fmt_pad_left") | "__fmt_pad_right") | "Stdlib.mod") | "failwith") | "Sys.time") | "Sys.exit") | "Sys.getenv") | "Sys.args") | "IO.read_file") | "IO.write_file") | "IO.append_file") | "IO.read_line") | "IO.file_exists") | "Runtime.eval") | "Runtime.eval_file") | "phys_equal") | "Stdlib.phys_equal") | "copy_continuation") | "Stdlib.copy_continuation") | "print") | "Stdlib.print") | "__show_value") | "show") | "size") | "get") | "set") | "has") | "remove") | "keys") | "values") | "of_list") | "__num_add_int") | "__num_add_float") | "__num_sub_int") | "__num_sub_float") | "__num_mul_int") | "__num_mul_float") | "__num_div_int") | "__num_div_float") | "__num_neg_int") | "__num_neg_float") | "__eq_int") | "__eq_float") | "__eq_string") | "__eq_bool") | "__eq_byte") | "__eq_rune") | "__neq_int") | "__neq_float") | "__neq_string") | "__neq_bool") | "__neq_byte") | "__neq_rune") | "__lt_int") | "__lt_float") | "__lt_string") | "__lt_byte") | "__lt_rune") | "__gt_int") | "__gt_float") | "__gt_string") | "__gt_byte") | "__gt_rune") | "__le_int") | "__le_float") | "__le_string") | "__le_byte") | "__le_rune") | "__ge_int") | "__ge_float") | "__ge_string") | "__ge_byte") | "__ge_rune") | "__band_int") | "__bor_int") | "__bxor_int") | "__bshl_int") | "__bshr_int") | "__bnot_int") | "__structural_eq") | "__structural_neq") | "__structural_lt") | "__structural_gt") | "__structural_le") | "__structural_ge") | "__poly_hash") | "__index_at_array") | "__index_at_string") -> true
      | _ -> false

  and is_dict_or_inst name =
    let len = String.length name in
    (len >= 7) && (((String.sub name 0 7) = "__dict_") || ((String.sub name 0 7) = "__inst_"))
  and free_vars_of_fun ctx params body =
    let param_set = Hashtbl.create 16 in
    List.iter (fn p -> Hashtbl.set param_set p ()) params;
    let free = Ref.create [] in
    let bound = Hashtbl.create 16 in
    let is_known_global name =
      match ctx with
      -- A module-qualified syscall (module_externs) or a typed-FFI extern
      -- (ffi_externs, e.g. `Sdl.text_texture`) resolves globally to a runtime/C
      -- symbol at the call site, so referencing one inside a function body is NOT
      -- a free-variable capture — same as a top-level function or global.
      | Some c -> (Hashtbl.has c.module_externs name) || ((Hashtbl.has c.ffi_externs name) || (match lookup_var c name with
      | Some (((Func _ | FuncLocal _) | Global _) | MutGlobal _) -> true
      | _ -> false
      ))
      | None -> false
     in
    let shadows_value_local name =
      match ctx with
      | Some c -> 
        do
          match lookup_var c name with
          | Some ((Local _ | MutLocal _) | MutRefCell _) -> true
          | _ -> false

        end
      | None -> false
     in
    let capture_field_evidence record_ty field_name =
      match ctx with
      | Some c -> 
        do
          match field_evidence_param c record_ty field_name with
          | Some ev_name -> 
            if (not (Hashtbl.has param_set ev_name)) && ((not (Hashtbl.has bound ev_name)) && (not (List.mem ev_name (Ref.get free)))) do
              Ref.set free (ev_name :: Ref.get free)
            end
          | None -> ()

        end
      | None -> ()
     in
    let rec scan_expr (e : Typechecker.texpr) =
      match e.expr with
      | TEVar name -> 
        if (not (Hashtbl.has param_set name)) && ((not (Hashtbl.has bound name)) && ((not (is_known_global name)) && ((not (is_builtin_name name)) || (shadows_value_local name)))) do
          if not (List.mem name (Ref.get free)) do
            if is_dict_or_inst name do
              do
                match ctx with
                | Some c when (lookup_var c name) <> None -> Ref.set free (name :: Ref.get free)
                | _ -> ()

              end
            else
              Ref.set free (name :: Ref.get free)
          end
        end
      | ((((((TEInt _ | TEFloat _) | TEBool _) | TEString _) | TEUnit) | TEByte _) | TERune _) -> ()
      | TEBinop ((_, a, b)) -> 
        scan_expr a;
        scan_expr b
      | TEUnop ((_, a)) -> scan_expr a
      | TEApp ((a, b)) -> 
        scan_expr a;
        scan_expr b
      | TESeq ((a, b)) -> 
        scan_expr a;
        scan_expr b
      | TEIf ((c, t, e)) -> 
        scan_expr c;
        scan_expr t;
        scan_expr e
      | TELet ((n, _, init, body)) -> 
        scan_expr init;
        let was_bound = Hashtbl.has bound n in
        Hashtbl.set bound n ();
        scan_expr body;
        if not was_bound do
          Hashtbl.remove bound n
        end
      | TELetRec ((n, _, init, body)) -> 
        let was_bound = Hashtbl.has bound n in
        Hashtbl.set bound n ();
        scan_expr init;
        scan_expr body;
        if not was_bound do
          Hashtbl.remove bound n
        end
      | TELetRecAnd ((bindings, body)) -> 
        let prev = List.map (fn (n, _) -> (n, Hashtbl.has bound n)) bindings in
        List.iter (fn (n, _) -> Hashtbl.set bound n ()) bindings;
        List.iter (fn (_, e) -> scan_expr e) bindings;
        scan_expr body;
        List.iter (fn (n, was) -> if not was do
          Hashtbl.remove bound n
        end) prev
      | TELetMut ((n, init, body)) -> 
        scan_expr init;
        let was_bound = Hashtbl.has bound n in
        Hashtbl.set bound n ();
        scan_expr body;
        if not was_bound do
          Hashtbl.remove bound n
        end
      | TEAssign ((name, e)) -> 
        if (not (Hashtbl.has param_set name)) && ((not (Hashtbl.has bound name)) && ((not (is_known_global name)) && ((not (is_builtin_name name)) || (shadows_value_local name)))) do
          if not (List.mem name (Ref.get free)) do
            Ref.set free (name :: Ref.get free)
          end
        end;
        scan_expr e
      | TEFun ((p, body, _)) -> 
        let was_param = Hashtbl.has param_set p in
        Hashtbl.set param_set p ();
        scan_expr body;
        if not was_param do
          Hashtbl.remove param_set p
        end
      | TEWhile {tw_cond; tw_body; tw_step} -> 
        scan_expr tw_cond;
        scan_expr tw_body;
        Option.iter scan_expr tw_step
      | TEBreak e -> scan_expr e
      | TEContinueLoop -> ()
      | TEReturn e -> scan_expr e
      | TETuple es -> List.iter scan_expr es
      | TERecord fields -> List.iter (fn (_, e) -> scan_expr e) fields
      | TERecordUpdate ((base, overrides)) -> 
        List.iter (fn (fname, _) -> capture_field_evidence base.ty fname) overrides;
        scan_expr base;
        List.iter (fn (_, e) -> scan_expr e) overrides
      | TERecordUpdateIdx ((base, pairs)) -> 
        scan_expr base;
        List.iter (fn (i, v) -> scan_expr i;
        scan_expr v) pairs
      | TEField ((e, fname)) -> 
        capture_field_evidence e.ty fname;
        scan_expr e
      | TEFieldAssign ((e1, fname, e2)) -> 
        capture_field_evidence e1.ty fname;
        scan_expr e1;
        scan_expr e2
      | TEConstruct ((_, arg, _)) -> Option.iter scan_expr arg
      | TENil -> ()
      | TECons ((hd, tl)) -> 
        scan_expr hd;
        scan_expr tl
      | TEArray elems -> List.iter scan_expr elems
      | TEForLoop e -> scan_expr e
      | TEFoldContinue e -> scan_expr e
      | TEIndex ((e1, e2)) -> 
        scan_expr e1;
        scan_expr e2
      | TEMatch ((scrut, arms, _)) -> 
        scan_expr scrut;
        List.iter (fn (pat, guard, body) -> scan_pattern pat;
        Option.iter scan_expr guard;
        scan_expr body) arms
      | TEMatchTree cm -> 
        scan_expr cm.scrutinee;
        let scan_var_name name =
          if (not (Hashtbl.has param_set name)) && ((not (Hashtbl.has bound name)) && ((not (is_known_global name)) && ((not (is_builtin_name name)) || (shadows_value_local name)))) do
            if not (List.mem name (Ref.get free)) do
              Ref.set free (name :: Ref.get free)
            end
          end in
        let scan_map_key mk =
          match mk with
          | Match_tree_types.MKPin name -> scan_var_name name
          | _ -> ()
         in
        let scan_test test =
          match test with
          | Match_tree_types.TMapHasKey mk -> scan_map_key mk
          | Match_tree_types.TPin name -> scan_var_name name
          | _ -> ()
         in
        let scan_occ occ = List.iter (fn
          | Match_tree_types.AMapValue mk -> scan_map_key mk
          | _ -> ()
        ) occ in
        let rec collect_bindings =
          fn
            | Match_tree_types.DSwitch {cases; default; _} -> 
              List.iter (fn (_, _, sub) -> collect_bindings sub) cases;
              Option.iter collect_bindings default
            | Match_tree_types.DGuard {bindings; on_true; on_false; _} -> 
              List.iter (fn (b : Match_tree_types.binding) -> Hashtbl.set bound b.var_name ()) bindings;
              collect_bindings on_true;
              collect_bindings on_false
            | Match_tree_types.DLeaf {bindings; _} -> List.iter (fn (b : Match_tree_types.binding) -> Hashtbl.set bound b.var_name ()) bindings
            | Match_tree_types.DFail _ -> ()
         in
        collect_bindings cm.tree;
        Array.iter (fn arm -> scan_expr arm.arm_body) cm.match_arms;
        let rec scan_tree =
          fn
            | Match_tree_types.DSwitch {cases; default; _} -> 
              List.iter (fn (test, _, sub) -> scan_test test;
              scan_tree sub) cases;
              Option.iter scan_tree default
            | Match_tree_types.DGuard {guard; bindings; on_true; on_false; _} -> 
              List.iter (fn (b : Match_tree_types.binding) -> scan_occ b.bind_occ) bindings;
              scan_expr guard;
              scan_tree on_true;
              scan_tree on_false
            | Match_tree_types.DLeaf {bindings; _} -> List.iter (fn (b : Match_tree_types.binding) -> scan_occ b.bind_occ) bindings
            | Match_tree_types.DFail _ -> ()
         in
        scan_tree cm.tree
      | TEPerform ((_op, arg_e)) -> scan_expr arg_e
      | TEResume ((k_e, v_e)) -> 
        scan_expr k_e;
        scan_expr v_e
      | TEHandle ((body_e, arms)) -> 
        scan_expr body_e;
        List.iter (fn arm ->
          do
            match arm with
            | Typechecker.THReturn ((name, e)) -> 
              Hashtbl.set bound name ();
              scan_expr e;
              Hashtbl.remove bound name
            | Typechecker.THOp {arg; k; body = e; _} -> 
              Hashtbl.set bound arg ();
              Hashtbl.set bound k ();
              scan_expr e;
              Hashtbl.remove bound arg;
              Hashtbl.remove bound k
            | Typechecker.THOpProvide ((_, arg, e)) -> 
              Hashtbl.set bound arg ();
              scan_expr e;
              Hashtbl.remove bound arg
            | Typechecker.THOpTry ((_, arg, e)) -> 
              Hashtbl.set bound arg ();
              scan_expr e;
              Hashtbl.remove bound arg

          end) arms

    and scan_pattern =
      fn
        | Ast.PatVar name -> Hashtbl.set bound name ()
        | Ast.PatTuple pats -> List.iter scan_pattern pats
        | Ast.PatConstruct ((_, sub)) -> Option.iter scan_pattern sub
        | Ast.PatRecord fields -> List.iter (fn (_, p) -> scan_pattern p) fields
        | Ast.PatAs ((p, name)) -> 
          Hashtbl.set bound name ();
          scan_pattern p
        | Ast.PatOr ((p1, p2)) -> 
          scan_pattern p1;
          scan_pattern p2
        | Ast.PatAnnot ((p, _)) -> scan_pattern p
        | Ast.PatCons ((p1, p2)) -> 
          scan_pattern p1;
          scan_pattern p2
        | Ast.PatArray pats -> List.iter scan_pattern pats
        | Ast.PatMap entries -> List.iter (fn (_, vp) -> scan_pattern vp) entries
        | Ast.PatPolyVariant ((_, sub)) -> Option.iter scan_pattern sub
        | Ast.PatPin _ -> ()
        | _ -> ()
     in
    scan_expr body;
    List.rev (Ref.get free)
  and emit_named_function ctx llvm_name params body = with_fresh_ir ctx (fn fn_ir -> let outer_scopes = ctx.scopes in
  let seen = Hashtbl.create 8 in
  let unique_params = List.map (fn p -> let base = sanitize_name p in
  if Hashtbl.has seen base do
    let n = Hashtbl.find seen base in
    Hashtbl.set seen base (n + 1);
    (p, $"param_{base}_{n}")
  else do
    Hashtbl.set seen base 1;
    (p, $"param_{base}")
  end) params in
  let param_pairs = List.map (fn (_, llvm_p) -> ("i64", $"%{llvm_p}")) unique_params in
  Ir_emit.emit_define_start fn_ir "i64" llvm_name param_pairs;
  Ir_emit.emit_label fn_ir "entry";
  ctx.current_label := "entry";
  ctx.loop_stack := [];
  let fn_scope = Hashtbl.create 16 in
  List.iter (fn scope -> Hashtbl.iter (fn name info ->
    do
      match info with
      | (((Func _ | FuncLocal _) | Global _) | MutGlobal _) -> 
        if not (Hashtbl.has fn_scope name) do
          Hashtbl.set fn_scope name info
        end
      | ((Local _ | MutLocal _) | MutRefCell _) -> ()

    end) scope) outer_scopes;
  ctx.scopes := fn_scope :: [];
  List.iter (fn (p, llvm_p) -> let ptr = Ir_emit.emit_alloca fn_ir "i64" in
  Ir_emit.emit_store fn_ir "i64" ($"%{llvm_p}") ptr;
  bind_var ctx p (Local ptr)) unique_params;
  setup_handler_mark ctx body;
  let body_result = emit_expr ctx body in
  Ir_emit.emit_ret fn_ir "i64" body_result;
  Ir_emit.emit_define_end fn_ir)
  and emit_named_function_with_captures ctx llvm_name params body self_name captures capture_modes = with_fresh_ir ctx (fn fn_ir -> let outer_scopes = ctx.scopes in
  let seen = Hashtbl.create 8 in
  let unique_params = List.map (fn p -> let base = sanitize_name p in
  if Hashtbl.has seen base do
    let n = Hashtbl.find seen base in
    Hashtbl.set seen base (n + 1);
    (p, $"param_{base}_{n}")
  else do
    Hashtbl.set seen base 1;
    (p, $"param_{base}")
  end) params in
  let arity = List.length params in
  let high_arity = arity > 8 in
  let param_pairs =
    if high_arity do
      ("ptr", "%env") :: ("ptr", "%args") :: []
    else
      ("ptr", "%env") :: List.map (fn (_, llvm_p) -> ("i64", $"%{llvm_p}")) unique_params in
  Ir_emit.emit_define_start fn_ir "i64" llvm_name param_pairs;
  Ir_emit.emit_label fn_ir "entry";
  ctx.current_label := "entry";
  ctx.loop_stack := [];
  let fn_scope = Hashtbl.create 16 in
  List.iter (fn scope -> Hashtbl.iter (fn name info ->
    do
      match info with
      | (((Func _ | FuncLocal _) | Global _) | MutGlobal _) -> 
        if not (Hashtbl.has fn_scope name) do
          Hashtbl.set fn_scope name info
        end
      | ((Local _ | MutLocal _) | MutRefCell _) -> ()

    end) scope) outer_scopes;
  ctx.scopes := fn_scope :: [];
  let self_i64 = Ir_emit.emit_ptrtoint fn_ir "%env" in
  let self_alloca = Ir_emit.emit_alloca fn_ir "i64" in
  Ir_emit.emit_store fn_ir "i64" self_i64 self_alloca;
  bind_var ctx self_name (Local self_alloca);
  List.iteri (fn i cap_name -> let cap_ptr = Ir_emit.emit_gep fn_ir "i64" "%env" (3 + i) in
  let cap_val = Ir_emit.emit_load fn_ir "i64" cap_ptr in
  let mode = List.nth capture_modes i in
  match mode with
  | `Mutable -> 
    let mut_ptr = Ir_emit.emit_inttoptr fn_ir cap_val in
    bind_var ctx cap_name (MutLocal mut_ptr)
  | `RefCell -> 
    let alloca = Ir_emit.emit_alloca fn_ir "i64" in
    Ir_emit.emit_store fn_ir "i64" cap_val alloca;
    bind_var ctx cap_name (MutRefCell alloca)
  | `Immutable -> 
    let alloca = Ir_emit.emit_alloca fn_ir "i64" in
    Ir_emit.emit_store fn_ir "i64" cap_val alloca;
    bind_var ctx cap_name (Local alloca)
  ) captures;
  if high_arity do
    List.iteri (fn i (p, _) -> let arg_ptr = Ir_emit.emit_gep fn_ir "i64" "%args" i in
    let arg_val = Ir_emit.emit_load fn_ir "i64" arg_ptr in
    let ptr = Ir_emit.emit_alloca fn_ir "i64" in
    Ir_emit.emit_store fn_ir "i64" arg_val ptr;
    bind_var ctx p (Local ptr)) unique_params
  else
    List.iter (fn (p, llvm_p) -> let ptr = Ir_emit.emit_alloca fn_ir "i64" in
    Ir_emit.emit_store fn_ir "i64" ($"%{llvm_p}") ptr;
    bind_var ctx p (Local ptr)) unique_params;
  setup_handler_mark ctx body;
  let body_result = emit_expr ctx body in
  Ir_emit.emit_ret fn_ir "i64" body_result;
  Ir_emit.emit_define_end fn_ir)
  and emit_c_string ctx s =
    let name = $".cstr.{ctx.str_counter}" in
    ctx.str_counter := ctx.str_counter + 1;
    let escaped = Buffer.contents (llvm_escape_string s) in
    let total = (String.length s) + 1 in
    let decl = $"@{name} = private unnamed_addr constant [{total} x i8] c\"{escaped}\\00\"" in
    ctx.string_globals := decl :: ctx.string_globals;
    Ir_emit.emit_ptrtoint ctx.ir ($"@{name}")
  and handler_arm_free_vars ctx bound_names body =
    let free = free_vars_of_fun (Some ctx) bound_names body in
    List.filter_map (fn name ->
      do
        match lookup_var ctx name with
        | Some info -> Some (name, info)
        | None -> None

      end) free
  and emit_handler_env ctx free_with_info =
    match free_with_info with
    | [] -> "0"
    | captures -> 
      let n = List.length captures in
      let env_ptr = emit_alloc ctx (n * 8) (make_header n mml_hdr_tuple) in
      List.iteri (fn i (name, info) -> let cap_val = emit_capture_value ctx name info in
      let slot = Ir_emit.emit_gep ctx.ir "i64" env_ptr i in
      Ir_emit.emit_store ctx.ir "i64" cap_val slot) captures;
      Ir_emit.emit_ptrtoint ctx.ir env_ptr

  and emit_handler_arm_fn ctx arg_name body free_with_info =
    let fn_name = $"mml_handler_arm_{ctx.unit_prefix}{ctx.fn_counter}" in
    ctx.fn_counter := ctx.fn_counter + 1;
    with_fresh_ir ctx (fn fn_ir -> let outer_scopes = ctx.scopes in
    let params = ("ptr", "%env") :: ("i64", "%arg") :: ("i64", "%k") :: [] in
    Ir_emit.emit_define_start fn_ir "i64" fn_name params;
    Ir_emit.emit_label fn_ir "entry";
    ctx.current_label := "entry";
    ctx.loop_stack := [];
    let fn_scope = Hashtbl.create 16 in
    List.iter (fn scope -> Hashtbl.iter (fn name info ->
      do
        match info with
        | (((Func _ | FuncLocal _) | Global _) | MutGlobal _) -> 
          if not (Hashtbl.has fn_scope name) do
            Hashtbl.set fn_scope name info
          end
        | ((Local _ | MutLocal _) | MutRefCell _) -> ()

      end) scope) outer_scopes;
    ctx.scopes := fn_scope :: [];
    List.iteri (fn i (name, info) -> let env_slot = Ir_emit.emit_gep fn_ir "i64" "%env" i in
    let cap_val = Ir_emit.emit_load fn_ir "i64" env_slot in
    match info with
    | ((MutLocal _ | MutRefCell _) | MutGlobal _) -> 
      let alloca_ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" cap_val alloca_ptr;
      bind_var ctx name (MutRefCell alloca_ptr)
    | _ -> 
      let ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" cap_val ptr;
      bind_var ctx name (Local ptr)
    ) free_with_info;
    let arg_ptr = Ir_emit.emit_alloca fn_ir "i64" in
    Ir_emit.emit_store fn_ir "i64" "%arg" arg_ptr;
    bind_var ctx arg_name (Local arg_ptr);
    setup_handler_mark ctx body;
    let body_result = emit_expr ctx body in
    Ir_emit.emit_ret fn_ir "i64" body_result;
    Ir_emit.emit_define_end fn_ir);
    fn_name
  and emit_full_handler_arm_fn ctx arg_name k_name body free_with_info =
    let fn_name = $"mml_handler_arm_{ctx.unit_prefix}{ctx.fn_counter}" in
    ctx.fn_counter := ctx.fn_counter + 1;
    with_fresh_ir ctx (fn fn_ir -> let outer_scopes = ctx.scopes in
    let params = ("ptr", "%env") :: ("i64", "%arg") :: ("i64", "%k") :: [] in
    Ir_emit.emit_define_start fn_ir "i64" fn_name params;
    Ir_emit.emit_label fn_ir "entry";
    ctx.current_label := "entry";
    ctx.loop_stack := [];
    let fn_scope = Hashtbl.create 16 in
    List.iter (fn scope -> Hashtbl.iter (fn name info ->
      do
        match info with
        | (((Func _ | FuncLocal _) | Global _) | MutGlobal _) -> 
          if not (Hashtbl.has fn_scope name) do
            Hashtbl.set fn_scope name info
          end
        | ((Local _ | MutLocal _) | MutRefCell _) -> ()

      end) scope) outer_scopes;
    ctx.scopes := fn_scope :: [];
    List.iteri (fn i (name, info) -> let env_slot = Ir_emit.emit_gep fn_ir "i64" "%env" i in
    let cap_val = Ir_emit.emit_load fn_ir "i64" env_slot in
    match info with
    | ((MutLocal _ | MutRefCell _) | MutGlobal _) -> 
      let alloca_ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" cap_val alloca_ptr;
      bind_var ctx name (MutRefCell alloca_ptr)
    | _ -> 
      let ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" cap_val ptr;
      bind_var ctx name (Local ptr)
    ) free_with_info;
    let arg_ptr = Ir_emit.emit_alloca fn_ir "i64" in
    Ir_emit.emit_store fn_ir "i64" "%arg" arg_ptr;
    bind_var ctx arg_name (Local arg_ptr);
    let k_ptr = Ir_emit.emit_alloca fn_ir "i64" in
    Ir_emit.emit_store fn_ir "i64" "%k" k_ptr;
    bind_var ctx k_name (Local k_ptr);
    setup_handler_mark ctx body;
    let body_result = emit_expr ctx body in
    Ir_emit.emit_ret fn_ir "i64" body_result;
    Ir_emit.emit_define_end fn_ir);
    fn_name
  and emit_handler_body_thunk ctx body free_with_info =
    let fn_name = $"mml_handler_body_{ctx.unit_prefix}{ctx.fn_counter}" in
    ctx.fn_counter := ctx.fn_counter + 1;
    with_fresh_ir ctx (fn fn_ir -> let outer_scopes = ctx.scopes in
    let params = ("ptr", "%env") :: [] in
    Ir_emit.emit_define_start fn_ir "i64" fn_name params;
    Ir_emit.emit_label fn_ir "entry";
    ctx.current_label := "entry";
    ctx.loop_stack := [];
    let fn_scope = Hashtbl.create 16 in
    List.iter (fn scope -> Hashtbl.iter (fn name info ->
      do
        match info with
        | (((Func _ | FuncLocal _) | Global _) | MutGlobal _) -> 
          if not (Hashtbl.has fn_scope name) do
            Hashtbl.set fn_scope name info
          end
        | ((Local _ | MutLocal _) | MutRefCell _) -> ()

      end) scope) outer_scopes;
    ctx.scopes := fn_scope :: [];
    List.iteri (fn i (name, info) -> let env_slot = Ir_emit.emit_gep fn_ir "i64" "%env" i in
    let cap_val = Ir_emit.emit_load fn_ir "i64" env_slot in
    match info with
    | ((MutLocal _ | MutRefCell _) | MutGlobal _) -> 
      let alloca_ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" cap_val alloca_ptr;
      bind_var ctx name (MutRefCell alloca_ptr)
    | _ -> 
      let ptr = Ir_emit.emit_alloca fn_ir "i64" in
      Ir_emit.emit_store fn_ir "i64" cap_val ptr;
      bind_var ctx name (Local ptr)
    ) free_with_info;
    setup_handler_mark ctx body;
    ctx.in_handler_thunk := true;
    let body_result = emit_expr ctx body in
    Ir_emit.emit_ret fn_ir "i64" body_result;
    Ir_emit.emit_define_end fn_ir);
    fn_name
  and emit_handle ctx body_expr arms =
    let return_arm = Ref.create None in
    let provide_ops = Ref.create [] in
    let try_ops = Ref.create [] in
    let full_ops = Ref.create [] in
    List.iter (fn arm ->
      do
        match arm with
        | Typechecker.THReturn ((name, e)) -> Ref.set return_arm (Some (name, e))
        | Typechecker.THOpProvide ((op, arg, e)) -> Ref.set provide_ops ((op, arg, e) :: Ref.get provide_ops)
        | Typechecker.THOpTry ((op, arg, e)) -> Ref.set try_ops ((op, arg, e) :: Ref.get try_ops)
        | Typechecker.THOp {op_name = op; arg; k; body = e} -> Ref.set full_ops ((op, arg, k, e) :: Ref.get full_ops)

      end) arms;
    let provide_ops = List.rev (Ref.get provide_ops) in
    let try_ops = List.rev (Ref.get try_ops) in
    let full_ops = List.rev (Ref.get full_ops) in
    let has_try_arms = try_ops <> [] in
    let has_full_arms = full_ops <> [] in
    let needs_thunk = has_try_arms || has_full_arms in
    let all_ops = ((List.length provide_ops) + (List.length try_ops)) + (List.length full_ops) in
    let compiled_provide = List.map (fn (op, arg, body) -> let free = handler_arm_free_vars ctx (arg :: []) body in
    let fn_name = emit_handler_arm_fn ctx arg body free in
    let env_val = emit_handler_env ctx free in
    (op, fn_name, env_val, "0")) provide_ops in
    let compiled_try = List.map (fn (op, arg, body) -> let free = handler_arm_free_vars ctx (arg :: []) body in
    let fn_name = emit_handler_arm_fn ctx arg body free in
    let env_val = emit_handler_env ctx free in
    (op, fn_name, env_val, "1")) try_ops in
    let compiled_full = List.map (fn (op, arg, k, body) -> let free = handler_arm_free_vars ctx (arg :: k :: []) body in
    let fn_name = emit_full_handler_arm_fn ctx arg k body free in
    let env_val = emit_handler_env ctx free in
    (op, fn_name, env_val, "2")) full_ops in
    let compiled_ops = List.concat compiled_provide (List.concat compiled_try compiled_full) in
    add_extern ctx "mml_alloc_handler" "i64" ("i64" :: []);
    let handler_val = Ir_emit.emit_call ctx.ir "i64" "mml_alloc_handler" (("i64", string_of_int all_ops) :: []) in
    add_extern ctx "mml_handler_set_op" "void" ("i64" :: "i64" :: "i64" :: "i64" :: "i64" :: "i64" :: []);
    List.iteri (fn i (op, fn_name, env_val, kind_str) -> let op_str = emit_c_string ctx op in
    let fn_ptr = Ir_emit.emit_ptrtoint ctx.ir ($"@{fn_name}") in
    Ir_emit.emit_call_void ctx.ir "mml_handler_set_op" (("i64", handler_val) :: ("i64", string_of_int i) :: ("i64", op_str) :: ("i64", kind_str) :: ("i64", fn_ptr) :: ("i64", env_val) :: [])) compiled_ops;
    let (return_fn_name, return_env_val) =
      match Ref.get return_arm with
      | None -> ("0", "0")
      | Some ((name, body)) -> 
        let is_identity =
          match body.expr with
          | Typechecker.TEVar v -> v = name
          | _ -> false
         in
        if is_identity do
          ("0", "0")
        else do
          let free = handler_arm_free_vars ctx (name :: []) body in
          let fn_name = emit_handler_arm_fn ctx name body free in
          let env_val = emit_handler_env ctx free in
          let fn_ptr = Ir_emit.emit_ptrtoint ctx.ir ($"@{fn_name}") in
          (fn_ptr, env_val)
        end
     in
    add_extern ctx "mml_handler_set_return" "void" ("i64" :: "i64" :: "i64" :: []);
    Ir_emit.emit_call_void ctx.ir "mml_handler_set_return" (("i64", handler_val) :: ("i64", return_fn_name) :: ("i64", return_env_val) :: []);
    add_extern ctx "mml_push_handler" "void" ("i64" :: []);
    Ir_emit.emit_call_void ctx.ir "mml_push_handler" (("i64", handler_val) :: []);
    if not needs_thunk do
      do
        let body_val = emit_expr ctx body_expr in
        add_extern ctx "mml_pop_handler" "void" [];
        Ir_emit.emit_call_void ctx.ir "mml_pop_handler" [];
        match Ref.get return_arm with
        | None -> body_val
        | Some ((name, ret_body)) -> 
          let is_identity =
            match ret_body.expr with
            | Typechecker.TEVar v -> v = name
            | _ -> false
           in
          if is_identity do
            body_val
          else do
            push_scope ctx;
            let ptr = Ir_emit.emit_alloca ctx.ir "i64" in
            Ir_emit.emit_store ctx.ir "i64" body_val ptr;
            bind_var ctx name (Local ptr);
            let result = emit_expr ctx ret_body in
            pop_scope ctx;
            result
          end

      end
    else do
      let body_free = handler_arm_free_vars ctx [] body_expr in
      let body_fn_name = emit_handler_body_thunk ctx body_expr body_free in
      let body_env_val = emit_handler_env ctx body_free in
      let body_fn_ptr = Ir_emit.emit_ptrtoint ctx.ir ($"@{body_fn_name}") in
      let runtime_fn =
        if has_full_arms do
          "mml_run_full_handler"
        else
          "mml_run_try_handler" in
      add_extern ctx runtime_fn "i64" ("i64" :: "i64" :: "i64" :: "i64" :: "i64" :: []);
      let hv = Ir_emit.emit_call ctx.ir "i64" runtime_fn (("i64", handler_val) :: ("i64", body_fn_ptr) :: ("i64", body_env_val) :: ("i64", return_fn_name) :: ("i64", return_env_val) :: []) in
      if not has_full_arms do
        add_extern ctx "mml_check_early_return" "i64" [];
        let flag = Ir_emit.emit_call ctx.ir "i64" "mml_check_early_return" [] in
        let has_ret = Ir_emit.emit_icmp ctx.ir "ne" "i64" flag "0" in
        let early = fresh_label ctx "h_early_ret" in
        let cont = fresh_label ctx "h_no_ret" in
        Ir_emit.emit_condbr ctx.ir has_ret early cont;
        Ir_emit.emit_label ctx.ir early;
        ctx.current_label := early;
        emit_handler_mark_restore ctx;
        if (ctx.fold_break_depth > 0) || ctx.in_handler_thunk do
          emit_ctl_ret ctx hv
        else do
          add_extern ctx "mml_get_early_return" "i64" [];
          let rv = Ir_emit.emit_call ctx.ir "i64" "mml_get_early_return" [] in
          emit_ctl_ret ctx rv
        end;
        Ir_emit.emit_label ctx.ir cont;
        ctx.current_label := cont;
        if (ctx.loop_stack <> []) || ((ctx.fold_break_depth > 0) || ctx.in_handler_thunk) do
          add_extern ctx "mml_check_break_escape" "i64" [];
          let bflag = Ir_emit.emit_call ctx.ir "i64" "mml_check_break_escape" [] in
          let has_brk = Ir_emit.emit_icmp ctx.ir "ne" "i64" bflag "0" in
          let brk = fresh_label ctx "h_break" in
          let cont2 = fresh_label ctx "h_no_break" in
          Ir_emit.emit_condbr ctx.ir has_brk brk cont2;
          Ir_emit.emit_label ctx.ir brk;
          ctx.current_label := brk;
          add_extern ctx "mml_get_break_escape" "i64" [];
          let bv = Ir_emit.emit_call ctx.ir "i64" "mml_get_break_escape" [] in
          emit_break_action ctx bv;
          Ir_emit.emit_label ctx.ir cont2;
          ctx.current_label := cont2;
          add_extern ctx "mml_check_continue_escape" "i64" [];
          let cflag = Ir_emit.emit_call ctx.ir "i64" "mml_check_continue_escape" [] in
          let has_cont = Ir_emit.emit_icmp ctx.ir "ne" "i64" cflag "0" in
          let cl = fresh_label ctx "h_continue" in
          let cont3 = fresh_label ctx "h_no_continue" in
          Ir_emit.emit_condbr ctx.ir has_cont cl cont3;
          Ir_emit.emit_label ctx.ir cl;
          ctx.current_label := cl;
          add_extern ctx "mml_clear_continue_escape" "void" [];
          Ir_emit.emit_call_void ctx.ir "mml_clear_continue_escape" [];
          emit_continue_action ctx;
          Ir_emit.emit_label ctx.ir cont3;
          ctx.current_label := cont3
        end
      end;
      hv
    end
  and infer_result_type (expr : Typechecker.texpr) : Types.ty =
    let ty = Types.repr expr.ty in
    let is_unresolved t =
      match t with
      | (Types.TVar {contents = Types.Unbound _} | Types.TGen _) -> true
      | _ -> false
     in
    if not (is_unresolved ty) do
      ty
    else
      match expr.expr with
      | TEApp ((fn_expr, _)) -> 
        do
          let fn_ty = Types.repr fn_expr.ty in
          match fn_ty with
          | Types.TArrow ((_, _, ret_ty)) -> 
            let ret = Types.repr ret_ty in
            if not (is_unresolved ret) do
              ret
            else
              infer_type_from_dict_method fn_expr
          | _ -> ty

        end
      | (TELet ((_, _, _, body)) | TESeq ((_, body))) -> infer_result_type body
      | TEIf ((_, then_e, _)) -> infer_result_type then_e
      | TEMatch ((_, (_, _, first_body) :: _, _)) -> infer_result_type first_body
      | _ -> ty

  and infer_type_from_dict_method (fn_expr : Typechecker.texpr) : Types.ty = Types.repr fn_expr.ty
  and emit_decl (ctx : codegen_ctx) (decl : Typechecker.tdecl) : unit =
    match decl with
    | TDLet (("_", expr)) -> 
      let v = emit_expr ctx expr in
      ctx.result_type := infer_result_type expr;
      Ir_emit.emit_store ctx.ir "i64" v ctx.result_ptr;
      ()
    | TDLet ((name, expr)) -> 
      let is_dict = ((String.length name) > 7) && ((String.sub name 0 7) = "__dict_") in
      if is_dict do
        ctx.current_dict_name := Some name
      end;
      do
        match expr.expr with
        | TEFun _ -> 
          let (params, body) = flatten_fun expr in
          if params <> [] do
            let fn_id = ctx.fn_counter in
            ctx.fn_counter := ctx.fn_counter + 1;
            let llvm_name = $"mml_f_{ctx.unit_prefix}{sanitize_name name}_{fn_id}" in
            let free = free_vars_of_fun (Some ctx) params body in
            if free <> [] do
              failwith ($"native codegen: top-level function {name} captures free variables: {String.concat ", " free} (Phase 3)")
            end;
            bind_var ctx name (Func (llvm_name, List.length params));
            emit_named_function ctx llvm_name params body;
            ctx.result_type := Types.TUnit;
            Ir_emit.emit_store ctx.ir "i64" unit_value ctx.result_ptr
          else
            emit_global_let ctx name expr
        | _ -> emit_global_let ctx name expr

      end;
      if is_dict do
        ctx.current_dict_name := None
      end
    | TDLetMut ((name, expr)) -> 
      let v = emit_expr ctx expr in
      let gname = ensure_global ctx name in
      Ir_emit.emit_store ctx.ir "i64" v ($"@{gname}");
      bind_var ctx name (MutGlobal gname);
      ctx.result_type := Types.TUnit;
      Ir_emit.emit_store ctx.ir "i64" unit_value ctx.result_ptr
    | TDLetRec ((name, expr)) -> 
      let (params, body) = flatten_fun expr in
      if params = [] do
        let (placeholder_val, nbytes) = emit_rec_placeholder ctx expr in
        let gname = ensure_global ctx name in
        Ir_emit.emit_store ctx.ir "i64" placeholder_val ($"@{gname}");
        bind_var ctx name (Global gname);
        let computed_val = emit_expr ctx expr in
        emit_backpatch ctx placeholder_val computed_val nbytes;
        ctx.result_type := Types.TUnit;
        Ir_emit.emit_store ctx.ir "i64" unit_value ctx.result_ptr
      else do
        let fn_id = ctx.fn_counter in
        ctx.fn_counter := ctx.fn_counter + 1;
        let llvm_name = $"mml_f_{ctx.unit_prefix}{sanitize_name name}_{fn_id}" in
        bind_var ctx name (Func (llvm_name, List.length params));
        let free = free_vars_of_fun (Some ctx) (name :: params) body in
        if free <> [] do
          failwith ($"native codegen: top-level function {name} captures free variables: {String.concat ", " free} (Phase 3)")
        end;
        emit_named_function ctx llvm_name params body;
        ctx.result_type := Types.TUnit;
        Ir_emit.emit_store ctx.ir "i64" unit_value ctx.result_ptr
      end
    | TDLetRecAnd bindings -> 
      let all_names = List.map fst bindings in
      let binding_info = List.map (fn (name, expr) -> let (params, _) = flatten_fun expr in
      if params <> [] do
        `Func (name, expr)
      else
        `Value (name, expr)) bindings in
      let value_infos = Ref.create [] in
      List.iter (fn info ->
        do
          match info with
          | `Func (name, expr) -> 
            let (params, _) = flatten_fun expr in
            let fn_id = ctx.fn_counter in
            ctx.fn_counter := ctx.fn_counter + 1;
            let llvm_name = $"mml_f_{ctx.unit_prefix}{sanitize_name name}_{fn_id}" in
            bind_var ctx name (Func (llvm_name, List.length params))
          | `Value (name, expr) -> 
            let (placeholder_val, nbytes) = emit_rec_placeholder ctx expr in
            let gname = ensure_global ctx name in
            Ir_emit.emit_store ctx.ir "i64" placeholder_val ($"@{gname}");
            bind_var ctx name (Global gname);
            Ref.set value_infos ((name, expr, placeholder_val, nbytes) :: Ref.get value_infos)

        end) binding_info;
      let value_infos = List.rev (Ref.get value_infos) in
      List.iter (fn info ->
        do
          match info with
          | `Func (name, expr) -> 
            let (params, body) = flatten_fun expr in
            let llvm_name =
              match lookup_var ctx name with
              | Some (Func ((n, _))) -> n
              | _ -> failwith "expected Func"
             in
            let free = free_vars_of_fun (Some ctx) (List.concat all_names params) body in
            if free <> [] do
              failwith ($"native codegen: top-level function captures free variables: {String.concat ", " free} (Phase 3)")
            end;
            emit_named_function ctx llvm_name params body
          | `Value _ -> ()

        end) binding_info;
      List.iter (fn (_, expr, placeholder_val, nbytes) -> let computed_val = emit_expr ctx expr in
      emit_backpatch ctx placeholder_val computed_val nbytes) value_infos;
      ctx.result_type := Types.TUnit;
      Ir_emit.emit_store ctx.ir "i64" unit_value ctx.result_ptr
    | TDExpr expr -> 
      let v = emit_expr ctx expr in
      ctx.result_type := infer_result_type expr;
      Ir_emit.emit_store ctx.ir "i64" v ctx.result_ptr
    | TDModule ((_name, inner_decls, _)) -> List.iter (emit_decl ctx) inner_decls
    | TDOpen alias_pairs -> List.iter (fn (short_name, qualified_name) ->
      do
        match lookup_var ctx qualified_name with
        | Some info -> bind_var ctx short_name info
        | None -> ()

      end) alias_pairs
    | ((((TDType _ | TDClass _) | TDEffect _) | TDExtern _) | TDFfi _) -> ()

  and ensure_global ctx name =
    let gname = $"mml_g_{ctx.unit_prefix}{sanitize_name name}" in
    let decl = $"@{gname} = global i64 0, section \"__DATA,__mmlgc\"" in
    if not (List.mem decl ctx.global_decls) do
      ctx.global_decls := decl :: ctx.global_decls
    end;
    gname
  and emit_global_let ctx name expr =
    let v = emit_expr ctx expr in
    let gname = ensure_global ctx name in
    Ir_emit.emit_store ctx.ir "i64" v ($"@{gname}");
    bind_var ctx name (Global gname);
    ctx.result_type := Types.TUnit;
    Ir_emit.emit_store ctx.ir "i64" unit_value ctx.result_ptr
  and result_type_tag ty =
    match Types.repr ty with
    | Types.TInt -> 0
    | Types.TByte -> 6
    | Types.TBool -> 1
    | Types.TString -> 2
    | Types.TFloat -> 3
    | Types.TUnit -> 4
    | (((((Types.TTuple _ | Types.TRecord _) | Types.TVariant _) | Types.TList _) | Types.TArray _) | Types.TPolyVariant _) -> 5
    | Types.TRune -> 7
    | _ -> 4

  and needs_format_result ty =
    match Types.repr ty with
    | (((((Types.TTuple _ | Types.TRecord _) | Types.TVariant _) | Types.TList _) | Types.TPolyVariant _) | Types.TArray _) -> true
    | _ -> false

  and emit_format_result ctx ty = with_fresh_ir ctx (fn fn_ir -> ctx.scopes := Hashtbl.create 8 :: [];
  Ir_emit.emit_define_start fn_ir "void" "mml_format_result" (("i64", "%param_val") :: []);
  Ir_emit.emit_label fn_ir "entry";
  ctx.current_label := "entry";
  emit_format_value ctx "%param_val" ty;
  Ir_emit.emit_ret_void fn_ir;
  Ir_emit.emit_define_end fn_ir)
  and emit_format_value ctx val_reg ty =
    match Types.repr ty with
    | Types.TInt -> 
      add_extern ctx "mml_fmt_int" "void" ("i64" :: []);
      Ir_emit.emit_call_void ctx.ir "mml_fmt_int" (("i64", val_reg) :: [])
    | Types.TBool -> 
      add_extern ctx "mml_fmt_bool" "void" ("i64" :: []);
      Ir_emit.emit_call_void ctx.ir "mml_fmt_bool" (("i64", val_reg) :: [])
    | Types.TString -> 
      add_extern ctx "mml_fmt_string" "void" ("i64" :: []);
      Ir_emit.emit_call_void ctx.ir "mml_fmt_string" (("i64", val_reg) :: [])
    | Types.TFloat -> 
      add_extern ctx "mml_fmt_float" "void" ("i64" :: []);
      Ir_emit.emit_call_void ctx.ir "mml_fmt_float" (("i64", val_reg) :: [])
    | Types.TUnit -> emit_format_str ctx "()"
    | Types.TTuple tys -> 
      emit_format_str ctx "(";
      let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
      List.iteri (fn i elem_ty -> if i > 0 do
        emit_format_str ctx ", "
      end;
      let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr i in
      let elem = Ir_emit.emit_load ctx.ir "i64" elem_ptr in
      emit_format_value ctx elem elem_ty) tys;
      emit_format_str ctx ")"
    | Types.TRecord row -> 
      let fields = Types.record_row_to_fields row in
      let sorted = List.sort (fn (a, _) (b, _) -> String.compare a b) fields in
      emit_format_str ctx "{ ";
      let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
      List.iteri (fn i (fname, fty) -> if i > 0 do
        emit_format_str ctx "; "
      end;
      emit_format_str ctx (fname ^ " = ");
      let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr i in
      let elem = Ir_emit.emit_load ctx.ir "i64" elem_ptr in
      emit_format_value ctx elem fty) sorted;
      emit_format_str ctx " }"
    | Types.TVariant ((type_name, ty_args)) -> 
      if Types.type_is_newtype ctx.type_env type_name do
        do
          match List.assoc_opt type_name ctx.variant_defs with
          | Some ((_, Some underlying_ty) :: []) -> 
            let args = Array.of_list ty_args in
            let rec instantiate t =
              match Types.repr t with
              | Types.TGen i when i < (Array.length args) -> Array.get args i
              | Types.TTuple ts -> Types.TTuple (List.map instantiate ts)
              | Types.TVariant ((n, ts)) -> Types.TVariant (n, List.map instantiate ts)
              | Types.TList t' -> Types.TList (instantiate t')
              | _ -> t
             in
            emit_format_value ctx val_reg (instantiate underlying_ty)
          | _ -> emit_format_variant ctx val_reg type_name ty_args

        end
      else
        emit_format_variant ctx val_reg type_name ty_args
    | Types.TList elem_ty -> 
      emit_format_str ctx "[";
      let loop_head = fresh_label ctx "list_loop" in
      let loop_body = fresh_label ctx "list_body" in
      let loop_done = fresh_label ctx "list_done" in
      let cur_ptr = Ir_emit.emit_alloca ctx.ir "i64" in
      let first_ptr = Ir_emit.emit_alloca ctx.ir "i64" in
      Ir_emit.emit_store ctx.ir "i64" val_reg cur_ptr;
      Ir_emit.emit_store ctx.ir "i64" true_value first_ptr;
      Ir_emit.emit_br ctx.ir loop_head;
      Ir_emit.emit_label ctx.ir loop_head;
      ctx.current_label := loop_head;
      let cur = Ir_emit.emit_load ctx.ir "i64" cur_ptr in
      let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" cur "1" in
      let is_nil = Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0" in
      Ir_emit.emit_condbr ctx.ir is_nil loop_done loop_body;
      Ir_emit.emit_label ctx.ir loop_body;
      ctx.current_label := loop_body;
      let is_first = Ir_emit.emit_load ctx.ir "i64" first_ptr in
      let not_first = Ir_emit.emit_icmp ctx.ir "eq" "i64" is_first false_value in
      let sep_label = fresh_label ctx "list_sep" in
      let elem_label = fresh_label ctx "list_elem" in
      Ir_emit.emit_condbr ctx.ir not_first sep_label elem_label;
      Ir_emit.emit_label ctx.ir sep_label;
      ctx.current_label := sep_label;
      emit_format_str ctx "; ";
      Ir_emit.emit_br ctx.ir elem_label;
      Ir_emit.emit_label ctx.ir elem_label;
      ctx.current_label := elem_label;
      let cell_ptr = Ir_emit.emit_inttoptr ctx.ir cur in
      let hd_ptr = Ir_emit.emit_gep ctx.ir "i64" cell_ptr 0 in
      let hd_val = Ir_emit.emit_load ctx.ir "i64" hd_ptr in
      emit_format_value ctx hd_val elem_ty;
      let tl_ptr = Ir_emit.emit_gep ctx.ir "i64" cell_ptr 1 in
      let tl_val = Ir_emit.emit_load ctx.ir "i64" tl_ptr in
      Ir_emit.emit_store ctx.ir "i64" tl_val cur_ptr;
      Ir_emit.emit_store ctx.ir "i64" false_value first_ptr;
      Ir_emit.emit_br ctx.ir loop_head;
      Ir_emit.emit_label ctx.ir loop_done;
      ctx.current_label := loop_done;
      emit_format_str ctx "]"
    | Types.TArray elem_ty -> 
      emit_format_str ctx "#[";
      let is_empty = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
      let empty_check = Ir_emit.emit_icmp ctx.ir "ne" "i64" is_empty "0" in
      let arr_nonempty = fresh_label ctx "arr_nonempty" in
      let arr_end = fresh_label ctx "arr_end" in
      Ir_emit.emit_condbr ctx.ir empty_check arr_end arr_nonempty;
      Ir_emit.emit_label ctx.ir arr_nonempty;
      ctx.current_label := arr_nonempty;
      let arr_ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
      let len_ptr = Ir_emit.emit_gep ctx.ir "i64" arr_ptr 0 in
      let arr_len = Ir_emit.emit_load ctx.ir "i64" len_ptr in
      let idx_ptr = Ir_emit.emit_alloca ctx.ir "i64" in
      Ir_emit.emit_store ctx.ir "i64" "0" idx_ptr;
      let loop_head = fresh_label ctx "arr_loop" in
      let loop_body = fresh_label ctx "arr_body" in
      let loop_done = fresh_label ctx "arr_done" in
      Ir_emit.emit_br ctx.ir loop_head;
      Ir_emit.emit_label ctx.ir loop_head;
      ctx.current_label := loop_head;
      let idx = Ir_emit.emit_load ctx.ir "i64" idx_ptr in
      let cmp = Ir_emit.emit_icmp ctx.ir "slt" "i64" idx arr_len in
      Ir_emit.emit_condbr ctx.ir cmp loop_body loop_done;
      Ir_emit.emit_label ctx.ir loop_body;
      ctx.current_label := loop_body;
      let not_first = Ir_emit.emit_icmp ctx.ir "ne" "i64" idx "0" in
      let sep_label = fresh_label ctx "arr_sep" in
      let elem_label = fresh_label ctx "arr_elem" in
      Ir_emit.emit_condbr ctx.ir not_first sep_label elem_label;
      Ir_emit.emit_label ctx.ir sep_label;
      ctx.current_label := sep_label;
      emit_format_str ctx "; ";
      Ir_emit.emit_br ctx.ir elem_label;
      Ir_emit.emit_label ctx.ir elem_label;
      ctx.current_label := elem_label;
      let offset = Ir_emit.emit_binop ctx.ir "add" "i64" idx "1" in
      let elem_ptr = Ir_emit.emit_gep_dynamic ctx.ir "i64" arr_ptr offset in
      let elem_val = Ir_emit.emit_load ctx.ir "i64" elem_ptr in
      emit_format_value ctx elem_val elem_ty;
      let next_idx = Ir_emit.emit_binop ctx.ir "add" "i64" idx "1" in
      Ir_emit.emit_store ctx.ir "i64" next_idx idx_ptr;
      Ir_emit.emit_br ctx.ir loop_head;
      Ir_emit.emit_label ctx.ir loop_done;
      ctx.current_label := loop_done;
      Ir_emit.emit_br ctx.ir arr_end;
      Ir_emit.emit_label ctx.ir arr_end;
      ctx.current_label := arr_end;
      emit_format_str ctx "]"
    | Types.TPolyVariant row -> 
      let rec collect_tags acc =
        fn
          | Types.PVRow ((name, payload_ty, rest)) -> 
            let tag = Types.polyvar_tag name in
            collect_tags ((tag, name, payload_ty) :: acc) rest
          | Types.PVVar {contents = Types.PVLink r} -> collect_tags acc r
          | _ -> List.rev acc
       in
      let tags = collect_tags [] row in
      let done_label = fresh_label ctx "fmt_pv_done" in
      let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
      let is_tagged = Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0" in
      let tagged_label = fresh_label ctx "fmt_pv_tagged" in
      let ptr_label = fresh_label ctx "fmt_pv_ptr" in
      Ir_emit.emit_condbr ctx.ir is_tagged tagged_label ptr_label;
      Ir_emit.emit_label ctx.ir tagged_label;
      ctx.current_label := tagged_label;
      let default_tagged = fresh_label ctx "fmt_pv_tagged_default" in
      let tagged_cases = List.filter_map (fn (tag, name, payload_ty) ->
        do
          match payload_ty with
          | None -> 
            let label = fresh_label ctx ($"fmt_pvt_{tag}") in
            Some (tag_int_value tag, label, name)
          | Some _ -> None

        end) tags in
      Ir_emit.emit_switch ctx.ir val_reg default_tagged (List.map (fn (tag, label, _) -> (tag, label)) tagged_cases);
      List.iter (fn (_, label, name) -> Ir_emit.emit_label ctx.ir label;
      ctx.current_label := label;
      emit_format_str ctx ("`" ^ name);
      Ir_emit.emit_br ctx.ir done_label) tagged_cases;
      Ir_emit.emit_label ctx.ir default_tagged;
      ctx.current_label := default_tagged;
      emit_format_str ctx "<poly_variant>";
      Ir_emit.emit_br ctx.ir done_label;
      Ir_emit.emit_label ctx.ir ptr_label;
      ctx.current_label := ptr_label;
      let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
      let tag_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
      let tag_val = Ir_emit.emit_load ctx.ir "i64" tag_ptr in
      let default_ptr = fresh_label ctx "fmt_pv_ptr_default" in
      let ptr_cases = List.filter_map (fn (tag, name, payload_ty) ->
        do
          match payload_ty with
          | Some _ -> 
            let label = fresh_label ctx ($"fmt_pvp_{tag}") in
            Some (tag_int_value tag, label, name, payload_ty)
          | None -> None

        end) tags in
      Ir_emit.emit_switch ctx.ir tag_val default_ptr (List.map (fn (tag, label, _, _) -> (tag, label)) ptr_cases);
      List.iter (fn (_tag, label, name, payload_ty) -> Ir_emit.emit_label ctx.ir label;
      ctx.current_label := label;
      do
        match payload_ty with
        | Some pty -> 
          emit_format_str ctx ("`" ^ (name ^ " "));
          let payload_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
          let payload = Ir_emit.emit_load ctx.ir "i64" payload_ptr in
          let needs_parens =
            match Types.repr pty with
            | ((Types.TTuple _ | Types.TVariant _) | Types.TPolyVariant _) -> true
            | _ -> false
           in
          if needs_parens do
            emit_format_str ctx "("
          end;
          emit_format_value ctx payload pty;
          if needs_parens do
            emit_format_str ctx ")"
          end
        | None -> emit_format_str ctx ("`" ^ name)

      end;
      Ir_emit.emit_br ctx.ir done_label) ptr_cases;
      Ir_emit.emit_label ctx.ir default_ptr;
      ctx.current_label := default_ptr;
      emit_format_str ctx "<poly_variant>";
      Ir_emit.emit_br ctx.ir done_label;
      Ir_emit.emit_label ctx.ir done_label;
      ctx.current_label := done_label
    | Types.TByte -> 
      add_extern ctx "mml_fmt_byte" "void" ("i64" :: []);
      Ir_emit.emit_call_void ctx.ir "mml_fmt_byte" (("i64", val_reg) :: [])
    | Types.TRune -> 
      add_extern ctx "mml_fmt_rune" "void" ("i64" :: []);
      Ir_emit.emit_call_void ctx.ir "mml_fmt_rune" (("i64", val_reg) :: [])
    | _ -> emit_format_str ctx "<unknown>"

  and emit_format_str ctx s =
    let name = $".str.{ctx.str_counter}" in
    ctx.str_counter := ctx.str_counter + 1;
    let escaped = Buffer.contents (llvm_escape_string s) in
    let len = (String.length s) + 1 in
    let decl = $"@{name} = private unnamed_addr constant [{len} x i8] c\"{escaped}\\00\"" in
    ctx.string_globals := decl :: ctx.string_globals;
    let sptr = Ir_emit.emit_ptrtoint ctx.ir ($"@{name}") in
    add_extern ctx "mml_fmt_str" "void" ("i64" :: []);
    Ir_emit.emit_call_void ctx.ir "mml_fmt_str" (("i64", sptr) :: [])
  and emit_format_variant ctx val_reg type_name ty_args =
    match List.assoc_opt type_name ctx.variant_defs with
    | None -> emit_format_str ctx "<variant>"
    | Some vdef -> 
      let instantiate_ty ty =
        let args = Array.of_list ty_args in
        let rec go t =
          match Types.repr t with
          | Types.TGen i when i < (Array.length args) -> Array.get args i
          | Types.TTuple ts -> Types.TTuple (List.map go ts)
          | Types.TRecord _ -> t
          | Types.TVariant ((n, ts)) -> Types.TVariant (n, List.map go ts)
          | Types.TList t' -> Types.TList (go t')
          | _ -> t
         in
        go ty in
      let done_label = fresh_label ctx "fmt_done" in
      let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
      let is_tagged = Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0" in
      let tagged_label = fresh_label ctx "fmt_tagged" in
      let ptr_label = fresh_label ctx "fmt_ptr" in
      Ir_emit.emit_condbr ctx.ir is_tagged tagged_label ptr_label;
      Ir_emit.emit_label ctx.ir tagged_label;
      ctx.current_label := tagged_label;
      let default_tagged = fresh_label ctx "fmt_tagged_default" in
      let tagged_cases = List.filter_map (fn (i, (ctor_name, payload_ty)) ->
        do
          match payload_ty with
          | None -> 
            let label = fresh_label ctx ($"fmt_tag_{i}") in
            Some (tag_int_value i, label, ctor_name)
          | Some _ -> None

        end) (List.mapi (fn i c -> (i, c)) vdef) in
      Ir_emit.emit_switch ctx.ir val_reg default_tagged (List.map (fn (tag, label, _) -> (tag, label)) tagged_cases);
      List.iter (fn (_, label, ctor_name) -> Ir_emit.emit_label ctx.ir label;
      ctx.current_label := label;
      emit_format_str ctx ctor_name;
      Ir_emit.emit_br ctx.ir done_label) tagged_cases;
      Ir_emit.emit_label ctx.ir default_tagged;
      ctx.current_label := default_tagged;
      emit_format_str ctx "<unknown>";
      Ir_emit.emit_br ctx.ir done_label;
      Ir_emit.emit_label ctx.ir ptr_label;
      ctx.current_label := ptr_label;
      let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
      let tag_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
      let tag_val = Ir_emit.emit_load ctx.ir "i64" tag_ptr in
      let default_ptr = fresh_label ctx "fmt_ptr_default" in
      let ptr_cases = List.filter_map (fn (i, (ctor_name, payload_ty)) ->
        do
          match payload_ty with
          | Some _ -> 
            let label = fresh_label ctx ($"fmt_ctor_{i}") in
            Some (tag_int_value i, label, ctor_name, payload_ty)
          | None -> None

        end) (List.mapi (fn i c -> (i, c)) vdef) in
      Ir_emit.emit_switch ctx.ir tag_val default_ptr (List.map (fn (tag, label, _, _) -> (tag, label)) ptr_cases);
      List.iter (fn (_tag, label, ctor_name, payload_ty) -> Ir_emit.emit_label ctx.ir label;
      ctx.current_label := label;
      do
        match payload_ty with
        | Some pty -> 
          let concrete_pty = instantiate_ty pty in
          emit_format_str ctx (ctor_name ^ " ");
          let payload_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
          let payload = Ir_emit.emit_load ctx.ir "i64" payload_ptr in
          let needs_parens =
            match Types.repr concrete_pty with
            | (Types.TTuple _ | Types.TVariant _) -> true
            | _ -> false
           in
          if needs_parens do
            emit_format_str ctx "("
          end;
          emit_format_value ctx payload concrete_pty;
          if needs_parens do
            emit_format_str ctx ")"
          end
        | None -> emit_format_str ctx ctor_name

      end;
      Ir_emit.emit_br ctx.ir done_label) ptr_cases;
      Ir_emit.emit_label ctx.ir default_ptr;
      ctx.current_label := default_ptr;
      emit_format_str ctx "<unknown>";
      Ir_emit.emit_br ctx.ir done_label;
      Ir_emit.emit_label ctx.ir done_label;
      ctx.current_label := done_label

  and tag_int_value n = (n lsl 1) lor 1

  pub let collect_symbol_refs text =
    let n = String.length text in
    let set = Hashtbl.create 256 in
    let is_sym c = ((c >= #61) && (c <= #7a)) || (((c >= #41) && (c <= #5a)) || (((c >= #30) && (c <= #39)) || ((c = #5f) || ((c = #2e) || ((c = #24) || (c = #2d)))))) in
    let i = Ref.create 0 in
    for (Ref.get i) < n do
      if (String.get text (Ref.get i)) = #40 do
        let j = Ref.create ((Ref.get i) + 1) in
        for ((Ref.get j) < n) && (is_sym (String.get text (Ref.get j))) do
          Ref.set j (Ref.get j + 1)
        end;
        if (Ref.get j) > ((Ref.get i) + 1) do
          Hashtbl.set set (String.sub text ((Ref.get i) + 1) (((Ref.get j) - (Ref.get i)) - 1)) ()
        end;
        Ref.set i (Ref.get j)
      else
        Ref.set i (Ref.get i + 1)
    end;
    set

  pub let assemble_output imports aliases emit_result_type ctx main_body =
    let body = Buffer.create 8192 in
    List.iter (fn decl -> Buffer.add_string body decl;
    Buffer.add_byte body #0a) (List.rev ctx.string_globals);
    if ctx.string_globals <> [] do
      Buffer.add_byte body #0a
    end;
    List.iter (fn decl -> Buffer.add_string body decl;
    Buffer.add_byte body #0a) (List.rev ctx.float_globals);
    if ctx.float_globals <> [] do
      Buffer.add_byte body #0a
    end;
    List.iter (fn decl -> Buffer.add_string body decl;
    Buffer.add_byte body #0a) (List.rev ctx.global_decls);
    if emit_result_type do
      -- a binding-terminated program has no value to echo (tag 8 = MML_RESULT_NONE)
      let tag = if ctx.result_present do result_type_tag ctx.result_type else 8 in
      Buffer.add_string (body) $"@mml_result_type = global i32 {tag}
"
    end;
    Buffer.add_byte body #0a;
    if (Buffer.length ctx.fn_buf) > 0 do
      Buffer.add_buffer body ctx.fn_buf
    end;
    Buffer.add_string body main_body;
    List.iter (fn a -> Buffer.add_byte body #0a;
    Buffer.add_string body a;
    Buffer.add_byte body #0a) aliases;
    let body_str = Buffer.contents body in
    let out = Buffer.create ((String.length body_str) + 4096) in
    Buffer.add_string (out) $"target triple = \"{ctx.target_triple}\"

";
    let base_externs = ("mml_print_int", "i64", "i64" :: []) :: ("mml_print_bool", "i64", "i64" :: []) :: ("mml_print_string", "i64", "i64" :: []) :: ("mml_print_float", "i64", "i64" :: []) :: ("mml_print_unit", "i64", "i64" :: []) :: ("mml_print_value", "i64", "i64" :: []) :: ("mml_box_float", "i64", "double" :: []) :: ("mml_unbox_float", "double", "i64" :: []) :: ("mml_alloc", "ptr", "i64" :: "i64" :: []) :: [] in
    let all_externs = List.concat base_externs ctx.extern_decls in
    let seen = Hashtbl.create 16 in
    List.iter (fn (name, ret_ty, param_tys) -> if not (Hashtbl.has seen name) do
      Hashtbl.set seen name ();
      let pt_str =
        match param_tys with
        | [] -> ""
        | _ -> String.concat ", " param_tys
       in
      let attrs =
        if (name = "mml_panic") || (name = "mml_panic_mml") do
          " noreturn"
        else
          "" in
      Buffer.add_string (out) $"declare {ret_ty} @{name}({pt_str}){attrs}
"
    end) all_externs;
    let refs = collect_symbol_refs body_str in
    let needed = Hashtbl.fold (fn sym () acc ->
      do
        match Hashtbl.get imports sym with
        | Some d -> d :: acc
        | None -> acc

      end) refs [] in
    List.iter (fn d -> Buffer.add_string out d;
    Buffer.add_byte out #0a) (List.sort_uniq String.compare needed);
    Buffer.add_byte out #0a;
    Buffer.add_string out body_str;
    Buffer.contents out

  pub let emit_unit_init ctx init_name decls =
    let saved_ir = ctx.ir in
    let saved_label = ctx.current_label in
    let saved_result_ptr = ctx.result_ptr in
    let saved_fn_void = ctx.current_fn_void in
    let fn_ir = Ir_emit.create () in
    ctx.ir := fn_ir;
    ctx.current_fn_void := true;
    Ir_emit.emit_define_start fn_ir "void" init_name [];
    Ir_emit.emit_label fn_ir "entry";
    ctx.current_label := "entry";
    ctx.result_ptr := Ir_emit.emit_alloca fn_ir "i64";
    Ir_emit.emit_store fn_ir "i64" unit_value ctx.result_ptr;
    List.iter (emit_decl ctx) decls;
    Ir_emit.emit_ret_void ctx.ir;
    Ir_emit.emit_define_end ctx.ir;
    Buffer.add_string ctx.fn_buf (Ir_emit.contents ctx.ir);
    Buffer.add_byte ctx.fn_buf #0a;
    ctx.ir := saved_ir;
    ctx.current_label := saved_label;
    ctx.result_ptr := saved_result_ptr;
    ctx.current_fn_void := saved_fn_void

  pub let rec arrow_arity ty =
    match Types.repr ty with
    | Types.TArrow ((_, _, ret)) -> 1 + (arrow_arity ret)
    | _ -> 0


  pub let is_ffi_bare_extern name = List.mem name ("__cache_has" :: "__cache_get" :: "__cache_set" :: [])

  pub let collect_module_externs (programs : Typechecker.tprogram list) =
    let tbl = Hashtbl.create 32 in
    let rec scan decls = List.iter (fn d ->
      do
        match d with
        | Typechecker.TDExtern ((name, scheme)) when (String.contains "." name) || (is_ffi_bare_extern name) -> Hashtbl.set tbl name (arrow_arity scheme.body)
        | Typechecker.TDModule ((_, inner, _)) -> scan inner
        | _ -> ()

      end) decls in
    List.iter scan programs;
    tbl

  -- Collect typed-FFI externs (TDFfi) into name -> (c_symbol, params, ret).
  pub let collect_ffi_externs (programs : Typechecker.tprogram list) =
    let tbl = Hashtbl.create 16 in
    let rec scan decls = List.iter (fn d ->
      do
        match d with
        | Typechecker.TDFfi ((name, _scheme, c_symbol, c_params, c_ret)) -> Hashtbl.set tbl name (c_symbol, c_params, c_ret)
        | Typechecker.TDModule ((_, inner, _)) -> scan inner
        | _ -> ()
      end) decls in
    List.iter scan programs;
    tbl

  pub let compile_program_with_stdlib target_triple (type_env : Types.type_env) (stdlib_programs : (Types.type_env * Typechecker.tprogram) list) (user_program : Typechecker.tprogram) : string =
    let ctx = create_ctx target_triple type_env in
    ctx.module_externs := collect_module_externs (user_program :: List.map snd stdlib_programs);
    ctx.ffi_externs := collect_ffi_externs (user_program :: List.map snd stdlib_programs);
    let stdlib_decls = List.concat_map (fn (_te, prog) -> prog) stdlib_programs in
    emit_unit_init ctx "mml_init_std" stdlib_decls;
    Ir_emit.emit_define_start ctx.ir "i64" "mml_main" [];
    Ir_emit.emit_label ctx.ir "entry";
    ctx.current_label := "entry";
    ctx.result_ptr := Ir_emit.emit_alloca ctx.ir "i64";
    Ir_emit.emit_store ctx.ir "i64" unit_value ctx.result_ptr;
    Ir_emit.emit_call_void ctx.ir "mml_init_std" [];
    List.iter (emit_decl ctx) user_program;
    ctx.result_present := (match List.rev user_program with Typechecker.TDExpr _ :: _ -> true | _ -> false);
    let result = Ir_emit.emit_load ctx.ir "i64" ctx.result_ptr in
    Ir_emit.emit_ret ctx.ir "i64" result;
    Ir_emit.emit_define_end ctx.ir;
    emit_format_result ctx ctx.result_type;
    let main_body = Ir_emit.contents ctx.ir in
    assemble_output (Hashtbl.create 1) [] true ctx main_body

  pub let global_decl_to_extern decl =
    match String.index_opt decl #20 with
    | Some i -> (String.sub decl 0 i) ^ " = external global i64"
    | None -> decl


  pub type unit_exports = {
    ue_init: string;
    ue_funcs: (string * int) list;
    ue_global_externs: string list;
    ue_scope: (string * var_info) list;
    ue_aliases: string list
  }

  pub let export_alias_name unit_prefix source_name = $"mml_x_{unit_prefix}{sanitize_name source_name}"

  pub let capture_exports ctx init_name =
    let scope = List.hd ctx.scopes in
    let funcs = Ref.create [] in
    let entries = Ref.create [] in
    let aliases = Ref.create [] in
    let local_prefix = "mml_f_" ^ ctx.unit_prefix in
    Hashtbl.iter (fn name info ->
      do
        match match info with
        | FuncLocal ((n, a, _)) -> Func (n, a)
        | i -> i
         with
        | Func ((internal, a)) when String.starts_with local_prefix internal -> 
          let stable = export_alias_name ctx.unit_prefix name in
          let ps = String.concat ", " (List.init a (fn _ -> "i64")) in
          Ref.set aliases ($"@{stable} = alias i64 ({ps}), ptr @{internal}" :: Ref.get aliases);
          Ref.set funcs ((stable, a) :: Ref.get funcs);
          Ref.set entries ((name, Func (stable, a)) :: Ref.get entries)
        | Func ((internal, a)) -> 
          Ref.set funcs ((internal, a) :: Ref.get funcs);
          Ref.set entries ((name, Func (internal, a)) :: Ref.get entries)
        | other -> Ref.set entries ((name, other) :: Ref.get entries)

      end) scope;
    {ue_init = init_name; ue_funcs = Ref.get funcs; ue_global_externs = List.map global_decl_to_extern ctx.global_decls; ue_scope = Ref.get entries; ue_aliases = Ref.get aliases}

  pub let global_extern_name line =
    if ((String.length line) > 1) && ((String.get line 0) = #40) do
      do
        match String.index_opt line #20 with
        | Some i -> Some (String.sub line 1 (i - 1))
        | None -> None

      end
    else
      None

  pub let build_import_table (exps : unit_exports list) =
    let t = Hashtbl.create 512 in
    List.iter (fn e -> Hashtbl.set t e.ue_init ($"declare void @{e.ue_init}()");
    List.iter (fn (n, a) -> let ps = String.concat ", " (List.init a (fn _ -> "i64")) in
    Hashtbl.set t n ($"declare i64 @{n}({ps})")) e.ue_funcs;
    List.iter (fn gext ->
      do
        match global_extern_name gext with
        | Some nm -> Hashtbl.set t nm gext
        | None -> ()

      end) e.ue_global_externs) exps;
    t

  pub let seed_scope ctx (exp : unit_exports) =
    let top = List.hd ctx.scopes in
    List.iter (fn (name, info) -> Hashtbl.set top name info) exp.ue_scope

  pub let compile_units target_triple (type_env : Types.type_env) (stdlib_programs : (Types.type_env * Typechecker.tprogram) list) (user_program : Typechecker.tprogram) : (string * string) list =
    let externs = collect_module_externs (user_program :: List.map snd stdlib_programs) in
    let ctx_std = create_ctx target_triple type_env in
    ctx_std.module_externs := externs;
    ctx_std.unit_prefix := "s_";
    let stdlib_decls = List.concat_map (fn (_te, p) -> p) stdlib_programs in
    emit_unit_init ctx_std "mml_init_std" stdlib_decls;
    let exports_std = capture_exports ctx_std "mml_init_std" in
    let stdlib_ll = assemble_output (Hashtbl.create 1) exports_std.ue_aliases false ctx_std "" in
    let ctx = create_ctx target_triple type_env in
    ctx.module_externs := externs;
    ctx.unit_prefix := "u_";
    seed_scope ctx exports_std;
    Ir_emit.emit_define_start ctx.ir "i64" "mml_main" [];
    Ir_emit.emit_label ctx.ir "entry";
    ctx.current_label := "entry";
    ctx.result_ptr := Ir_emit.emit_alloca ctx.ir "i64";
    Ir_emit.emit_store ctx.ir "i64" unit_value ctx.result_ptr;
    Ir_emit.emit_call_void ctx.ir "mml_init_std" [];
    let visible = Ref.create (exports_std :: []) in
    let module_units = Ref.create [] in
    let mod_seen = Hashtbl.create 8 in
    List.iter (fn decl ->
      do
        match decl with
        | Typechecker.TDModule ((name, inner, _)) -> 
          let base = sanitize_name name in
          let n =
            match Hashtbl.get mod_seen base with
            | Some n -> n
            | None -> 0
           in
          Hashtbl.set mod_seen base (n + 1);
          let mangled =
            if n = 0 do
              base
            else
              $"{base}_{n}" in
          let init_name = $"mml_init_m_{mangled}" in
          let ctx_m = create_ctx target_triple type_env in
          ctx_m.module_externs := externs;
          ctx_m.unit_prefix := $"m_{mangled}_";
          List.iter (seed_scope ctx_m) (List.rev (Ref.get visible));
          push_scope ctx_m;
          emit_unit_init ctx_m init_name inner;
          let exp = capture_exports ctx_m init_name in
          let m_ll = assemble_output (build_import_table (List.rev (Ref.get visible))) exp.ue_aliases false ctx_m "" in
          Ref.set module_units (($"mod_{mangled}", m_ll) :: Ref.get module_units);
          Ref.set visible (exp :: Ref.get visible);
          seed_scope ctx exp;
          Ir_emit.emit_call_void ctx.ir init_name []
        | d -> emit_decl ctx d

      end) user_program;
    let result = Ir_emit.emit_load ctx.ir "i64" ctx.result_ptr in
    Ir_emit.emit_ret ctx.ir "i64" result;
    Ir_emit.emit_define_end ctx.ir;
    emit_format_result ctx ctx.result_type;
    let main_body = Ir_emit.contents ctx.ir in
    let entry_ll = assemble_output (build_import_table (List.rev (Ref.get visible))) [] true ctx main_body in
    List.concat (("stdlib", stdlib_ll) :: List.rev (Ref.get module_units)) (("main", entry_ll) :: [])

end
