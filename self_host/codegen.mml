module Codegen =


  pub let tag_int (n : int) : string = string_of_int ((n lsl 1) lor 1)

  pub let unit_value = "1"

  pub let true_value = "3"

  pub let false_value = "1"

  pub type var_info =
    | Local of string
    | MutLocal of string
    | MutRefCell of string
    | Global of string
    | MutGlobal of string
    | Func of string * int
    | FuncLocal of string * int * string


  pub type codegen_ctx = {
    mut ir: Ir_emit.t;
    fn_buf: Buffer.t;
    mut scopes: (string, var_info) Hashtbl.t list;
    mut current_label: string;
    mut label_counter: int;
    mut fn_counter: int;
    mut module_externs: (string, int) Hashtbl.t;
    -- typed-FFI externs (TDFfi): name -> (c_symbol, c_param_types, c_return_type),
    -- driving marshalled direct C calls (see emit_ffi_call).
    mut ffi_externs: (string, string * Ast.cty list * Ast.cty) Hashtbl.t;
    mut unit_prefix: string;
    mut str_counter: int;
    mut float_counter: int;
    mut string_globals: string list;
    mut float_globals: string list;
    mut extern_decls: (string * string * string list) list;
    mut global_decls: string list;
    mut loop_stack: (string * string) list;
    mut result_type: Types.ty;
    mut has_print_output: bool;
    mut variant_defs: (string * Types.variant_def) list;
    mut constructors: (string * (string * int)) list;
    type_env: Types.type_env;
    generated_wrappers: (string, unit) Hashtbl.t;
    mut fold_break_depth: int;
    mut fold_guard_pending: bool;
    mut in_handler_thunk: bool;
    mut handler_mark_ptr: string option;
    mut or_pattern_allocas: (string * string) list;
    mut current_dict_name: string option;
    mut result_ptr: string;
    mut target_triple: string;
    mut current_fn_void: bool;
    -- false once the program is known to end in a binding (no value to echo)
    mut result_present: bool
  }

  pub let create_ctx target_triple type_env =
    let tbl = Hashtbl.create 16 in
    let variant_defs = List.map (fn (name, _nparams, vdef, _is_gadt) -> (name, vdef)) type_env.variants in
    let constructors = List.map (fn (name, info) -> let tag =
      if List.mem_assoc info.ctor_type_name variant_defs do
        Types.nominal_ctor_tag type_env info.ctor_type_name (Types.short_unqual name)
      else
        0 in
    (name, (info.ctor_type_name, tag))) type_env.constructors in
    {ir = Ir_emit.create (); fn_buf = Buffer.create 4096; scopes = tbl :: []; current_label = "entry"; label_counter = 0; fn_counter = 0; module_externs = Hashtbl.create 16; ffi_externs = Hashtbl.create 16; unit_prefix = ""; str_counter = 0; float_counter = 0; string_globals = []; float_globals = []; extern_decls = []; global_decls = []; loop_stack = []; result_type = Types.TUnit; has_print_output = false; variant_defs; constructors; type_env; generated_wrappers = Hashtbl.create 16; fold_break_depth = 0; fold_guard_pending = false; in_handler_thunk = false; handler_mark_ptr = None; or_pattern_allocas = []; current_dict_name = None; result_ptr = ""; target_triple; current_fn_void = false; result_present = true}

  pub let push_scope ctx = ctx.scopes := Hashtbl.create 8 :: ctx.scopes

  pub let pop_scope ctx =
    match ctx.scopes with
    | _ :: rest -> ctx.scopes := rest
    | [] -> failwith "pop_scope: empty scope stack"


  pub let bind_var ctx name info =
    match ctx.scopes with
    | top :: _ -> Hashtbl.set top name info
    | [] -> failwith "bind_var: empty scope stack"


  pub let lookup_var ctx name =
    let rec search =
      fn
        | [] -> None
        | scope :: rest -> 
          do
            match Hashtbl.get scope name with
            | Some v -> Some v
            | None -> search rest

          end
     in
    search ctx.scopes

  pub let fresh_label ctx prefix =
    let n = ctx.label_counter in
    ctx.label_counter := n + 1;
    $"{prefix}_{n}"

  pub let add_extern ctx name ret_ty param_tys =
    if not (List.exists (fn (n, _, _) -> n = name) ctx.extern_decls) do
      ctx.extern_decls := (name, ret_ty, param_tys) :: ctx.extern_decls
    end

  pub let llvm_escape_string s =
    let buf = Buffer.create ((String.length s) * 2) in
    String.iter (fn c -> let code = Byte.to_int c in
    if (code >= 32) && ((code < 127) && ((c <> #22) && (c <> #5c))) do
      Buffer.add_byte buf c
    else
      Buffer.add_string (buf) $"\\{code:02X}") s;
    buf

  pub let llvm_encode_le_i64 n =
    let buf = Buffer.create 24 in
    let mut i = 0 in
    for i <= 7 do
      let byte = (n lsr (i * 8)) land 0xFF in
      Buffer.add_string (buf) $"\\{byte:02X}";
      i := i + 1
    end;
    Buffer.contents buf

  pub let llvm_format_float f = "0x" ^ (Math.float_bits_hex f)

  pub let mml_hdr_cons = 0x00

  pub let mml_hdr_tuple = 0x01

  pub let mml_hdr_record = 0x02

  pub let mml_hdr_closure = 0x03

  pub let mml_hdr_variant = 0x04

  pub let mml_hdr_array = 0x05

  pub let mml_hdr_float = 0x07

  pub let mml_hdr_pair = 0x09

  pub let mml_hdr_ref = 0x0A

  pub let mml_hdr_polyvar = 0x0B

  pub let make_header size tag = string_of_int ((size lsl 16) lor tag)

  pub let emit_alloc ctx nbytes header =
    add_extern ctx "mml_alloc" "ptr" ("i64" :: "i64" :: []);
    Ir_emit.emit_call ctx.ir "ptr" "mml_alloc" (("i64", string_of_int nbytes) :: ("i64", header) :: [])

  pub let short_ctor_name name =
    match String.rindex_opt name #2e with
    | Some i -> String.sub name (i + 1) (((String.length name) - i) - 1)
    | None -> name


  pub let lookup_ctor ctx name =
    match List.assoc_opt name ctx.constructors with
    | Some _ as r -> r
    | None -> List.assoc_opt (short_ctor_name name) ctx.constructors


  pub let tag_for_constructor ctx name =
    match lookup_ctor ctx name with
    | Some ((_, tag)) -> tag
    | None -> failwith ($"native codegen: unknown constructor {name} (not yet implemented)")


  pub let is_newtype_ctor ctx name =
    match lookup_ctor ctx name with
    | Some ((type_name, _tag)) -> Types.type_is_newtype ctx.type_env type_name
    | None -> false


  pub let rec subst_tgens_in_ty inst_tys ty =
    match ty with
    | Types.TGen i when i < (List.length inst_tys) -> List.nth inst_tys i
    | Types.TArrow ((a, e, r)) -> Types.TArrow (subst_tgens_in_ty inst_tys a, e, subst_tgens_in_ty inst_tys r)
    | Types.TTuple ts -> Types.TTuple (List.map (subst_tgens_in_ty inst_tys) ts)
    | Types.TList t -> Types.TList (subst_tgens_in_ty inst_tys t)
    | Types.TArray t -> Types.TArray (subst_tgens_in_ty inst_tys t)
    | _ -> ty


  pub let field_index_from_type ty field_name =
    let row =
      match Types.repr ty with
      | Types.TRecord row -> row
      | _ -> failwith ($"native codegen: field {field_name} access on non-record (typeclass dict access requires Phase 3)")
     in
    let fields = Types.record_row_to_fields row in
    let sorted = List.sort (fn (a, _) (b, _) -> String.compare a b) fields in
    let rec find i =
      fn
        | [] -> failwith ($"native codegen: field {field_name} not found in record type")
        | (name, _) :: _ when name = field_name -> i
        | _ :: rest -> find (i + 1) rest
     in
    find 0 sorted

  pub let record_fields_from_type ty =
    let row =
      match Types.repr ty with
      | Types.TRecord row -> row
      | _ -> failwith "native codegen: record update on non-record"
     in
    let fields = Types.record_row_to_fields row in
    List.sort (fn (a, _) (b, _) -> String.compare a b) fields

  pub let emit_make_closure ctx fn_name arity captures =
    let n_captures = List.length captures in
    let total_slots = 3 + n_captures in
    let ptr = emit_alloc ctx (total_slots * 8) (make_header total_slots mml_hdr_closure) in
    let fn_ptr_i64 = Ir_emit.emit_ptrtoint ctx.ir ($"@{fn_name}") in
    let slot0 = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
    Ir_emit.emit_store ctx.ir "i64" fn_ptr_i64 slot0;
    let slot1 = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
    Ir_emit.emit_store ctx.ir "i64" (string_of_int arity) slot1;
    let slot2 = Ir_emit.emit_gep ctx.ir "i64" ptr 2 in
    Ir_emit.emit_store ctx.ir "i64" "0" slot2;
    List.iteri (fn i cap_val -> let slot = Ir_emit.emit_gep ctx.ir "i64" ptr (3 + i) in
    Ir_emit.emit_store ctx.ir "i64" cap_val slot) captures;
    Ir_emit.emit_ptrtoint ctx.ir ptr

  pub let emit_closure_apply ctx closure_val arg_vals =
    let n = List.length arg_vals in
    if n <= 3 do
      let apply_name = $"mml_apply{n}" in
      let param_tys = List.init (n + 1) (fn _ -> "i64") in
      add_extern ctx apply_name "i64" param_tys;
      let all_args = ("i64", closure_val) :: List.map (fn v -> ("i64", v)) arg_vals in
      Ir_emit.emit_call ctx.ir "i64" apply_name all_args
    else do
      let arr_ptr = Ir_emit.emit_alloca_array ctx.ir "i64" n in
      List.iteri (fn i v -> let slot = Ir_emit.emit_gep ctx.ir "i64" arr_ptr i in
      Ir_emit.emit_store ctx.ir "i64" v slot) arg_vals;
      add_extern ctx "mml_apply" "i64" ("i64" :: "i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_apply" (("i64", closure_val) :: ("ptr", arr_ptr) :: ("i64", string_of_int n) :: [])
    end

  pub let rec _is_captured_in_closures name (body : Typechecker.texpr) =
    let found = Ref.create false in
    let rec scan (e : Typechecker.texpr) =
      if Ref.get found do
        ()
      else
        match e.expr with
        | TEFun _ -> 
          let (params, fn_body) =
            let rec collect ps e =
              match e.expr with
              | TEFun ((p, b, _)) -> collect (p :: ps) b
              | _ -> (List.rev ps, e)
             in
            collect [] e in
          let param_set = List.fold (fn s p -> let tbl = Hashtbl.create 4 in
          Hashtbl.set tbl p ();
          (s; ());
          tbl) (Hashtbl.create 4) params in
          (param_set; ());
          if (not (List.mem name params)) && (mentions_var name fn_body) do
            Ref.set found true
          end;
          scan fn_body
        | ((((((TEInt _ | TEFloat _) | TEBool _) | TEString _) | TEUnit) | TEByte _) | TERune _) -> ()
        | TEVar _ -> ()
        | ((TEBinop ((_, a, b)) | TESeq ((a, b))) | TEApp ((a, b))) -> 
          scan a;
          scan b
        | ((TEUnop ((_, a)) | TEReturn a) | TEBreak a) -> scan a
        | TEIf ((c, t, e)) -> 
          scan c;
          scan t;
          scan e
        | TELet ((n, _, init, body)) -> 
          scan init;
          if n <> name do
            scan body
          end
        | TELetRec ((n, _, init, body)) -> 
          if n <> name do
            scan init;
            scan body
          end
        | TELetRecAnd ((bindings, body)) -> 
          let names = List.map fst bindings in
          List.iter (fn (_, e) -> scan e) bindings;
          if not (List.mem name names) do
            scan body
          end
        | TELetMut ((n, init, body)) -> 
          scan init;
          if n <> name do
            scan body
          end
        | TEAssign ((_, e)) -> scan e
        | TEWhile {tw_cond; tw_body; tw_step} -> 
          scan tw_cond;
          scan tw_body;
          Option.iter scan tw_step
        | TEContinueLoop -> ()
        | TETuple es -> List.iter scan es
        | TERecord fields -> List.iter (fn (_, e) -> scan e) fields
        | TERecordUpdate ((base, overrides)) -> 
          scan base;
          List.iter (fn (_, e) -> scan e) overrides
        | TERecordUpdateIdx ((base, pairs)) -> 
          scan base;
          List.iter (fn (i, v) -> scan i;
          scan v) pairs
        | TEField ((e, _)) -> scan e
        | TEFieldAssign ((e1, _, e2)) -> 
          scan e1;
          scan e2
        | TEConstruct ((_, arg, _)) -> Option.iter scan arg
        | (TEForLoop e | TEFoldContinue e) -> scan e
        | TEIndex ((e1, e2)) -> 
          scan e1;
          scan e2
        | TEMatch ((scrut, arms, _)) -> 
          scan scrut;
          List.iter (fn (_, guard, body) -> Option.iter scan guard;
          scan body) arms
        | TEMatchTree cm -> 
          scan cm.scrutinee;
          Array.iter (fn arm -> scan arm.arm_body) cm.match_arms
        | TEPerform ((_op, arg_e)) -> scan arg_e
        | TEResume ((k_e, v_e)) -> 
          scan k_e;
          scan v_e
        | TEHandle ((body_e, arms)) -> 
          let body_is_thunk = List.exists (fn
            | (Typechecker.THOpTry _ | Typechecker.THOp _) -> true
            | _ -> false
          ) arms in
          if body_is_thunk && (mentions_var name body_e) do
            Ref.set found true
          else
            scan body_e;
          List.iter (fn arm ->
            do
              match arm with
              | Typechecker.THReturn ((n, e)) -> 
                if (n <> name) && (mentions_var name e) do
                  Ref.set found true
                else
                  scan e
              | Typechecker.THOp {arg; k; body = e; _} -> 
                if (arg <> name) && ((k <> name) && (mentions_var name e)) do
                  Ref.set found true
                else
                  scan e
              | Typechecker.THOpProvide ((_, arg, e)) -> 
                if (arg <> name) && (mentions_var name e) do
                  Ref.set found true
                else
                  scan e
              | Typechecker.THOpTry ((_, arg, e)) -> 
                if (arg <> name) && (mentions_var name e) do
                  Ref.set found true
                else
                  scan e

            end) arms
        | _ -> ()
     in
    scan body;
    Ref.get found
  and mentions_var name (e : Typechecker.texpr) =
    match e.expr with
    | TEVar n -> n = name
    | ((((((TEInt _ | TEFloat _) | TEBool _) | TEString _) | TEUnit) | TEByte _) | TERune _) -> false
    | ((TEBinop ((_, a, b)) | TESeq ((a, b))) | TEApp ((a, b))) -> (mentions_var name a) || (mentions_var name b)
    | ((TEUnop ((_, a)) | TEReturn a) | TEBreak a) -> mentions_var name a
    | TEIf ((c, t, e)) -> (mentions_var name c) || ((mentions_var name t) || (mentions_var name e))
    | TELet ((n, _, init, body)) -> (mentions_var name init) || ((n <> name) && (mentions_var name body))
    | TELetRec ((n, _, init, body)) -> ((n <> name) && (mentions_var name init)) || ((n <> name) && (mentions_var name body))
    | TELetMut ((n, init, body)) -> (mentions_var name init) || ((n <> name) && (mentions_var name body))
    | TEAssign ((n, e)) -> (n = name) || (mentions_var name e)
    | TEFun ((p, body, _)) -> (p <> name) && (mentions_var name body)
    | TEWhile {tw_cond; tw_body; tw_step} -> (mentions_var name tw_cond) || ((mentions_var name tw_body) || (match tw_step with
    | Some s -> mentions_var name s
    | None -> false
    ))
    | TEContinueLoop -> false
    | TETuple es -> List.exists (mentions_var name) es
    | TERecord fields -> List.exists (fn (_, e) -> mentions_var name e) fields
    | TERecordUpdate ((base, overrides)) -> (mentions_var name base) || (List.exists (fn (_, e) -> mentions_var name e) overrides)
    | TERecordUpdateIdx ((base, pairs)) -> (mentions_var name base) || (List.exists (fn (i, v) -> (mentions_var name i) || (mentions_var name v)) pairs)
    | TEField ((e, _)) -> mentions_var name e
    | TEFieldAssign ((e1, _, e2)) -> (mentions_var name e1) || (mentions_var name e2)
    | TEConstruct ((_, arg, _)) -> (Option.is_some arg) && (mentions_var name (Option.unwrap arg))
    | TEMatch ((scrut, arms, _)) -> (mentions_var name scrut) || (List.exists (fn (_, guard, body) -> (match guard with
    | Some g -> mentions_var name g
    | None -> false
    ) || (mentions_var name body)) arms)
    | TELetRecAnd ((bindings, body)) -> (List.exists (fn (_, e) -> mentions_var name e) bindings) || (mentions_var name body)
    | (TEForLoop e | TEFoldContinue e) -> mentions_var name e
    | TEIndex ((e1, e2)) -> (mentions_var name e1) || (mentions_var name e2)
    | TEMatchTree cm -> (mentions_var name cm.scrutinee) || ((Array.exists (fn arm -> mentions_var name arm.arm_body) cm.match_arms) || (mentions_var_in_dtree name cm.tree))
    | TEPerform ((_op, arg_e)) -> mentions_var name arg_e
    | TEResume ((k_e, v_e)) -> (mentions_var name k_e) || (mentions_var name v_e)
    | TEHandle ((body_e, arms)) -> (mentions_var name body_e) || (List.exists (fn arm ->
      do
        match arm with
        | Typechecker.THReturn ((n, e)) -> (n <> name) && (mentions_var name e)
        | Typechecker.THOp {arg; k; body = e; _} -> (arg <> name) && ((k <> name) && (mentions_var name e))
        | Typechecker.THOpProvide ((_, arg, e)) -> (arg <> name) && (mentions_var name e)
        | Typechecker.THOpTry ((_, arg, e)) -> (arg <> name) && (mentions_var name e)

      end) arms)
    | _ -> false

  and mentions_var_in_mk name mk =
    match mk with
    | Match_tree_types.MKPin n -> n = name
    | _ -> false

  and mentions_var_in_test name test =
    match test with
    | Match_tree_types.TPin n -> n = name
    | Match_tree_types.TMapHasKey mk -> mentions_var_in_mk name mk
    | _ -> false

  and mentions_var_in_occ name occ = List.exists (fn
    | Match_tree_types.AMapValue mk -> mentions_var_in_mk name mk
    | _ -> false
  ) occ
  and mentions_var_in_dtree name =
    fn
      | Match_tree_types.DSwitch {cases; default; _} -> (List.exists (fn (test, binds, sub) -> (mentions_var_in_test name test) || ((List.exists (fn (b : Match_tree_types.binding) -> mentions_var_in_occ name b.bind_occ) binds) || (mentions_var_in_dtree name sub))) cases) || (match default with
      | Some d -> mentions_var_in_dtree name d
      | None -> false
      )
      | Match_tree_types.DGuard {guard; bindings; on_true; on_false; _} -> (mentions_var name guard) || ((List.exists (fn (b : Match_tree_types.binding) -> mentions_var_in_occ name b.bind_occ) bindings) || ((mentions_var_in_dtree name on_true) || (mentions_var_in_dtree name on_false)))
      | Match_tree_types.DLeaf {bindings; _} -> List.exists (fn (b : Match_tree_types.binding) -> mentions_var_in_occ name b.bind_occ) bindings
      | Match_tree_types.DFail _ -> false


  pub let with_fresh_ir ctx f =
    let saved_ir = ctx.ir in
    let saved_label = ctx.current_label in
    let saved_scopes = ctx.scopes in
    let saved_loop_stack = ctx.loop_stack in
    let saved_in_handler_thunk = ctx.in_handler_thunk in
    let saved_handler_mark_ptr = ctx.handler_mark_ptr in
    let saved_fn_void = ctx.current_fn_void in
    ctx.in_handler_thunk := false;
    ctx.handler_mark_ptr := None;
    ctx.current_fn_void := false;
    let fn_ir = Ir_emit.create () in
    ctx.ir := fn_ir;
    let result = f fn_ir in
    Buffer.add_string ctx.fn_buf (Ir_emit.contents fn_ir);
    Buffer.add_byte ctx.fn_buf #0a;
    ctx.ir := saved_ir;
    ctx.current_label := saved_label;
    ctx.scopes := saved_scopes;
    ctx.loop_stack := saved_loop_stack;
    ctx.in_handler_thunk := saved_in_handler_thunk;
    ctx.handler_mark_ptr := saved_handler_mark_ptr;
    ctx.current_fn_void := saved_fn_void;
    result

  pub let emit_ctl_ret ctx value =
    if ctx.current_fn_void do
      Ir_emit.emit_ret_void ctx.ir
    else
      Ir_emit.emit_ret ctx.ir "i64" value

  pub let rec body_installs_inline_handler (e : Typechecker.texpr) =
    match e.expr with
    | Typechecker.TEFun _ -> false
    | Typechecker.TEHandle ((_, arms)) -> not (List.exists (fn
      | (Typechecker.THOpTry _ | Typechecker.THOp _) -> true
      | _ -> false
    ) arms)
    | _ -> 
      let found = Ref.create false in
      (Typechecker.map_texpr_children (fn c -> if body_installs_inline_handler c do
        Ref.set found true
      end;
      c) e; ());
      Ref.get found


  pub let setup_handler_mark ctx body =
    if body_installs_inline_handler body do
      add_extern ctx "mml_handler_mark" "i64" [];
      let mark = Ir_emit.emit_call ctx.ir "i64" "mml_handler_mark" [] in
      let ptr = Ir_emit.emit_alloca ctx.ir "i64" in
      Ir_emit.emit_store ctx.ir "i64" mark ptr;
      ctx.handler_mark_ptr := Some ptr
    end

  pub let emit_handler_mark_restore ctx =
    match ctx.handler_mark_ptr with
    | None -> ()
    | Some ptr -> 
      add_extern ctx "mml_handler_restore" "void" ("i64" :: []);
      let m = Ir_emit.emit_load ctx.ir "i64" ptr in
      Ir_emit.emit_call_void ctx.ir "mml_handler_restore" (("i64", m) :: [])


  pub let emit_break_action ctx v =
    match ctx.loop_stack with
    | (_, exit_label) :: _ -> Ir_emit.emit_br ctx.ir exit_label
    | [] when ctx.in_handler_thunk -> 
      emit_handler_mark_restore ctx;
      add_extern ctx "mml_set_break_escape" "void" ("i64" :: []);
      Ir_emit.emit_call_void ctx.ir "mml_set_break_escape" (("i64", v) :: []);
      emit_ctl_ret ctx v
    | [] when ctx.fold_break_depth > 0 -> 
      emit_handler_mark_restore ctx;
      add_extern ctx "mml_fold_break" "void" ("i64" :: []);
      Ir_emit.emit_call_void ctx.ir "mml_fold_break" (("i64", v) :: []);
      emit_ctl_ret ctx v
    | [] -> failwith "native codegen: break outside loop"


  pub let emit_continue_action ctx =
    match ctx.loop_stack with
    | (cond_label, _) :: _ -> Ir_emit.emit_br ctx.ir cond_label
    | [] when ctx.in_handler_thunk -> 
      emit_handler_mark_restore ctx;
      add_extern ctx "mml_set_continue_escape" "void" [];
      Ir_emit.emit_call_void ctx.ir "mml_set_continue_escape" [];
      emit_ctl_ret ctx unit_value
    | [] when ctx.fold_break_depth > 0 -> 
      emit_handler_mark_restore ctx;
      emit_ctl_ret ctx unit_value
    | [] -> failwith "native codegen: continue outside loop"


  pub let rec emit_expr (ctx : codegen_ctx) (expr : Typechecker.texpr) : string =
    match expr.expr with
    | TEInt n -> tag_int n
    | TEByte n -> tag_int n
    | TERune n -> tag_int n
    | TEBool true -> true_value
    | TEBool false -> false_value
    | TEUnit -> unit_value
    | TEString s -> 
      let name = $".str.{ctx.str_counter}" in
      ctx.str_counter := ctx.str_counter + 1;
      let escaped = Buffer.contents (llvm_escape_string s) in
      let slen = String.length s in
      let header_prefix = llvm_encode_le_i64 0x06 in
      let len_prefix = llvm_encode_le_i64 (slen * 2) in
      let total = ((8 + 8) + slen) + 1 in
      let decl = $"@{name} = private unnamed_addr constant [{total} x i8] c\"{header_prefix}{len_prefix}{escaped}\\00\", align 8" in
      ctx.string_globals := decl :: ctx.string_globals;
      let gep = Ir_emit.emit_gep ctx.ir "i8" ($"@{name}") 8 in
      Ir_emit.emit_ptrtoint ctx.ir gep
    | TEFloat f -> 
      let name = $".float.{ctx.float_counter}" in
      ctx.float_counter := ctx.float_counter + 1;
      let decl = $"@{name} = private unnamed_addr constant \{ i64, double \} \{ i64 {0x07}, double {llvm_format_float f} \}" in
      ctx.float_globals := decl :: ctx.float_globals;
      let gep = Ir_emit.emit_gep ctx.ir "i8" ($"@{name}") 8 in
      Ir_emit.emit_ptrtoint ctx.ir gep
    | TEUnop ((Ast.Neg, e)) -> 
      do
        let ty = Types.repr e.ty in
        match ty with
        | Types.TFloat -> 
          let v = emit_expr ctx e in
          let d = emit_unbox_float ctx v in
          let neg = Ir_emit.emit_fneg ctx.ir d in
          emit_box_float ctx neg
        | _ -> 
          do
            match e.expr with
            | TEInt n -> tag_int (-(n))
            | _ -> 
              let v = emit_expr ctx e in
              let untagged = Ir_emit.emit_binop ctx.ir "ashr" "i64" v "1" in
              let negated = Ir_emit.emit_binop ctx.ir "sub" "i64" "0" untagged in
              let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" negated "1" in
              Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"

          end

      end
    | TEUnop ((Ast.Not, e)) -> 
      let v = emit_expr ctx e in
      Ir_emit.emit_binop ctx.ir "xor" "i64" v "2"
    | TEUnop ((Ast.Lnot, e)) -> 
      let v = emit_expr ctx e in
      let untagged = Ir_emit.emit_binop ctx.ir "ashr" "i64" v "1" in
      let notted = Ir_emit.emit_binop ctx.ir "xor" "i64" untagged "-1" in
      let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" notted "1" in
      Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"
    | TEBinop ((op, e1, e2)) -> emit_binop ctx op e1 e2
    | TEApp ((fn_expr, arg_expr)) -> emit_app ctx fn_expr arg_expr
    | TESeq ((e1, e2)) -> 
      (emit_expr ctx e1; ());
      emit_expr ctx e2
    | TEVar name -> emit_var ctx name expr.ty
    | TELet ((name, _scheme, init, body)) -> emit_let ctx name init body false
    | TELetRec ((name, _scheme, fn_expr, body)) -> emit_letrec ctx name fn_expr body
    | TELetRecAnd ((bindings, body)) -> emit_letrec_and ctx bindings body
    | TELetMut ((name, init, body)) -> emit_let ctx name init body true
    | TEAssign ((name, value_expr)) -> 
      do
        let v = emit_expr ctx value_expr in
        match lookup_var ctx name with
        | Some (MutLocal ptr) -> 
          Ir_emit.emit_store ctx.ir "i64" v ptr;
          unit_value
        | Some (MutRefCell alloca_ptr) -> 
          let heap_ptr = Ir_emit.emit_load ctx.ir "i64" alloca_ptr in
          let ptr = Ir_emit.emit_inttoptr ctx.ir heap_ptr in
          Ir_emit.emit_store ctx.ir "i64" v ptr;
          unit_value
        | Some (MutGlobal gname) -> 
          Ir_emit.emit_store ctx.ir "i64" v ($"@{gname}");
          unit_value
        | _ -> failwith ($"native codegen: cannot assign to {name}")

      end
    | TEIf ((cond, then_e, else_e)) -> emit_if ctx cond then_e else_e
    | TEWhile {tw_cond; tw_body; tw_step} -> emit_while ctx tw_cond tw_body tw_step
    | TEBreak value_expr -> 
      let v = emit_expr ctx value_expr in
      emit_break_action ctx v;
      let dead = fresh_label ctx "dead" in
      Ir_emit.emit_label ctx.ir dead;
      ctx.current_label := dead;
      v
    | TEContinueLoop -> 
      emit_continue_action ctx;
      let dead = fresh_label ctx "dead" in
      Ir_emit.emit_label ctx.ir dead;
      ctx.current_label := dead;
      unit_value
    | TEFun _ -> emit_lambda_as_closure ctx expr
    | TEReturn e -> 
      let v = emit_expr ctx e in
      emit_handler_mark_restore ctx;
      if (ctx.fold_break_depth > 0) || ctx.in_handler_thunk do
        add_extern ctx "mml_set_early_return" "void" ("i64" :: []);
        Ir_emit.emit_call_void ctx.ir "mml_set_early_return" (("i64", v) :: []);
        emit_ctl_ret ctx v
      else
        emit_ctl_ret ctx v;
      let dead = fresh_label ctx "dead" in
      Ir_emit.emit_label ctx.ir dead;
      ctx.current_label := dead;
      v
    | TETuple exprs -> emit_tuple ctx exprs
    | TERecord fields -> emit_record ctx fields
    | TEField ((record_expr, field_name)) -> emit_field ctx record_expr field_name expr.ty
    | TERecordUpdate ((base, overrides)) -> emit_record_update ctx base overrides
    | TERecordUpdateIdx ((base, pairs)) -> emit_record_update_idx ctx base pairs
    | TEFieldAssign ((record_expr, field_name, value_expr)) -> emit_field_assign ctx record_expr field_name value_expr
    | TEConstruct ((name, arg, tag)) -> emit_construct ctx name arg tag
    | TEMatch ((scrutinee, arms, _partial)) -> emit_match ctx scrutinee arms
    | TENil -> unit_value
    | TECons ((hd_expr, tl_expr)) -> 
      let hd_val = emit_expr ctx hd_expr in
      let tl_val = emit_expr ctx tl_expr in
      let ptr = emit_alloc ctx 16 (make_header 0 mml_hdr_cons) in
      let hd_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
      Ir_emit.emit_store ctx.ir "i64" hd_val hd_ptr;
      let tl_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
      Ir_emit.emit_store ctx.ir "i64" tl_val tl_ptr;
      Ir_emit.emit_ptrtoint ctx.ir ptr
    | TEArray elems -> 
      let n = List.length elems in
      if n = 0 do
        unit_value
      else do
        let vals = List.map (emit_expr ctx) elems in
        let total_bytes = (n + 1) * 8 in
        let ptr = emit_alloc ctx total_bytes (make_header 0 mml_hdr_array) in
        let len_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
        Ir_emit.emit_store ctx.ir "i64" (string_of_int n) len_ptr;
        List.iteri (fn i v -> let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr (i + 1) in
        Ir_emit.emit_store ctx.ir "i64" v elem_ptr) vals;
        Ir_emit.emit_ptrtoint ctx.ir ptr
      end
    | TEForLoop fold_expr -> 
      ctx.fold_break_depth := ctx.fold_break_depth + 1;
      let result = emit_for_loop_expr ctx fold_expr in
      ctx.fold_break_depth := ctx.fold_break_depth - 1;
      add_extern ctx "mml_check_early_return" "i64" [];
      let flag = Ir_emit.emit_call ctx.ir "i64" "mml_check_early_return" [] in
      let has_return = Ir_emit.emit_icmp ctx.ir "ne" "i64" flag "0" in
      let early_ret = fresh_label ctx "early_ret" in
      let no_ret = fresh_label ctx "no_early_ret" in
      Ir_emit.emit_condbr ctx.ir has_return early_ret no_ret;
      Ir_emit.emit_label ctx.ir early_ret;
      ctx.current_label := early_ret;
      add_extern ctx "mml_get_early_return" "i64" [];
      let ret_val = Ir_emit.emit_call ctx.ir "i64" "mml_get_early_return" [] in
      emit_ctl_ret ctx ret_val;
      Ir_emit.emit_label ctx.ir no_ret;
      ctx.current_label := no_ret;
      result
    | TEFoldContinue value_expr -> 
      let v = emit_expr ctx value_expr in
      emit_ctl_ret ctx v;
      let dead = fresh_label ctx "dead" in
      Ir_emit.emit_label ctx.ir dead;
      ctx.current_label := dead;
      v
    | TEIndex ((base_expr, idx_expr)) -> 
      do
        let base_val = emit_expr ctx base_expr in
        let idx_val = emit_expr ctx idx_expr in
        let base_ty = Types.repr base_expr.ty in
        match base_ty with
        | Types.TString -> 
          add_extern ctx "mml_string_get_byte" "i64" ("i64" :: "i64" :: []);
          Ir_emit.emit_call ctx.ir "i64" "mml_string_get_byte" (("i64", idx_val) :: ("i64", base_val) :: [])
        | Types.TArray _ -> 
          add_extern ctx "mml_array_get" "i64" ("i64" :: "i64" :: []);
          Ir_emit.emit_call ctx.ir "i64" "mml_array_get" (("i64", idx_val) :: ("i64", base_val) :: [])
        | _ -> 
          add_extern ctx "mml_list_nth" "i64" ("i64" :: "i64" :: []);
          Ir_emit.emit_call ctx.ir "i64" "mml_list_nth" (("i64", idx_val) :: ("i64", base_val) :: [])

      end
    | TEPerform ((op_name, arg_expr)) -> 
      let arg_val = emit_expr ctx arg_expr in
      let op_str = emit_c_string ctx op_name in
      add_extern ctx "mml_perform_op" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_perform_op" (("i64", op_str) :: ("i64", arg_val) :: [])
    | TEMatchTree cm -> emit_match_tree ctx cm
    | TEHandle ((body_expr, arms)) -> emit_handle ctx body_expr arms
    | TEResume ((k_expr, val_expr)) -> 
      let k_val = emit_expr ctx k_expr in
      let v_val = emit_expr ctx val_expr in
      add_extern ctx "mml_resume_continuation" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_resume_continuation" (("i64", k_val) :: ("i64", v_val) :: [])

  and emit_var ctx name expr_ty =
    match lookup_var ctx name with
    | Some (Local ptr) -> Ir_emit.emit_load ctx.ir "i64" ptr
    | Some (MutLocal ptr) -> Ir_emit.emit_load ctx.ir "i64" ptr
    | Some (MutRefCell alloca_ptr) -> 
      let heap_ptr = Ir_emit.emit_load ctx.ir "i64" alloca_ptr in
      let ptr = Ir_emit.emit_inttoptr ctx.ir heap_ptr in
      Ir_emit.emit_load ctx.ir "i64" ptr
    | Some (Global gname) -> Ir_emit.emit_load ctx.ir "i64" ($"@{gname}")
    | Some (MutGlobal gname) -> Ir_emit.emit_load ctx.ir "i64" ($"@{gname}")
    | Some (Func ((llvm_name, arity))) -> emit_func_as_closure ctx llvm_name arity
    | Some (FuncLocal ((_, _, alloca_ptr))) -> Ir_emit.emit_load ctx.ir "i64" alloca_ptr
    | None -> 
      do
        match emit_builtin_as_value ctx name expr_ty with
        | Some v -> v
        | None -> 
          if is_dict_or_inst name do
            emit_or_cache_builtin_dict ctx name
          else
            failwith ($"native codegen: unbound variable {name} (not yet implemented)")

      end

  and emit_let ctx name init body is_mutable =
    match init.expr with
    | TEFun _ when not is_mutable -> 
      let (params, fn_body) = flatten_fun init in
      if params <> [] do
        let fn_id = ctx.fn_counter in
        ctx.fn_counter := ctx.fn_counter + 1;
        let llvm_name = $"mml_f_{ctx.unit_prefix}{sanitize_name name}_{fn_id}" in
        let free = free_vars_of_fun (Some ctx) params fn_body in
        if free = [] do
          let arity = List.length params in
          emit_named_function ctx llvm_name params fn_body;
          let wrapper_name = $"{llvm_name}_wrap" in
          if not (Hashtbl.has ctx.generated_wrappers wrapper_name) do
            Hashtbl.set ctx.generated_wrappers wrapper_name ();
            emit_func_wrapper ctx wrapper_name llvm_name arity
          end;
          let closure_val = emit_make_closure ctx wrapper_name arity [] in
          let ptr = Ir_emit.emit_alloca ctx.ir "i64" in
          Ir_emit.emit_store ctx.ir "i64" closure_val ptr;
          push_scope ctx;
          bind_var ctx name (FuncLocal (llvm_name, arity, ptr));
          let result = emit_expr ctx body in
          pop_scope ctx;
          result
        else do
          let free_with_info = List.map (fn n ->
            do
              match lookup_var ctx n with
              | Some info -> (n, info)
              | None -> failwith ($"native codegen: free var {n} not found")

            end) free in
          let closure_fn_name = $"{llvm_name}_cls" in
          emit_closure_function ctx closure_fn_name params fn_body free_with_info;
          let captures = List.map (fn (n, info) -> emit_capture_value ctx n info) free_with_info in
          let closure_val = emit_make_closure ctx closure_fn_name (List.length params) captures in
          let ptr = Ir_emit.emit_alloca ctx.ir "i64" in
          Ir_emit.emit_store ctx.ir "i64" closure_val ptr;
          push_scope ctx;
          bind_var ctx name (Local ptr);
          let result = emit_expr ctx body in
          pop_scope ctx;
          result
        end
      else
        emit_let_value emit_expr ctx name init body is_mutable
    | _ -> emit_let_value emit_expr ctx name init body is_mutable

  and emit_let_value emit_body ctx name init body is_mutable =
    let v = emit_expr ctx init in
    if is_mutable do
      let cell_ptr = emit_alloc ctx 8 (make_header 0 mml_hdr_ref) in
      Ir_emit.emit_store ctx.ir "i64" v cell_ptr;
      let cell_i64 = Ir_emit.emit_ptrtoint ctx.ir cell_ptr in
      let alloca_ptr = Ir_emit.emit_alloca ctx.ir "i64" in
      Ir_emit.emit_store ctx.ir "i64" cell_i64 alloca_ptr;
      push_scope ctx;
      bind_var ctx name (MutRefCell alloca_ptr);
      let result = emit_body ctx body in
      pop_scope ctx;
      result
    else do
      let ptr = Ir_emit.emit_alloca ctx.ir "i64" in
      Ir_emit.emit_store ctx.ir "i64" v ptr;
      push_scope ctx;
      bind_var ctx name (if is_mutable do
        MutLocal ptr
      else
        Local ptr);
      let result = emit_body ctx body in
      pop_scope ctx;
      result
    end
  and emit_rec_placeholder ctx te =
    let rec go te =
      match te.expr with
      | Typechecker.TECons _ -> 
        let ptr = emit_alloc ctx 16 (make_header 0 mml_hdr_cons) in
        let hd_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
        Ir_emit.emit_store ctx.ir "i64" unit_value hd_ptr;
        let tl_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
        Ir_emit.emit_store ctx.ir "i64" unit_value tl_ptr;
        (Ir_emit.emit_ptrtoint ctx.ir ptr, 16)
      | Typechecker.TETuple es -> 
        let n = List.length es in
        let nbytes = n * 8 in
        let ptr = emit_alloc ctx nbytes (make_header n mml_hdr_tuple) in
        let mut i = 0 in
        for i <= n - 1 do
          let p = Ir_emit.emit_gep ctx.ir "i64" ptr i in
          Ir_emit.emit_store ctx.ir "i64" unit_value p;
          i := i + 1
        end;
        (Ir_emit.emit_ptrtoint ctx.ir ptr, nbytes)
      | Typechecker.TERecord fields -> 
        let sorted = List.sort (fn (a, _) (b, _) -> String.compare a b) fields in
        let n = List.length sorted in
        let nbytes = n * 8 in
        let ptr = emit_alloc ctx nbytes (make_header n mml_hdr_record) in
        let mut i = 0 in
        for i <= n - 1 do
          let p = Ir_emit.emit_gep ctx.ir "i64" ptr i in
          Ir_emit.emit_store ctx.ir "i64" unit_value p;
          i := i + 1
        end;
        (Ir_emit.emit_ptrtoint ctx.ir ptr, nbytes)
      | Typechecker.TEConstruct ((name, payload_opt, tag)) -> 
        do
          if is_newtype_ctor ctx name do
            do
              match payload_opt with
              | Some inner -> go inner
              | None -> failwith "native codegen: cannot create placeholder for nullary newtype"

            end
          else
            match payload_opt with
            | Some _ -> 
              let hdr_tag =
                if ((String.length name) > 0) && ((String.get name 0) = #60) do
                  mml_hdr_polyvar
                else
                  mml_hdr_variant in
              let ptr = emit_alloc ctx 16 (make_header 0 hdr_tag) in
              let tag_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
              Ir_emit.emit_store ctx.ir "i64" (tag_int tag) tag_ptr;
              let payload_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
              Ir_emit.emit_store ctx.ir "i64" unit_value payload_ptr;
              (Ir_emit.emit_ptrtoint ctx.ir ptr, 16)
            | None -> failwith "native codegen: cannot create placeholder for nullary variant"

        end
      | Typechecker.TEArray es -> 
        let n = List.length es in
        let total_bytes = (n + 1) * 8 in
        let ptr = emit_alloc ctx total_bytes (make_header 0 mml_hdr_array) in
        let len_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
        Ir_emit.emit_store ctx.ir "i64" (string_of_int n) len_ptr;
        let mut i = 1 in
        for i <= n do
          let p = Ir_emit.emit_gep ctx.ir "i64" ptr i in
          Ir_emit.emit_store ctx.ir "i64" unit_value p;
          i := i + 1
        end;
        (Ir_emit.emit_ptrtoint ctx.ir ptr, total_bytes)
      | Typechecker.TELet ((_, _, _, body)) -> go body
      | Typechecker.TESeq ((_, body)) -> go body
      | _ -> failwith "native codegen: cannot create placeholder for recursive value"
     in
    go te
  and emit_backpatch ctx placeholder_val computed_val nbytes =
    let p_ptr = Ir_emit.emit_inttoptr ctx.ir placeholder_val in
    let c_ptr = Ir_emit.emit_inttoptr ctx.ir computed_val in
    add_extern ctx "memcpy" "ptr" ("ptr" :: "ptr" :: "i64" :: []);
    (Ir_emit.emit_call ctx.ir "ptr" "memcpy" (("ptr", p_ptr) :: ("ptr", c_ptr) :: ("i64", string_of_int nbytes) :: []); ())
  and emit_letrec ctx name fn_expr body =
    let (params, inner_body) = flatten_fun fn_expr in
    if params = [] do
      push_scope ctx;
      let (placeholder_val, nbytes) = emit_rec_placeholder ctx fn_expr in
      let alloca = Ir_emit.emit_alloca ctx.ir "i64" in
      Ir_emit.emit_store ctx.ir "i64" placeholder_val alloca;
      bind_var ctx name (Local alloca);
      let computed_val = emit_expr ctx fn_expr in
      emit_backpatch ctx placeholder_val computed_val nbytes;
      let result = emit_expr ctx body in
      pop_scope ctx;
      result
    else do
      let fn_id = ctx.fn_counter in
      ctx.fn_counter := ctx.fn_counter + 1;
      let llvm_name = $"mml_f_{ctx.unit_prefix}{sanitize_name name}_{fn_id}" in
      let free = free_vars_of_fun (Some ctx) (name :: params) inner_body in
      if free = [] do
        push_scope ctx;
        bind_var ctx name (Func (llvm_name, List.length params));
        emit_named_function ctx llvm_name params inner_body;
        let result = emit_expr ctx body in
        pop_scope ctx;
        result
      else do
        push_scope ctx;
        let capture_infos = List.map (fn v ->
          do
            match lookup_var ctx v with
            | Some (MutLocal ptr) -> 
              let ptr_i64 = Ir_emit.emit_ptrtoint ctx.ir ptr in
              (v, ptr_i64, `Mutable)
            | Some (MutRefCell alloca_ptr) -> 
              let heap_ptr = Ir_emit.emit_load ctx.ir "i64" alloca_ptr in
              (v, heap_ptr, `RefCell)
            | _ -> (v, emit_var ctx v Types.TUnit, `Immutable)

          end) free in
        let capture_vals = List.map (fn (_, v, _) -> v) capture_infos in
        let arity = List.length params in
        let closure_val = emit_make_closure ctx llvm_name arity capture_vals in
        let closure_alloca = Ir_emit.emit_alloca ctx.ir "i64" in
        Ir_emit.emit_store ctx.ir "i64" closure_val closure_alloca;
        bind_var ctx name (Local closure_alloca);
        let capture_modes = List.map (fn (_, _, m) -> m) capture_infos in
        emit_named_function_with_captures ctx llvm_name params inner_body name free capture_modes;
        let result = emit_expr ctx body in
        pop_scope ctx;
        result
      end
    end
  and emit_letrec_and ctx bindings body =
    let all_names = List.map fst bindings in
    let binding_info = List.map (fn (name, fn_expr) -> let (params, _) = flatten_fun fn_expr in
    if params <> [] do
      `Func (name, fn_expr)
    else
      `Value (name, fn_expr)) bindings in
    let all_funcs = List.forall (fn
      | `Func _ -> true
      | _ -> false
    ) binding_info in
    let captures_outer = all_funcs && (List.exists (fn (_, fn_expr) -> let (params, inner) = flatten_fun fn_expr in
    let raw = free_vars_of_fun (Some ctx) params inner in
    List.exists (fn v -> not (List.mem v all_names)) raw) bindings) in
    if captures_outer do
      emit_letrec_and_closures ctx bindings body
    else
      emit_letrec_and_named ctx bindings binding_info body
  and emit_letrec_and_closures ctx bindings body =
    push_scope ctx;
    let fns = List.map (fn (name, fn_expr) -> let (params, inner) = flatten_fun fn_expr in
    (name, params, inner)) bindings in
    let group_names = List.map (fn (n, _, _) -> n) fns in
    let outer_free =
      let seen = Hashtbl.create 8 in
      let acc = Ref.create [] in
      List.iter (fn (_, params, inner) -> let raw = free_vars_of_fun (Some ctx) params inner in
      List.iter (fn v -> if (not (List.mem v group_names)) && (not (Hashtbl.has seen v)) do
        Hashtbl.set seen v ();
        Ref.set acc (v :: Ref.get acc)
      end) raw) fns;
      List.rev (Ref.get acc) in
    let outer_infos = List.map (fn v ->
      do
        match lookup_var ctx v with
        | Some (MutLocal ptr) -> (Ir_emit.emit_ptrtoint ctx.ir ptr, `Mutable)
        | Some (MutRefCell alloca_ptr) -> (Ir_emit.emit_load ctx.ir "i64" alloca_ptr, `RefCell)
        | _ -> (emit_var ctx v Types.TUnit, `Immutable)

      end) outer_free in
    let outer_vals = List.map fst outer_infos in
    let outer_modes = List.map snd outer_infos in
    let n_outer = List.length outer_free in
    let capture_names = List.concat outer_free group_names in
    let capture_modes = List.concat outer_modes (List.map (fn _ -> `Immutable) group_names) in
    let llvm_names = List.map (fn name -> let id = ctx.fn_counter in
    ctx.fn_counter := ctx.fn_counter + 1;
    $"mml_f_{ctx.unit_prefix}{sanitize_name name}_{id}") group_names in
    List.iter2 (fn (_, params, inner) llvm_name -> emit_named_function_with_captures ctx llvm_name params inner "__letrec_group_self" capture_names capture_modes) fns llvm_names;
    let closure_vals = List.map2 (fn (_, params, _) llvm_name -> let placeholders = List.map (fn _ -> "0") group_names in
    emit_make_closure ctx llvm_name (List.length params) (List.concat outer_vals placeholders)) fns llvm_names in
    List.iter2 (fn name cval -> let alloca = Ir_emit.emit_alloca ctx.ir "i64" in
    Ir_emit.emit_store ctx.ir "i64" cval alloca;
    bind_var ctx name (Local alloca)) group_names closure_vals;
    List.iter (fn ci -> let ci_ptr = Ir_emit.emit_inttoptr ctx.ir ci in
    List.iteri (fn j cj -> let slot = Ir_emit.emit_gep ctx.ir "i64" ci_ptr ((3 + n_outer) + j) in
    Ir_emit.emit_store ctx.ir "i64" cj slot) closure_vals) closure_vals;
    let result = emit_expr ctx body in
    pop_scope ctx;
    result
  and emit_letrec_and_named ctx bindings binding_info body =
    push_scope ctx;
    let all_names = List.map fst bindings in
    let value_infos = Ref.create [] in
    List.iter (fn info ->
      do
        match info with
        | `Func (name, fn_expr) -> 
          let (params, _) = flatten_fun fn_expr in
          let fn_id = ctx.fn_counter in
          ctx.fn_counter := ctx.fn_counter + 1;
          let llvm_name = $"mml_f_{ctx.unit_prefix}{sanitize_name name}_{fn_id}" in
          bind_var ctx name (Func (llvm_name, List.length params))
        | `Value (name, fn_expr) -> 
          let (placeholder_val, nbytes) = emit_rec_placeholder ctx fn_expr in
          let alloca = Ir_emit.emit_alloca ctx.ir "i64" in
          Ir_emit.emit_store ctx.ir "i64" placeholder_val alloca;
          bind_var ctx name (Local alloca);
          Ref.set value_infos ((name, fn_expr, placeholder_val, nbytes) :: Ref.get value_infos)

      end) binding_info;
    let value_infos = List.rev (Ref.get value_infos) in
    List.iter (fn info ->
      do
        match info with
        | `Func (name, fn_expr) -> 
          let (params, inner_body) = flatten_fun fn_expr in
          let llvm_name =
            match lookup_var ctx name with
            | Some (Func ((n, _))) -> n
            | _ -> failwith "expected Func"
           in
          let free = free_vars_of_fun (Some ctx) (List.concat all_names params) inner_body in
          if free <> [] do
            failwith ($"native codegen: closure captures free variables: {String.concat ", " free} (Phase 3)")
          end;
          emit_named_function ctx llvm_name params inner_body
        | `Value _ -> ()

      end) binding_info;
    List.iter (fn (_, fn_expr, placeholder_val, nbytes) -> let computed_val = emit_expr ctx fn_expr in
    emit_backpatch ctx placeholder_val computed_val nbytes) value_infos;
    let result = emit_expr ctx body in
    pop_scope ctx;
    result
  and find_custom_instance ctx class_name concrete_ty = List.find (fn (inst : Types.instance_def) -> (inst.inst_class = class_name) && ((inst.inst_constraints = []) && (match inst.inst_tys with
  | ty :: [] -> Types.match_partial_inst (ty :: []) (Some concrete_ty :: [])
  | _ -> false
  ))) ctx.type_env.instances
  and emit_dict_dispatch_binop ctx dict_name method_name e1 e2 =
    let dict_val = emit_var ctx dict_name Types.TUnit in
    let dict_ptr = Ir_emit.emit_inttoptr ctx.ir dict_val in
    let idx = dict_method_index ctx method_name in
    let method_ptr = Ir_emit.emit_gep ctx.ir "i64" dict_ptr idx in
    let method_closure = Ir_emit.emit_load ctx.ir "i64" method_ptr in
    let a = emit_expr ctx e1 in
    let b = emit_expr ctx e2 in
    add_extern ctx "mml_apply2" "i64" ("i64" :: "i64" :: "i64" :: []);
    Ir_emit.emit_call ctx.ir "i64" "mml_apply2" (("i64", method_closure) :: ("i64", a) :: ("i64", b) :: [])
  and emit_binop ctx op e1 e2 =
    match op with
    | Ast.And -> emit_short_circuit_and ctx e1 e2
    | Ast.Or -> emit_short_circuit_or ctx e1 e2
    | Ast.Concat -> emit_concat ctx e1 e2
    | Ast.Pipe -> emit_app ctx e2 e1
    | _ -> 
      do
        let ty1 = Types.repr e1.ty in
        let class_info =
          match op with
          | (((Ast.Add | Ast.Sub) | Ast.Mul) | Ast.Div) -> Some ("Num", match op with
          | Ast.Add -> "+"
          | Ast.Sub -> "-"
          | Ast.Mul -> "*"
          | Ast.Div -> "/"
          | _ -> "+"
          )
          | Ast.Eq -> Some ("Eq", "=")
          | Ast.Neq -> Some ("Eq", "<>")
          | Ast.Lt -> Some ("Ord", "<")
          | Ast.Gt -> Some ("Ord", ">")
          | Ast.Le -> Some ("Ord", "<=")
          | Ast.Ge -> Some ("Ord", ">=")
          | _ -> None
         in
        let custom_dispatch =
          match class_info with
          | Some ((class_name, method_name)) -> 
            do
              match ty1 with
              | ((((Types.TInt | Types.TFloat) | Types.TString) | Types.TBool) | Types.TUnit) -> None
              | _ -> 
                do
                  match find_custom_instance ctx class_name ty1 with
                  | Some inst -> Some (inst.inst_dict_name, method_name)
                  | None -> None

                end

            end
          | None -> None
         in
        match custom_dispatch with
        | Some ((dict_name, method_name)) -> emit_dict_dispatch_binop ctx dict_name method_name e1 e2
        | None -> 
          do
            match ty1 with
            | Types.TFloat -> emit_float_binop ctx op e1 e2
            | Types.TString -> emit_string_binop ctx op e1 e2
            | _ -> emit_int_binop ctx op e1 e2

          end

      end

  and emit_divmod_zero_check ctx divisor = emit_divmod_zero_check_ir ctx ctx.ir divisor
  and emit_divmod_zero_check_ir ctx ir divisor =
    add_extern ctx "mml_check_div_zero" "void" ("i64" :: []);
    Ir_emit.emit_call_void ir "mml_check_div_zero" (("i64", divisor) :: [])
  and emit_int_binop ctx op e1 e2 =
    let a = emit_expr ctx e1 in
    let b = emit_expr ctx e2 in
    match op with
    | Ast.Add -> 
      let sum = Ir_emit.emit_binop ctx.ir "add" "i64" a b in
      Ir_emit.emit_binop ctx.ir "sub" "i64" sum "1"
    | Ast.Sub -> 
      let diff = Ir_emit.emit_binop ctx.ir "sub" "i64" a b in
      Ir_emit.emit_binop ctx.ir "add" "i64" diff "1"
    | Ast.Mul -> 
      let ua = Ir_emit.emit_binop ctx.ir "ashr" "i64" a "1" in
      let ub = Ir_emit.emit_binop ctx.ir "ashr" "i64" b "1" in
      let prod = Ir_emit.emit_binop ctx.ir "mul" "i64" ua ub in
      let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" prod "1" in
      Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"
    | Ast.Div -> 
      let ua = Ir_emit.emit_binop ctx.ir "ashr" "i64" a "1" in
      let ub = Ir_emit.emit_binop ctx.ir "ashr" "i64" b "1" in
      emit_divmod_zero_check ctx ub;
      let quot = Ir_emit.emit_binop ctx.ir "sdiv" "i64" ua ub in
      let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" quot "1" in
      Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"
    | Ast.Mod -> 
      let ua = Ir_emit.emit_binop ctx.ir "ashr" "i64" a "1" in
      let ub = Ir_emit.emit_binop ctx.ir "ashr" "i64" b "1" in
      emit_divmod_zero_check ctx ub;
      let rem = Ir_emit.emit_binop ctx.ir "srem" "i64" ua ub in
      let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" rem "1" in
      Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"
    | (((Ast.Lt | Ast.Gt) | Ast.Le) | Ast.Ge) -> 
      let icmp_op =
        match op with
        | Ast.Lt -> "slt"
        | Ast.Gt -> "sgt"
        | Ast.Le -> "sle"
        | _ -> "sge"
       in
      let fcmp_op =
        match op with
        | Ast.Lt -> "olt"
        | Ast.Gt -> "ogt"
        | Ast.Le -> "ole"
        | _ -> "oge"
       in
      let cmp =
        match Types.repr e1.ty with
        | ((((Types.TInt | Types.TBool) | Types.TUnit) | Types.TByte) | Types.TRune) -> Ir_emit.emit_icmp ctx.ir icmp_op "i64" a b
        | Types.TFloat -> 
          let da = emit_unbox_float ctx a in
          let db = emit_unbox_float ctx b in
          Ir_emit.emit_fcmp ctx.ir fcmp_op da db
        | _ -> 
          add_extern ctx "mml_structural_compare" "i64" ("i64" :: "i64" :: []);
          let r = Ir_emit.emit_call ctx.ir "i64" "mml_structural_compare" (("i64", a) :: ("i64", b) :: []) in
          Ir_emit.emit_icmp ctx.ir icmp_op "i64" r (tag_int 0)
       in
      Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
    | Ast.Eq -> 
      do
        let ty1 = Types.repr e1.ty in
        let emit_eq_call name args =
          add_extern ctx name "i64" (List.map fst args);
          Ir_emit.emit_call ctx.ir "i64" name args in
        match ty1 with
        | ((((Types.TInt | Types.TBool) | Types.TUnit) | Types.TByte) | Types.TRune) -> 
          let cmp = Ir_emit.emit_icmp ctx.ir "eq" "i64" a b in
          Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
        | Types.TString -> emit_eq_call "mml_string_eq" (("i64", a) :: ("i64", b) :: [])
        | Types.TFloat -> 
          let da = emit_unbox_float ctx a in
          let db = emit_unbox_float ctx b in
          let cmp = Ir_emit.emit_fcmp ctx.ir "oeq" da db in
          Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
        | Types.TArray _ -> emit_eq_call "mml_array_eq" (("i64", a) :: ("i64", b) :: [])
        | Types.TList _ -> emit_eq_call "mml_list_eq" (("i64", a) :: ("i64", b) :: [])
        | Types.TTuple ts -> 
          let n = List.length ts in
          add_extern ctx "mml_tuple_eq" "i64" ("i64" :: "i64" :: "i64" :: []);
          Ir_emit.emit_call ctx.ir "i64" "mml_tuple_eq" (("i64", a) :: ("i64", b) :: ("i64", tag_int n) :: [])
        | Types.TRecord _ -> emit_eq_call "mml_record_eq" (("i64", a) :: ("i64", b) :: [])
        | _ -> emit_eq_call "mml_structural_eq" (("i64", a) :: ("i64", b) :: [])

      end
    | Ast.Neq -> 
      do
        let ty1 = Types.repr e1.ty in
        let emit_neq_via_eq name args =
          add_extern ctx name "i64" (List.map fst args);
          let eq = Ir_emit.emit_call ctx.ir "i64" name args in
          let cmp = Ir_emit.emit_icmp ctx.ir "eq" "i64" eq true_value in
          Ir_emit.emit_select ctx.ir cmp "i64" false_value true_value in
        match ty1 with
        | ((((Types.TInt | Types.TBool) | Types.TUnit) | Types.TByte) | Types.TRune) -> 
          let cmp = Ir_emit.emit_icmp ctx.ir "ne" "i64" a b in
          Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
        | Types.TString -> emit_neq_via_eq "mml_string_eq" (("i64", a) :: ("i64", b) :: [])
        | Types.TFloat -> 
          let da = emit_unbox_float ctx a in
          let db = emit_unbox_float ctx b in
          let cmp = Ir_emit.emit_fcmp ctx.ir "une" da db in
          Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
        | Types.TArray _ -> emit_neq_via_eq "mml_array_eq" (("i64", a) :: ("i64", b) :: [])
        | Types.TList _ -> emit_neq_via_eq "mml_list_eq" (("i64", a) :: ("i64", b) :: [])
        | Types.TTuple ts -> 
          let n = List.length ts in
          add_extern ctx "mml_tuple_eq" "i64" ("i64" :: "i64" :: "i64" :: []);
          let eq = Ir_emit.emit_call ctx.ir "i64" "mml_tuple_eq" (("i64", a) :: ("i64", b) :: ("i64", tag_int n) :: []) in
          let cmp = Ir_emit.emit_icmp ctx.ir "eq" "i64" eq true_value in
          Ir_emit.emit_select ctx.ir cmp "i64" false_value true_value
        | Types.TRecord _ -> emit_neq_via_eq "mml_record_eq" (("i64", a) :: ("i64", b) :: [])
        | _ -> emit_neq_via_eq "mml_structural_eq" (("i64", a) :: ("i64", b) :: [])

      end
    | Ast.Land -> 
      let ua = Ir_emit.emit_binop ctx.ir "ashr" "i64" a "1" in
      let ub = Ir_emit.emit_binop ctx.ir "ashr" "i64" b "1" in
      let result = Ir_emit.emit_binop ctx.ir "and" "i64" ua ub in
      let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" result "1" in
      Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"
    | Ast.Lor -> 
      let ua = Ir_emit.emit_binop ctx.ir "ashr" "i64" a "1" in
      let ub = Ir_emit.emit_binop ctx.ir "ashr" "i64" b "1" in
      let result = Ir_emit.emit_binop ctx.ir "or" "i64" ua ub in
      let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" result "1" in
      Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"
    | Ast.Lxor -> 
      let ua = Ir_emit.emit_binop ctx.ir "ashr" "i64" a "1" in
      let ub = Ir_emit.emit_binop ctx.ir "ashr" "i64" b "1" in
      let result = Ir_emit.emit_binop ctx.ir "xor" "i64" ua ub in
      let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" result "1" in
      Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"
    | Ast.Lsl -> 
      let ua = Ir_emit.emit_binop ctx.ir "ashr" "i64" a "1" in
      let ub = Ir_emit.emit_binop ctx.ir "ashr" "i64" b "1" in
      let result = Ir_emit.emit_binop ctx.ir "shl" "i64" ua ub in
      let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" result "1" in
      Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"
    | Ast.Lsr -> 
      let ua = Ir_emit.emit_binop ctx.ir "ashr" "i64" a "1" in
      let ub = Ir_emit.emit_binop ctx.ir "ashr" "i64" b "1" in
      let result = Ir_emit.emit_binop ctx.ir "lshr" "i64" ua ub in
      let shifted = Ir_emit.emit_binop ctx.ir "shl" "i64" result "1" in
      Ir_emit.emit_binop ctx.ir "or" "i64" shifted "1"
    | _ -> failwith ($"native codegen: int binop not yet implemented")

  and emit_float_binop ctx op e1 e2 =
    let a = emit_expr ctx e1 in
    let b = emit_expr ctx e2 in
    match op with
    | Ast.Add -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let result = Ir_emit.emit_float_binop ctx.ir "fadd" da db in
      emit_box_float ctx result
    | Ast.Sub -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let result = Ir_emit.emit_float_binop ctx.ir "fsub" da db in
      emit_box_float ctx result
    | Ast.Mul -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let result = Ir_emit.emit_float_binop ctx.ir "fmul" da db in
      emit_box_float ctx result
    | Ast.Div -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let result = Ir_emit.emit_float_binop ctx.ir "fdiv" da db in
      emit_box_float ctx result
    | Ast.Lt -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let cmp = Ir_emit.emit_fcmp ctx.ir "olt" da db in
      Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
    | Ast.Gt -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let cmp = Ir_emit.emit_fcmp ctx.ir "ogt" da db in
      Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
    | Ast.Le -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let cmp = Ir_emit.emit_fcmp ctx.ir "ole" da db in
      Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
    | Ast.Ge -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let cmp = Ir_emit.emit_fcmp ctx.ir "oge" da db in
      Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
    | Ast.Eq -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let cmp = Ir_emit.emit_fcmp ctx.ir "oeq" da db in
      Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
    | Ast.Neq -> 
      let da = emit_unbox_float ctx a in
      let db = emit_unbox_float ctx b in
      let cmp = Ir_emit.emit_fcmp ctx.ir "one" da db in
      Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
    | _ -> failwith "native codegen: unsupported float binop"

  and emit_string_binop ctx op e1 e2 =
    let a = emit_expr ctx e1 in
    let b = emit_expr ctx e2 in
    match op with
    | Ast.Eq -> 
      add_extern ctx "mml_string_eq" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_eq" (("i64", a) :: ("i64", b) :: [])
    | Ast.Neq -> 
      add_extern ctx "mml_string_eq" "i64" ("i64" :: "i64" :: []);
      let eq = Ir_emit.emit_call ctx.ir "i64" "mml_string_eq" (("i64", a) :: ("i64", b) :: []) in
      Ir_emit.emit_binop ctx.ir "xor" "i64" eq "2"
    | (((Ast.Lt | Ast.Gt) | Ast.Le) | Ast.Ge) -> 
      add_extern ctx "mml_string_compare" "i64" ("i64" :: "i64" :: []);
      let cmp_val = Ir_emit.emit_call ctx.ir "i64" "mml_string_compare" (("i64", a) :: ("i64", b) :: []) in
      let cmp_op =
        match op with
        | Ast.Lt -> "slt"
        | Ast.Gt -> "sgt"
        | Ast.Le -> "sle"
        | Ast.Ge -> "sge"
        | _ -> failwith "assert false"
       in
      let cmp = Ir_emit.emit_icmp ctx.ir cmp_op "i64" cmp_val unit_value in
      Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
    | _ -> failwith "native codegen: unsupported string binop"

  and emit_concat ctx e1 e2 =
    let a = emit_expr ctx e1 in
    let b = emit_expr ctx e2 in
    add_extern ctx "mml_string_concat" "i64" ("i64" :: "i64" :: []);
    Ir_emit.emit_call ctx.ir "i64" "mml_string_concat" (("i64", a) :: ("i64", b) :: [])
  and emit_short_circuit_and ctx e1 e2 =
    let a_val = emit_expr ctx e1 in
    let is_false = Ir_emit.emit_icmp ctx.ir "eq" "i64" a_val false_value in
    let and_rhs = fresh_label ctx "and_rhs" in
    let and_short = fresh_label ctx "and_short" in
    let and_done = fresh_label ctx "and_done" in
    Ir_emit.emit_condbr ctx.ir is_false and_short and_rhs;
    Ir_emit.emit_label ctx.ir and_rhs;
    ctx.current_label := and_rhs;
    let b_val = emit_expr ctx e2 in
    let rhs_end = ctx.current_label in
    Ir_emit.emit_br ctx.ir and_done;
    Ir_emit.emit_label ctx.ir and_short;
    Ir_emit.emit_br ctx.ir and_done;
    Ir_emit.emit_label ctx.ir and_done;
    ctx.current_label := and_done;
    Ir_emit.emit_phi ctx.ir "i64" ((false_value, and_short) :: (b_val, rhs_end) :: [])
  and emit_short_circuit_or ctx e1 e2 =
    let a_val = emit_expr ctx e1 in
    let is_false = Ir_emit.emit_icmp ctx.ir "eq" "i64" a_val false_value in
    let or_rhs = fresh_label ctx "or_rhs" in
    let or_short = fresh_label ctx "or_short" in
    let or_done = fresh_label ctx "or_done" in
    Ir_emit.emit_condbr ctx.ir is_false or_rhs or_short;
    Ir_emit.emit_label ctx.ir or_rhs;
    ctx.current_label := or_rhs;
    let b_val = emit_expr ctx e2 in
    let rhs_end = ctx.current_label in
    Ir_emit.emit_br ctx.ir or_done;
    Ir_emit.emit_label ctx.ir or_short;
    Ir_emit.emit_br ctx.ir or_done;
    Ir_emit.emit_label ctx.ir or_done;
    ctx.current_label := or_done;
    Ir_emit.emit_phi ctx.ir "i64" ((true_value, or_short) :: (b_val, rhs_end) :: [])
  and emit_if ctx cond then_e else_e =
    let cond_val = emit_expr ctx cond in
    let is_false = Ir_emit.emit_icmp ctx.ir "eq" "i64" cond_val false_value in
    let then_label = fresh_label ctx "then" in
    let else_label = fresh_label ctx "else" in
    let merge_label = fresh_label ctx "merge" in
    Ir_emit.emit_condbr ctx.ir is_false else_label then_label;
    Ir_emit.emit_label ctx.ir then_label;
    ctx.current_label := then_label;
    let then_val = emit_expr ctx then_e in
    let then_end = ctx.current_label in
    Ir_emit.emit_br ctx.ir merge_label;
    Ir_emit.emit_label ctx.ir else_label;
    ctx.current_label := else_label;
    let else_val = emit_expr ctx else_e in
    let else_end = ctx.current_label in
    Ir_emit.emit_br ctx.ir merge_label;
    Ir_emit.emit_label ctx.ir merge_label;
    ctx.current_label := merge_label;
    Ir_emit.emit_phi ctx.ir "i64" ((then_val, then_end) :: (else_val, else_end) :: [])
  and emit_while ctx cond body step =
    let cond_label = fresh_label ctx "while_cond" in
    let body_label = fresh_label ctx "while_body" in
    let exit_label = fresh_label ctx "while_exit" in
    let continue_label =
      match step with
      | Some step_te -> 
        let step_label = fresh_label ctx "while_step" in
        Ir_emit.emit_br ctx.ir cond_label;
        Ir_emit.emit_label ctx.ir step_label;
        ctx.current_label := step_label;
        (emit_expr ctx step_te; ());
        Ir_emit.emit_br ctx.ir cond_label;
        step_label
      | None -> 
        Ir_emit.emit_br ctx.ir cond_label;
        cond_label
     in
    Ir_emit.emit_label ctx.ir cond_label;
    ctx.current_label := cond_label;
    let cond_val = emit_expr ctx cond in
    let is_false = Ir_emit.emit_icmp ctx.ir "eq" "i64" cond_val false_value in
    Ir_emit.emit_condbr ctx.ir is_false exit_label body_label;
    Ir_emit.emit_label ctx.ir body_label;
    ctx.current_label := body_label;
    ctx.loop_stack := (continue_label, exit_label) :: ctx.loop_stack;
    (emit_expr ctx body; ());
    ctx.loop_stack := List.tl ctx.loop_stack;
    Ir_emit.emit_br ctx.ir continue_label;
    Ir_emit.emit_label ctx.ir exit_label;
    ctx.current_label := exit_label;
    unit_value
  and emit_tuple ctx exprs =
    let vals = List.map (emit_expr ctx) exprs in
    let n = List.length vals in
    let ptr = emit_alloc ctx (n * 8) (make_header n mml_hdr_tuple) in
    List.iteri (fn i v -> let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr i in
    Ir_emit.emit_store ctx.ir "i64" v elem_ptr) vals;
    Ir_emit.emit_ptrtoint ctx.ir ptr
  and emit_record ctx fields =
    let sorted = List.sort (fn (a, _) (b, _) -> String.compare a b) fields in
    let vals = List.map (fn (_, e) -> emit_expr ctx e) sorted in
    let n = List.length vals in
    let ptr = emit_alloc ctx (n * 8) (make_header n mml_hdr_record) in
    List.iteri (fn i v -> let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr i in
    Ir_emit.emit_store ctx.ir "i64" v elem_ptr) vals;
    Ir_emit.emit_ptrtoint ctx.ir ptr
  and emit_or_cache_builtin_dict ctx dict_name =
    match lookup_var ctx dict_name with
    | Some _ -> emit_var ctx dict_name Types.TUnit
    | None when ctx.current_dict_name = (Some dict_name) -> 
      let gname = ensure_global ctx dict_name in
      bind_var ctx dict_name (Global gname);
      Ir_emit.emit_load ctx.ir "i64" ($"@{gname}")
    | None -> 
      do
        let result =
          match List.find (fn inst -> inst.inst_dict_name = dict_name) ctx.type_env.instances with
          | Some inst when inst.inst_constraints = [] -> 
            do
              match List.find (fn (c : Types.class_def) -> c.class_name = inst.inst_class) ctx.type_env.classes with
              | Some class_def -> 
                let sorted_methods = List.sort (fn (a, _) (b, _) -> String.compare a b) class_def.class_methods in
                let n = List.length sorted_methods in
                if n = 0 do
                  None
                else if not (List.forall (fn (method_name, _) -> operator_closure_supported method_name) sorted_methods) do
                  None
                else do
                  let method_closures = List.map (fn (method_name, method_ty) -> let concrete_ty = subst_tgens_in_ty inst.inst_tys method_ty in
                  emit_operator_closure ctx method_name concrete_ty) sorted_methods in
                  let ptr = emit_alloc ctx (n * 8) (make_header n mml_hdr_record) in
                  List.iteri (fn i closure_val -> let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr i in
                  Ir_emit.emit_store ctx.ir "i64" closure_val elem_ptr) method_closures;
                  let dict_val = Ir_emit.emit_ptrtoint ctx.ir ptr in
                  let gname = ensure_global ctx dict_name in
                  Ir_emit.emit_store ctx.ir "i64" dict_val ($"@{gname}");
                  bind_var ctx dict_name (Global gname);
                  Some dict_val
                end
              | None -> None

            end
          | _ -> None
         in
        match result with
        | Some v -> v
        | None -> unit_value

      end

  and dict_method_index ctx field_name =
    match List.find (fn (c : Types.class_def) -> List.exists (fn (name, _) -> name = field_name) c.class_methods) ctx.type_env.classes with
    | Some class_def -> 
      let sorted = List.sort (fn (a, _) (b, _) -> String.compare a b) class_def.class_methods in
      let rec find i =
        fn
          | [] -> failwith ($"native codegen: method {field_name} not found in class")
          | (name, _) :: _ when name = field_name -> i
          | _ :: rest -> find (i + 1) rest
       in
      find 0 sorted
    | None -> failwith ($"native codegen: field {field_name} not found in any class or record type")

  and field_evidence_param ctx record_ty field_name =
    let rec has_open_row r =
      match Types.rrow_repr r with
      | Types.RRow ((_, _, tail)) -> has_open_row tail
      | Types.RVar {contents = Types.RUnbound _} -> true
      | _ -> false
     in
    match Types.repr record_ty with
    | Types.TRecord row when has_open_row row -> 
      let rec try_rgen i =
        if i > 10 do
          None
        else do
          let name = $"__ev_{field_name}_r{i}" in
          match lookup_var ctx name with
          | Some _ -> Some name
          | None -> try_rgen (i + 1)

        end in
      try_rgen 0
    | _ -> None

  and field_elem_ptr ctx ptr record_ty field_name =
    match field_evidence_param ctx record_ty field_name with
    | Some ev_name -> 
      let tagged_idx = emit_var ctx ev_name Types.TInt in
      let idx = Ir_emit.emit_binop ctx.ir "ashr" "i64" tagged_idx "1" in
      Ir_emit.emit_gep_dynamic ctx.ir "i64" ptr idx
    | None -> 
      let idx =
        match Types.repr record_ty with
        | Types.TRecord row -> 
          let fields = Types.record_row_to_fields row in
          let sorted = List.sort (fn (a, _) (b, _) -> String.compare a b) fields in
          let rec find i =
            fn
              | [] -> failwith ($"native codegen: field {field_name} not found in record type")
              | (name, _) :: _ when name = field_name -> i
              | _ :: rest -> find (i + 1) rest
           in
          find 0 sorted
        | _ -> dict_method_index ctx field_name
       in
      Ir_emit.emit_gep ctx.ir "i64" ptr idx

  and emit_field ctx (record_expr : Typechecker.texpr) field_name _expr_ty =
    let v = emit_expr ctx record_expr in
    let ptr = Ir_emit.emit_inttoptr ctx.ir v in
    let elem_ptr = field_elem_ptr ctx ptr record_expr.ty field_name in
    Ir_emit.emit_load ctx.ir "i64" elem_ptr
  and emit_record_update ctx base overrides =
    let base_val = emit_expr ctx base in
    let base_ptr = Ir_emit.emit_inttoptr ctx.ir base_val in
    let fields = record_fields_from_type base.ty in
    let n = List.length fields in
    let new_ptr = emit_alloc ctx (n * 8) (make_header n mml_hdr_record) in
    let mut i = 0 in
    for i <= n - 1 do
      let src = Ir_emit.emit_gep ctx.ir "i64" base_ptr i in
      let v = Ir_emit.emit_load ctx.ir "i64" src in
      let dst = Ir_emit.emit_gep ctx.ir "i64" new_ptr i in
      Ir_emit.emit_store ctx.ir "i64" v dst;
      i := i + 1
    end;
    List.iter (fn (name, expr) -> let v = emit_expr ctx expr in
    let idx = field_index_from_type base.ty name in
    let dst = Ir_emit.emit_gep ctx.ir "i64" new_ptr idx in
    Ir_emit.emit_store ctx.ir "i64" v dst) overrides;
    Ir_emit.emit_ptrtoint ctx.ir new_ptr
  and emit_record_update_idx ctx base pairs =
    let base_val = emit_expr ctx base in
    let base_ptr = Ir_emit.emit_inttoptr ctx.ir base_val in
    let hdr_ptr = Ir_emit.emit_gep ctx.ir "i64" base_ptr (-1) in
    let hdr = Ir_emit.emit_load ctx.ir "i64" hdr_ptr in
    let n = Ir_emit.emit_binop ctx.ir "lshr" "i64" hdr "16" in
    let alloc_bytes = Ir_emit.emit_binop ctx.ir "mul" "i64" n "8" in
    add_extern ctx "mml_alloc" "ptr" ("i64" :: "i64" :: []);
    let new_ptr = Ir_emit.emit_call ctx.ir "ptr" "mml_alloc" (("i64", alloc_bytes) :: ("i64", hdr) :: []) in
    let nbytes = alloc_bytes in
    add_extern ctx "memcpy" "ptr" ("ptr" :: "ptr" :: "i64" :: []);
    (Ir_emit.emit_call ctx.ir "ptr" "memcpy" (("ptr", new_ptr) :: ("ptr", base_ptr) :: ("i64", nbytes) :: []); ());
    List.iter (fn (idx_expr, val_expr) -> let idx_val = emit_expr ctx idx_expr in
    let val_v = emit_expr ctx val_expr in
    let idx_untagged = Ir_emit.emit_binop ctx.ir "ashr" "i64" idx_val "1" in
    let dst = Ir_emit.emit_gep_dynamic ctx.ir "i64" new_ptr idx_untagged in
    Ir_emit.emit_store ctx.ir "i64" val_v dst) pairs;
    Ir_emit.emit_ptrtoint ctx.ir new_ptr
  and emit_field_assign ctx record_expr field_name value_expr =
    let rec_val = emit_expr ctx record_expr in
    let v = emit_expr ctx value_expr in
    let ptr = Ir_emit.emit_inttoptr ctx.ir rec_val in
    let elem_ptr = field_elem_ptr ctx ptr record_expr.ty field_name in
    Ir_emit.emit_store ctx.ir "i64" v elem_ptr;
    unit_value
  and emit_construct ctx name arg tag =
    if is_newtype_ctor ctx name do
      do
        match arg with
        | Some e -> emit_expr ctx e
        | None -> tag_int 0

      end
    else do
      let tag_val = tag_int tag in
      match arg with
      | None -> tag_val
      | Some e -> 
        let payload = emit_expr ctx e in
        let hdr_tag =
          if ((String.length name) > 0) && ((String.get name 0) = #60) do
            mml_hdr_polyvar
          else
            mml_hdr_variant in
        let ptr = emit_alloc ctx 16 (make_header 0 hdr_tag) in
        let tag_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
        Ir_emit.emit_store ctx.ir "i64" tag_val tag_ptr;
        let payload_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
        Ir_emit.emit_store ctx.ir "i64" payload payload_ptr;
        Ir_emit.emit_ptrtoint ctx.ir ptr

    end
  and emit_match ctx scrutinee arms =
    let scrut_val = emit_expr ctx scrutinee in
    let scrut_ptr = Ir_emit.emit_alloca ctx.ir "i64" in
    Ir_emit.emit_store ctx.ir "i64" scrut_val scrut_ptr;
    let match_done = fresh_label ctx "match_done" in
    let match_fail = fresh_label ctx "match_fail" in
    let n = List.length arms in
    let arm_labels = List.init n (fn i -> fresh_label ctx ($"arm_{i}")) in
    let arm_fail_labels = List.init n (fn i -> if i < (n - 1) do
      List.nth arm_labels (i + 1)
    else
      match_fail) in
    let result_ptr = Ir_emit.emit_alloca ctx.ir "i64" in
    Ir_emit.emit_store ctx.ir "i64" unit_value result_ptr;
    Ir_emit.emit_br ctx.ir (List.hd arm_labels);
    let body_ends = Ref.create [] in
    List.iteri (fn i (pattern, guard, body) -> let arm_label = List.nth arm_labels i in
    let fail_label = List.nth arm_fail_labels i in
    Ir_emit.emit_label ctx.ir arm_label;
    ctx.current_label := arm_label;
    push_scope ctx;
    let scrut = Ir_emit.emit_load ctx.ir "i64" scrut_ptr in
    emit_pattern ctx scrut pattern fail_label scrutinee.ty;
    do
      match guard with
      | Some guard_expr -> 
        let guard_val = emit_expr ctx guard_expr in
        let is_false = Ir_emit.emit_icmp ctx.ir "eq" "i64" guard_val false_value in
        let guard_ok = fresh_label ctx "guard_ok" in
        Ir_emit.emit_condbr ctx.ir is_false fail_label guard_ok;
        Ir_emit.emit_label ctx.ir guard_ok;
        ctx.current_label := guard_ok
      | None -> ()

    end;
    let body_val = emit_expr ctx body in
    let body_end = ctx.current_label in
    Ir_emit.emit_store ctx.ir "i64" body_val result_ptr;
    Ir_emit.emit_br ctx.ir match_done;
    pop_scope ctx;
    Ref.set body_ends ((body_val, body_end) :: Ref.get body_ends)) arms;
    Ir_emit.emit_label ctx.ir match_fail;
    ctx.current_label := match_fail;
    emit_match_panic ctx scrutinee.loc;
    Ir_emit.emit_label ctx.ir match_done;
    ctx.current_label := match_done;
    Ir_emit.emit_load ctx.ir "i64" result_ptr
  and emit_match_panic ctx loc =
    let msg = $"non-exhaustive match at line {loc.line}" in
    let name = $".str.{ctx.str_counter}" in
    ctx.str_counter := ctx.str_counter + 1;
    let escaped = Buffer.contents (llvm_escape_string msg) in
    let len = (String.length msg) + 1 in
    let decl = $"@{name} = private unnamed_addr constant [{len} x i8] c\"{escaped}\\00\"" in
    ctx.string_globals := decl :: ctx.string_globals;
    let ptr = Ir_emit.emit_ptrtoint ctx.ir ($"@{name}") in
    add_extern ctx "mml_panic" "void" ("i64" :: []);
    Ir_emit.emit_call_void ctx.ir "mml_panic" (("i64", ptr) :: []);
    Ir_emit.emit_unreachable ctx.ir
  and emit_match_tree ctx (cm : Typechecker.texpr Match_tree_types.compiled_match) =
    let scrut_val = emit_expr ctx cm.scrutinee in
    let scrut_ptr = Ir_emit.emit_alloca ctx.ir "i64" in
    Ir_emit.emit_store ctx.ir "i64" scrut_val scrut_ptr;
    let match_done = fresh_label ctx "match_done" in
    let result_ptr = Ir_emit.emit_alloca ctx.ir "i64" in
    Ir_emit.emit_store ctx.ir "i64" unit_value result_ptr;
    emit_dtree ctx cm scrut_ptr result_ptr match_done cm.tree;
    Ir_emit.emit_label ctx.ir match_done;
    ctx.current_label := match_done;
    Ir_emit.emit_load ctx.ir "i64" result_ptr
  and emit_dtree ctx cm scrut_ptr result_ptr match_done tree =
    match tree with
    | Match_tree_types.DLeaf {arm_idx; bindings} -> 
      push_scope ctx;
      emit_tree_bindings ctx scrut_ptr bindings;
      let arm = Array.get cm.match_arms arm_idx in
      let body_val = emit_expr ctx arm.arm_body in
      Ir_emit.emit_store ctx.ir "i64" body_val result_ptr;
      Ir_emit.emit_br ctx.ir match_done;
      pop_scope ctx
    | Match_tree_types.DFail loc -> emit_match_panic ctx loc
    | Match_tree_types.DGuard {guard; bindings; on_true; on_false; _} -> 
      push_scope ctx;
      emit_tree_bindings ctx scrut_ptr bindings;
      let guard_val = emit_expr ctx guard in
      let is_false = Ir_emit.emit_icmp ctx.ir "eq" "i64" guard_val false_value in
      let guard_ok = fresh_label ctx "guard_ok" in
      let guard_fail = fresh_label ctx "guard_fail" in
      Ir_emit.emit_condbr ctx.ir is_false guard_fail guard_ok;
      Ir_emit.emit_label ctx.ir guard_ok;
      ctx.current_label := guard_ok;
      emit_dtree ctx cm scrut_ptr result_ptr match_done on_true;
      pop_scope ctx;
      Ir_emit.emit_label ctx.ir guard_fail;
      ctx.current_label := guard_fail;
      emit_dtree ctx cm scrut_ptr result_ptr match_done on_false
    | Match_tree_types.DSwitch {occ; cases; default; _} -> 
      let val_reg = emit_tree_occurrence ctx scrut_ptr occ in
      emit_dtree_switch ctx cm scrut_ptr result_ptr match_done val_reg cases default

  and emit_dtree_switch ctx cm scrut_ptr result_ptr match_done val_reg cases default =
    match cases with
    | [] -> 
      do
        match default with
        | Some def -> emit_dtree ctx cm scrut_ptr result_ptr match_done def
        | None -> emit_match_panic ctx cm.loc

      end
    | (test, _binds, sub_tree) :: rest_cases -> 
      let cond = emit_tree_test ctx val_reg test in
      let then_label = fresh_label ctx "case_then" in
      let else_label = fresh_label ctx "case_else" in
      Ir_emit.emit_condbr ctx.ir cond then_label else_label;
      Ir_emit.emit_label ctx.ir then_label;
      ctx.current_label := then_label;
      emit_dtree ctx cm scrut_ptr result_ptr match_done sub_tree;
      Ir_emit.emit_label ctx.ir else_label;
      ctx.current_label := else_label;
      emit_dtree_switch ctx cm scrut_ptr result_ptr match_done val_reg rest_cases default

  and emit_tree_occurrence ctx scrut_ptr (occ : Match_tree_types.occurrence) =
    let val_reg = Ir_emit.emit_load ctx.ir "i64" scrut_ptr in
    List.fold (fn v step ->
      do
        match step with
        | Match_tree_types.ATupleField i -> 
          let ptr = Ir_emit.emit_inttoptr ctx.ir v in
          let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr i in
          Ir_emit.emit_load ctx.ir "i64" elem_ptr
        | Match_tree_types.ARecordField ((_name, idx)) -> 
          let ptr = Ir_emit.emit_inttoptr ctx.ir v in
          let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr idx in
          Ir_emit.emit_load ctx.ir "i64" elem_ptr
        | Match_tree_types.AVariantPayload -> 
          let ptr = Ir_emit.emit_inttoptr ctx.ir v in
          let payload_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
          Ir_emit.emit_load ctx.ir "i64" payload_ptr
        | Match_tree_types.AConsHead -> 
          let ptr = Ir_emit.emit_inttoptr ctx.ir v in
          let hd_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
          Ir_emit.emit_load ctx.ir "i64" hd_ptr
        | Match_tree_types.AConsTail -> 
          let ptr = Ir_emit.emit_inttoptr ctx.ir v in
          let tl_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
          Ir_emit.emit_load ctx.ir "i64" tl_ptr
        | Match_tree_types.AArrayElem i -> 
          let ptr = Ir_emit.emit_inttoptr ctx.ir v in
          let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr (i + 1) in
          Ir_emit.emit_load ctx.ir "i64" elem_ptr
        | Match_tree_types.AMapValue mk -> 
          let map_get = emit_var ctx "Map.get" Types.TUnit in
          let key_val = emit_map_key_val ctx mk in
          let partial = emit_closure_apply ctx map_get (key_val :: []) in
          let result = emit_closure_apply ctx partial (v :: []) in
          let res_ptr = Ir_emit.emit_inttoptr ctx.ir result in
          let payload_ptr = Ir_emit.emit_gep ctx.ir "i64" res_ptr 1 in
          Ir_emit.emit_load ctx.ir "i64" payload_ptr

      end) val_reg occ
  and emit_map_key_val ctx mk =
    match mk with
    | Match_tree_types.MKInt n -> tag_int n
    | Match_tree_types.MKString s -> emit_expr ctx {expr = Typechecker.TEString s; ty = Types.TString; loc = Token.dummy_loc}
    | Match_tree_types.MKBool b -> 
      if b do
        true_value
      else
        false_value
    | Match_tree_types.MKFloat f -> emit_expr ctx {expr = Typechecker.TEFloat f; ty = Types.TFloat; loc = Token.dummy_loc}
    | Match_tree_types.MKPin name -> emit_var ctx name Types.TUnit

  and ctor_has_payload ctx name =
    let info =
      match List.assoc_opt name ctx.type_env.constructors with
      | Some _ as r -> r
      | None -> List.assoc_opt (short_ctor_name name) ctx.type_env.constructors
     in
    match info with
    | Some info -> info.ctor_arg_ty <> None
    | None -> true

  and emit_tree_test ctx val_reg (test : Match_tree_types.test) =
    match test with
    | Match_tree_types.TConstructor ((name, tag)) -> 
      if ctor_has_payload ctx name do
        let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
        let is_tagged = Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0" in
        let check_tag = fresh_label ctx "ctor_check_tag" in
        let ctor_false = fresh_label ctx "ctor_false" in
        let ctor_result = fresh_label ctx "ctor_result" in
        Ir_emit.emit_condbr ctx.ir is_tagged ctor_false check_tag;
        Ir_emit.emit_label ctx.ir check_tag;
        ctx.current_label := check_tag;
        let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
        let tag_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
        let actual_tag = Ir_emit.emit_load ctx.ir "i64" tag_ptr in
        let tag_eq = Ir_emit.emit_icmp ctx.ir "eq" "i64" actual_tag (tag_int tag) in
        Ir_emit.emit_br ctx.ir ctor_result;
        Ir_emit.emit_label ctx.ir ctor_false;
        ctx.current_label := ctor_false;
        Ir_emit.emit_br ctx.ir ctor_result;
        Ir_emit.emit_label ctx.ir ctor_result;
        ctx.current_label := ctor_result;
        Ir_emit.emit_phi ctx.ir "i1" ((tag_eq, check_tag) :: ("false", ctor_false) :: [])
      else
        Ir_emit.emit_icmp ctx.ir "eq" "i64" val_reg (tag_int tag)
    | Match_tree_types.TPolyVariant ((_, hash)) -> 
      let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
      let is_tagged = Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0" in
      let check_int = fresh_label ctx "pv_check_int" in
      let check_ptr = fresh_label ctx "pv_check_ptr" in
      let pv_result = fresh_label ctx "pv_result" in
      Ir_emit.emit_condbr ctx.ir is_tagged check_int check_ptr;
      Ir_emit.emit_label ctx.ir check_int;
      ctx.current_label := check_int;
      let int_eq = Ir_emit.emit_icmp ctx.ir "eq" "i64" val_reg (tag_int hash) in
      Ir_emit.emit_br ctx.ir pv_result;
      Ir_emit.emit_label ctx.ir check_ptr;
      ctx.current_label := check_ptr;
      let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
      let tag_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
      let actual_tag = Ir_emit.emit_load ctx.ir "i64" tag_ptr in
      let ptr_eq = Ir_emit.emit_icmp ctx.ir "eq" "i64" actual_tag (tag_int hash) in
      Ir_emit.emit_br ctx.ir pv_result;
      Ir_emit.emit_label ctx.ir pv_result;
      ctx.current_label := pv_result;
      Ir_emit.emit_phi ctx.ir "i1" ((int_eq, check_int) :: (ptr_eq, check_ptr) :: [])
    | Match_tree_types.TBoolLit b -> 
      let expected =
        if b do
          true_value
        else
          false_value in
      Ir_emit.emit_icmp ctx.ir "eq" "i64" val_reg expected
    | Match_tree_types.TIntLit n -> Ir_emit.emit_icmp ctx.ir "eq" "i64" val_reg (tag_int n)
    | Match_tree_types.TFloatLit f -> 
      let da = emit_unbox_float ctx val_reg in
      let fval = emit_expr ctx {expr = Typechecker.TEFloat f; ty = Types.TFloat; loc = Token.dummy_loc} in
      let db = emit_unbox_float ctx fval in
      Ir_emit.emit_fcmp ctx.ir "oeq" da db
    | Match_tree_types.TStringLit s -> 
      let sval = emit_expr ctx {expr = Typechecker.TEString s; ty = Types.TString; loc = Token.dummy_loc} in
      add_extern ctx "mml_string_eq" "i64" ("i64" :: "i64" :: []);
      let eq = Ir_emit.emit_call ctx.ir "i64" "mml_string_eq" (("i64", val_reg) :: ("i64", sval) :: []) in
      Ir_emit.emit_icmp ctx.ir "ne" "i64" eq false_value
    | Match_tree_types.TUnit -> Ir_emit.emit_icmp ctx.ir "eq" "i64" val_reg unit_value
    | Match_tree_types.TNil -> 
      let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
      Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0"
    | Match_tree_types.TCons -> 
      let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
      Ir_emit.emit_icmp ctx.ir "eq" "i64" low_bit "0"
    | Match_tree_types.TArrayLen n -> 
      add_extern ctx "mml_array_length" "i64" ("i64" :: []);
      let arr_len = Ir_emit.emit_call ctx.ir "i64" "mml_array_length" (("i64", val_reg) :: []) in
      Ir_emit.emit_icmp ctx.ir "eq" "i64" arr_len (tag_int n)
    | Match_tree_types.TMapHasKey mk -> 
      let map_has = emit_var ctx "Map.has" Types.TUnit in
      let key_val = emit_map_key_val ctx mk in
      let partial = emit_closure_apply ctx map_has (key_val :: []) in
      let result = emit_closure_apply ctx partial (val_reg :: []) in
      Ir_emit.emit_icmp ctx.ir "ne" "i64" result false_value
    | Match_tree_types.TPin name -> 
      let pinned_val = emit_var ctx name Types.TUnit in
      add_extern ctx "mml_structural_eq" "i64" ("i64" :: "i64" :: []);
      let eq = Ir_emit.emit_call ctx.ir "i64" "mml_structural_eq" (("i64", val_reg) :: ("i64", pinned_val) :: []) in
      Ir_emit.emit_icmp ctx.ir "ne" "i64" eq false_value

  and emit_tree_bindings ctx scrut_ptr (bindings : Match_tree_types.binding list) = List.iter (fn (b : Match_tree_types.binding) -> let val_reg = emit_tree_occurrence ctx scrut_ptr b.bind_occ in
  let ptr = Ir_emit.emit_alloca ctx.ir "i64" in
  Ir_emit.emit_store ctx.ir "i64" val_reg ptr;
  bind_var ctx b.var_name (Local ptr)) bindings
  and collect_pattern_names pat =
    match pat with
    | Ast.PatVar name -> name :: []
    | Ast.PatAs ((p, name)) -> name :: collect_pattern_names p
    | Ast.PatTuple ps -> List.concat_map collect_pattern_names ps
    | Ast.PatCons ((p1, p2)) -> List.concat (collect_pattern_names p1) (collect_pattern_names p2)
    | Ast.PatConstruct ((_, Some p)) -> collect_pattern_names p
    | Ast.PatPolyVariant ((_, Some p)) -> collect_pattern_names p
    | Ast.PatRecord fps -> List.concat_map (fn (_, p) -> collect_pattern_names p) fps
    | Ast.PatOr ((p1, _)) -> collect_pattern_names p1
    | Ast.PatAnnot ((p, _)) -> collect_pattern_names p
    | Ast.PatArray ps -> List.concat_map collect_pattern_names ps
    | Ast.PatMap entries -> List.concat_map (fn (_, vp) -> collect_pattern_names vp) entries
    | _ -> []

  and emit_pattern ctx val_reg pattern fail_label scrutinee_ty =
    match pattern with
    | Ast.PatWild -> ()
    | Ast.PatUnit -> ()
    | Ast.PatVar name -> 
      do
        match List.assoc_opt name ctx.or_pattern_allocas with
        | Some ptr -> Ir_emit.emit_store ctx.ir "i64" val_reg ptr
        | None -> 
          let ptr = Ir_emit.emit_alloca ctx.ir "i64" in
          Ir_emit.emit_store ctx.ir "i64" val_reg ptr;
          bind_var ctx name (Local ptr)

      end
    | Ast.PatInt n -> 
      let expected = tag_int n in
      let cmp = Ir_emit.emit_icmp ctx.ir "ne" "i64" val_reg expected in
      let cont = fresh_label ctx "pat_ok" in
      Ir_emit.emit_condbr ctx.ir cmp fail_label cont;
      Ir_emit.emit_label ctx.ir cont;
      ctx.current_label := cont
    | Ast.PatBool b -> 
      let expected =
        if b do
          true_value
        else
          false_value in
      let cmp = Ir_emit.emit_icmp ctx.ir "ne" "i64" val_reg expected in
      let cont = fresh_label ctx "pat_ok" in
      Ir_emit.emit_condbr ctx.ir cmp fail_label cont;
      Ir_emit.emit_label ctx.ir cont;
      ctx.current_label := cont
    | Ast.PatString s -> 
      let sval = emit_expr ctx {expr = TEString s; ty = Types.TString; loc = Token.dummy_loc} in
      add_extern ctx "mml_string_eq" "i64" ("i64" :: "i64" :: []);
      let eq = Ir_emit.emit_call ctx.ir "i64" "mml_string_eq" (("i64", val_reg) :: ("i64", sval) :: []) in
      let is_false = Ir_emit.emit_icmp ctx.ir "eq" "i64" eq false_value in
      let cont = fresh_label ctx "pat_ok" in
      Ir_emit.emit_condbr ctx.ir is_false fail_label cont;
      Ir_emit.emit_label ctx.ir cont;
      ctx.current_label := cont
    | Ast.PatTuple pats -> 
      let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
      List.iteri (fn i sub_pat -> let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr i in
      let elem = Ir_emit.emit_load ctx.ir "i64" elem_ptr in
      let elem_ty =
        match Types.repr scrutinee_ty with
        | Types.TTuple tys when i < (List.length tys) -> List.nth tys i
        | _ -> Types.TUnit
       in
      emit_pattern ctx elem sub_pat fail_label elem_ty) pats
    | Ast.PatConstruct ((name, sub_pat)) when is_newtype_ctor ctx name -> 
      do
        match sub_pat with
        | Some p -> 
          let payload_ty = ctor_payload_ty ctx name in
          emit_pattern ctx val_reg p fail_label payload_ty
        | None -> ()

      end
    | Ast.PatConstruct ((name, sub_pat)) -> 
      do
        let tag =
          if ((String.length name) > 0) && ((String.get name 0) = #60) do
            Types.polyvar_tag (String.sub name 1 ((String.length name) - 1))
          else
            tag_for_constructor ctx name in
        let expected_tag = tag_int tag in
        match sub_pat with
        | None -> 
          let cmp = Ir_emit.emit_icmp ctx.ir "ne" "i64" val_reg expected_tag in
          let cont = fresh_label ctx "pat_ctor_ok" in
          Ir_emit.emit_condbr ctx.ir cmp fail_label cont;
          Ir_emit.emit_label ctx.ir cont;
          ctx.current_label := cont
        | Some p -> 
          let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
          let is_tagged = Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0" in
          let check_tag = fresh_label ctx "pat_ctor_check" in
          Ir_emit.emit_condbr ctx.ir is_tagged fail_label check_tag;
          Ir_emit.emit_label ctx.ir check_tag;
          ctx.current_label := check_tag;
          let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
          let tag_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
          let actual_tag = Ir_emit.emit_load ctx.ir "i64" tag_ptr in
          let cmp = Ir_emit.emit_icmp ctx.ir "ne" "i64" actual_tag expected_tag in
          let cont = fresh_label ctx "pat_ctor_ok" in
          Ir_emit.emit_condbr ctx.ir cmp fail_label cont;
          Ir_emit.emit_label ctx.ir cont;
          ctx.current_label := cont;
          let payload_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
          let payload = Ir_emit.emit_load ctx.ir "i64" payload_ptr in
          let payload_ty = ctor_payload_ty ctx name in
          emit_pattern ctx payload p fail_label payload_ty

      end
    | Ast.PatRecord field_pats -> 
      let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
      List.iter (fn (fname, sub_pat) -> let idx = field_index_from_type scrutinee_ty fname in
      let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr idx in
      let elem = Ir_emit.emit_load ctx.ir "i64" elem_ptr in
      let field_ty = field_ty_from_type scrutinee_ty fname in
      emit_pattern ctx elem sub_pat fail_label field_ty) field_pats
    | Ast.PatAs ((pat, name)) -> 
      let ptr = Ir_emit.emit_alloca ctx.ir "i64" in
      Ir_emit.emit_store ctx.ir "i64" val_reg ptr;
      bind_var ctx name (Local ptr);
      emit_pattern ctx val_reg pat fail_label scrutinee_ty
    | Ast.PatOr ((p1, p2)) -> 
      let try_p2 = fresh_label ctx "pat_or_p2" in
      let bound_names = collect_pattern_names p1 in
      let shared = List.map (fn name -> let ptr = Ir_emit.emit_alloca ctx.ir "i64" in
      (name, ptr)) bound_names in
      let saved_or_allocas = ctx.or_pattern_allocas in
      ctx.or_pattern_allocas := List.concat shared ctx.or_pattern_allocas;
      emit_pattern ctx val_reg p1 try_p2 scrutinee_ty;
      let p1_ok = fresh_label ctx "pat_or_ok" in
      Ir_emit.emit_br ctx.ir p1_ok;
      Ir_emit.emit_label ctx.ir try_p2;
      ctx.current_label := try_p2;
      emit_pattern ctx val_reg p2 fail_label scrutinee_ty;
      ctx.or_pattern_allocas := saved_or_allocas;
      Ir_emit.emit_br ctx.ir p1_ok;
      Ir_emit.emit_label ctx.ir p1_ok;
      ctx.current_label := p1_ok;
      List.iter (fn (name, ptr) -> bind_var ctx name (Local ptr)) shared
    | Ast.PatAnnot ((pat, _)) -> emit_pattern ctx val_reg pat fail_label scrutinee_ty
    | Ast.PatFloat f -> 
      let fval = emit_expr ctx {expr = TEFloat f; ty = Types.TFloat; loc = Token.dummy_loc} in
      let da = emit_unbox_float ctx val_reg in
      let db = emit_unbox_float ctx fval in
      let cmp = Ir_emit.emit_fcmp ctx.ir "one" da db in
      let cont = fresh_label ctx "pat_ok" in
      Ir_emit.emit_condbr ctx.ir cmp fail_label cont;
      Ir_emit.emit_label ctx.ir cont;
      ctx.current_label := cont
    | Ast.PatNil -> 
      let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
      let is_pointer = Ir_emit.emit_icmp ctx.ir "eq" "i64" low_bit "0" in
      let cont = fresh_label ctx "pat_nil_ok" in
      Ir_emit.emit_condbr ctx.ir is_pointer fail_label cont;
      Ir_emit.emit_label ctx.ir cont;
      ctx.current_label := cont
    | Ast.PatCons ((hd_pat, tl_pat)) -> 
      let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
      let is_nil = Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0" in
      let cont = fresh_label ctx "pat_cons_ok" in
      Ir_emit.emit_condbr ctx.ir is_nil fail_label cont;
      Ir_emit.emit_label ctx.ir cont;
      ctx.current_label := cont;
      let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
      let hd_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
      let hd_val = Ir_emit.emit_load ctx.ir "i64" hd_ptr in
      let tl_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
      let tl_val = Ir_emit.emit_load ctx.ir "i64" tl_ptr in
      let elem_ty =
        match Types.repr scrutinee_ty with
        | Types.TList t -> t
        | _ -> Types.TUnit
       in
      emit_pattern ctx hd_val hd_pat fail_label elem_ty;
      emit_pattern ctx tl_val tl_pat fail_label scrutinee_ty
    | Ast.PatArray pats -> 
      let n = List.length pats in
      if n = 0 do
        let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
        let is_pointer = Ir_emit.emit_icmp ctx.ir "eq" "i64" low_bit "0" in
        let cont = fresh_label ctx "pat_arr_empty_ok" in
        Ir_emit.emit_condbr ctx.ir is_pointer fail_label cont;
        Ir_emit.emit_label ctx.ir cont;
        ctx.current_label := cont
      else do
        let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
        let is_int = Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0" in
        let cont1 = fresh_label ctx "pat_arr_ptr" in
        Ir_emit.emit_condbr ctx.ir is_int fail_label cont1;
        Ir_emit.emit_label ctx.ir cont1;
        ctx.current_label := cont1;
        let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
        let len_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
        let arr_len = Ir_emit.emit_load ctx.ir "i64" len_ptr in
        let cmp = Ir_emit.emit_icmp ctx.ir "ne" "i64" arr_len (string_of_int n) in
        let cont2 = fresh_label ctx "pat_arr_len_ok" in
        Ir_emit.emit_condbr ctx.ir cmp fail_label cont2;
        Ir_emit.emit_label ctx.ir cont2;
        ctx.current_label := cont2;
        let elem_ty =
          match Types.repr scrutinee_ty with
          | Types.TArray t -> t
          | _ -> Types.TUnit
         in
        List.iteri (fn i sub_pat -> let elem_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr (i + 1) in
        let elem = Ir_emit.emit_load ctx.ir "i64" elem_ptr in
        emit_pattern ctx elem sub_pat fail_label elem_ty) pats
      end
    | Ast.PatMap entries -> List.iter (fn (key_pat, val_pat) -> let key_val =
      match key_pat with
      | Ast.PatInt n -> tag_int n
      | Ast.PatString s -> emit_expr ctx {expr = TEString s; ty = Types.TString; loc = Token.dummy_loc}
      | Ast.PatBool b -> 
        if b do
          true_value
        else
          false_value
      | Ast.PatPin name -> 
        do
          match lookup_var ctx name with
          | (Some (Local ptr) | Some (MutLocal ptr)) -> Ir_emit.emit_load ctx.ir "i64" ptr
          | (Some (Global gname) | Some (MutGlobal gname)) -> Ir_emit.emit_load ctx.ir "i64" ($"@{gname}")
          | Some (MutRefCell ptr) -> 
            let cell = Ir_emit.emit_load ctx.ir "i64" ptr in
            let cell_ptr = Ir_emit.emit_inttoptr ctx.ir cell in
            Ir_emit.emit_load ctx.ir "i64" cell_ptr
          | (Some (Func _) | Some (FuncLocal _)) -> failwith "native codegen: cannot pin a function in map key"
          | None -> failwith ($"native codegen: unbound pin variable in map key: {name}")

        end
      | _ -> failwith "native codegen: map pattern keys must be literals or pin patterns"
     in
    add_extern ctx "mml_assoc_has" "i64" ("i64" :: "i64" :: []);
    let has = Ir_emit.emit_call ctx.ir "i64" "mml_assoc_has" (("i64", key_val) :: ("i64", val_reg) :: []) in
    let is_false = Ir_emit.emit_icmp ctx.ir "eq" "i64" has false_value in
    let cont = fresh_label ctx "pat_map_has" in
    Ir_emit.emit_condbr ctx.ir is_false fail_label cont;
    Ir_emit.emit_label ctx.ir cont;
    ctx.current_label := cont;
    add_extern ctx "mml_assoc_get" "i64" ("i64" :: "i64" :: []);
    let extracted = Ir_emit.emit_call ctx.ir "i64" "mml_assoc_get" (("i64", key_val) :: ("i64", val_reg) :: []) in
    let val_ty =
      match Types.repr scrutinee_ty with
      | Types.TList (Types.TTuple (_ :: vt :: [])) -> vt
      | _ -> Types.TUnit
     in
    emit_pattern ctx extracted val_pat fail_label val_ty) entries
    | Ast.PatPolyVariant ((name, sub_pat)) -> 
      do
        let tag = Types.polyvar_tag name in
        let expected_tag = tag_int tag in
        match sub_pat with
        | None -> 
          let cmp = Ir_emit.emit_icmp ctx.ir "ne" "i64" val_reg expected_tag in
          let cont = fresh_label ctx "pat_pv_ok" in
          Ir_emit.emit_condbr ctx.ir cmp fail_label cont;
          Ir_emit.emit_label ctx.ir cont;
          ctx.current_label := cont
        | Some p -> 
          let low_bit = Ir_emit.emit_binop ctx.ir "and" "i64" val_reg "1" in
          let is_tagged = Ir_emit.emit_icmp ctx.ir "ne" "i64" low_bit "0" in
          let check_tag = fresh_label ctx "pat_pv_check" in
          Ir_emit.emit_condbr ctx.ir is_tagged fail_label check_tag;
          Ir_emit.emit_label ctx.ir check_tag;
          ctx.current_label := check_tag;
          let ptr = Ir_emit.emit_inttoptr ctx.ir val_reg in
          let tag_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
          let actual_tag = Ir_emit.emit_load ctx.ir "i64" tag_ptr in
          let cmp = Ir_emit.emit_icmp ctx.ir "ne" "i64" actual_tag expected_tag in
          let cont = fresh_label ctx "pat_pv_ok" in
          Ir_emit.emit_condbr ctx.ir cmp fail_label cont;
          Ir_emit.emit_label ctx.ir cont;
          ctx.current_label := cont;
          let payload_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
          let payload = Ir_emit.emit_load ctx.ir "i64" payload_ptr in
          emit_pattern ctx payload p fail_label Types.TUnit

      end
    | Ast.PatPin name -> 
      let var_val =
        match lookup_var ctx name with
        | (Some (Local ptr) | Some (MutLocal ptr)) -> Ir_emit.emit_load ctx.ir "i64" ptr
        | (Some (Global gname) | Some (MutGlobal gname)) -> Ir_emit.emit_load ctx.ir "i64" ($"@{gname}")
        | Some (MutRefCell ptr) -> 
          let cell = Ir_emit.emit_load ctx.ir "i64" ptr in
          let cell_ptr = Ir_emit.emit_inttoptr ctx.ir cell in
          Ir_emit.emit_load ctx.ir "i64" cell_ptr
        | (Some (Func _) | Some (FuncLocal _)) -> failwith "native codegen: cannot pin a function"
        | None -> failwith ($"native codegen: unbound pin variable: {name}")
       in
      add_extern ctx "mml_structural_eq" "i64" ("i64" :: "i64" :: []);
      let eq = Ir_emit.emit_call ctx.ir "i64" "mml_structural_eq" (("i64", val_reg) :: ("i64", var_val) :: []) in
      let is_false = Ir_emit.emit_icmp ctx.ir "eq" "i64" eq false_value in
      let cont = fresh_label ctx "pat_pin_ok" in
      Ir_emit.emit_condbr ctx.ir is_false fail_label cont;
      Ir_emit.emit_label ctx.ir cont;
      ctx.current_label := cont
    | Ast.PatSet _ -> failwith "PatSet should be desugared before native codegen"

  and ctor_payload_ty ctx name =
    let short = short_ctor_name name in
    match lookup_ctor ctx name with
    | Some ((type_name, _tag)) -> 
      do
        match List.assoc_opt type_name ctx.variant_defs with
        | Some vdef -> 
          do
            match List.assoc_opt short vdef with
            | Some (Some ty) -> ty
            | _ -> Types.TUnit

          end
        | None -> Types.TUnit

      end
    | None -> Types.TUnit

  and field_ty_from_type ty fname =
    match Types.repr ty with
    | Types.TRecord row -> 
      do
        let fields = Types.record_row_to_fields row in
        match List.assoc_opt fname fields with
        | Some t -> t
        | None -> Types.TUnit

      end
    | _ -> Types.TUnit

  -- A boxed float value IS a pointer to its double (header at [-1]); unbox is a
  -- plain load and box is alloc+store. Inlined here (rather than calling the
  -- runtime mml_unbox_float/mml_box_float) so every float op is a load/alloc, not a
  -- call — and so -O2 can fold a box immediately consumed by an unbox.
  and emit_unbox_float ctx v =
    Ir_emit.emit_load ctx.ir "double" (Ir_emit.emit_inttoptr ctx.ir v)
  and emit_box_float ctx d =
    let p = emit_alloc ctx 8 (make_header 0 mml_hdr_float) in
    Ir_emit.emit_store ctx.ir "double" d p;
    Ir_emit.emit_ptrtoint ctx.ir p

  -- ---- Typed-FFI marshalling (cty <-> the MiniML i64 ABI) ----
  -- The LLVM type for a C type: integer widths are signless in LLVM; CStr/CPtr are
  -- pointers; CBool is i1; CVoid is void (only valid as a return type).
  and cty_llvm (c : Ast.cty) : string =
    match c with
    | Ast.CI8 -> "i8" | Ast.CU8 -> "i8"
    | Ast.CI16 -> "i16" | Ast.CU16 -> "i16"
    | Ast.CI32 -> "i32" | Ast.CU32 -> "i32"
    | Ast.CI64 -> "i64" | Ast.CU64 -> "i64"
    | Ast.CF32 -> "float" | Ast.CF64 -> "double"
    | Ast.CStr -> "ptr" | Ast.CPtr -> "ptr"
    | Ast.CBool -> "i1" | Ast.CVoid -> "void"
    | Ast.CNamed _ -> "ptr"
    | Ast.CStruct _ -> "ptr"   -- a C struct is passed by pointer
    | Ast.COut _ -> "ptr"      -- an OUT param is a pointer to a C scalar
    | Ast.CArray _ -> "ptr"    -- an array is passed as a pointer to its buffer
    | Ast.CNullable _ -> "ptr" -- a nullable pointer (None = NULL, Some x = &x)
  -- elem_kind for mml_ffi_array_to_c: 0=i8 1=i16 2=i32 3=i64 4=f32 5=f64 6=ptr 7=cstr
  and cty_kind (c : Ast.cty) : int =
    match c with
    | Ast.CI8 -> 0 | Ast.CU8 -> 0 | Ast.CBool -> 0
    | Ast.CI16 -> 1 | Ast.CU16 -> 1
    | Ast.CI32 -> 2 | Ast.CU32 -> 2
    | Ast.CI64 -> 3 | Ast.CU64 -> 3
    | Ast.CF32 -> 4 | Ast.CF64 -> 5
    | Ast.CPtr -> 6 | Ast.CNamed _ -> 6
    | Ast.CStr -> 7
    | _ -> failwith "FFI array element must be a scalar C type (no struct/array/out elements)"
  and cty_is_int (c : Ast.cty) : bool =
    match c with
    | Ast.CI8 -> true | Ast.CI16 -> true | Ast.CI32 -> true | Ast.CI64 -> true
    | Ast.CU8 -> true | Ast.CU16 -> true | Ast.CU32 -> true | Ast.CU64 -> true
    | _ -> false
  and cty_is_unsigned (c : Ast.cty) : bool =
    match c with
    | Ast.CU8 -> true | Ast.CU16 -> true | Ast.CU32 -> true | Ast.CU64 -> true | _ -> false
  -- C size and alignment (bytes) of a cty, for struct layout. A nested struct is
  -- laid out INLINE (its computed size, aligned to its widest field); pointer-like
  -- ctys (ptr/handle/cstr/i64/f64) are pointer-sized.
  and cty_size_align (c : Ast.cty) =
    match c with
    | Ast.CI8 -> (1, 1) | Ast.CU8 -> (1, 1) | Ast.CBool -> (1, 1)
    | Ast.CI16 -> (2, 2) | Ast.CU16 -> (2, 2)
    | Ast.CI32 -> (4, 4) | Ast.CU32 -> (4, 4) | Ast.CF32 -> (4, 4)
    | Ast.CStruct ((_, fields)) -> let (_, total) = struct_layout fields in (total, struct_align fields)
    | _ -> (8, 8)
  and struct_align fields =
    List.fold (fn acc pr -> let (_, fc) = pr in let (_, al) = cty_size_align fc in if al > acc do al else acc) 1 fields
  and align_up x a = (((x + a) - 1) / a) * a
  -- index of `nm` in the sorted field-name list (a record's runtime field order)
  and field_pos names nm =
    let rec go i lst = (match lst with [] -> 0 | x :: xs -> if x = nm do i else go (i + 1) xs) in
    go 0 names
  -- C struct layout: place each field (declaration order) at an aligned offset.
  -- Returns ([(fname, fcty, c_offset)], total_size_padded_to_max_alignment).
  and struct_layout fields =
    let off = Ref.create 0 in
    let maxal = Ref.create 1 in
    let placed = List.map (fn pr ->
      let (fname, fcty) = pr in
      let (sz, al) = cty_size_align fcty in
      let o = align_up (Ref.get off) al in
      Ref.set off (o + sz);
      (if al > (Ref.get maxal) do Ref.set maxal al end);
      (fname, fcty, o)
    ) fields in
    (placed, align_up (Ref.get off) (Ref.get maxal))
  -- Flatten a struct (recursively through nested-struct fields) to its leaf scalars
  -- as (record-slot path, absolute C offset, elem-kind). The path is the sequence
  -- of record slots to reach the leaf from the struct's own record (one slot per
  -- nesting level). Used to build the descriptor for array-of-struct marshalling.
  and struct_leaves fields =
    let (placed, _total) = struct_layout fields in
    let sorted = List.sort String.compare (List.map (fn pr -> let (n, _) = pr in n) fields) in
    List.concat_map (fn t ->
      let (fname, fcty, o) = t in
      let slot = field_pos sorted fname in
      match fcty with
      | Ast.CStruct ((_, nested)) ->
        List.map (fn lf -> let (path, off, k) = lf in (slot :: path, o + off, k)) (struct_leaves nested)
      | _ -> (slot :: [], o, cty_kind fcty) :: []
    ) placed
  -- Marshal one MiniML i64 value into a C argument. Some (llvm_ty, value), or None
  -- to DROP it (a CVoid parameter passes no C argument — e.g. `unit -> …`).
  and marshal_ffi_arg ctx (c : Ast.cty) (v : string) =
    if cty_is_int c do
      let untagged = Ir_emit.emit_binop ctx.ir "ashr" "i64" v "1" in
      let lty = cty_llvm c in
      Some (lty, if lty = "i64" do untagged else Ir_emit.emit_trunc ctx.ir "i64" untagged lty)
    else do
      match c with
      | Ast.CVoid -> None
      | Ast.CBool ->
        let untagged = Ir_emit.emit_binop ctx.ir "ashr" "i64" v "1" in
        Some ("i1", Ir_emit.emit_trunc ctx.ir "i64" untagged "i1")
      | Ast.CF64 -> Some ("double", emit_unbox_float ctx v)
      | Ast.CF32 -> Some ("float", Ir_emit.emit_fptrunc ctx.ir (emit_unbox_float ctx v))
      -- string value points AT the 8-byte length header; the C char* is v + 8
      | Ast.CStr -> Some ("ptr", Ir_emit.emit_inttoptr ctx.ir (Ir_emit.emit_binop ctx.ir "add" "i64" v "8"))
      | Ast.CPtr -> Some ("ptr", Ir_emit.emit_inttoptr ctx.ir v)
      -- opaque foreign handle: a raw C pointer carried as i64
      | Ast.CNamed _ -> Some ("ptr", Ir_emit.emit_inttoptr ctx.ir v)
      -- A C struct, passed by pointer: build it in a fixed-size stack buffer (which
      -- -O2 hoists to the function entry, so it's allocated once even inside a loop)
      -- then pass the pointer.
      | Ast.CStruct ((_, fields)) ->
        let (_placed, total) = struct_layout fields in
        let buf = Ir_emit.emit_alloca_array ctx.ir "i8" total in
        emit_struct_into ctx v buf 0 fields;
        Some ("ptr", buf)
      -- A nullable pointer: the MiniML value is an `option`. A runtime helper does
      -- the None/Some dispatch (None = tagged immediate -> NULL; Some = heap cell,
      -- payload at slot 1 -> the marshalled inner pointer) and returns the C pointer.
      | Ast.CNullable inner ->
        let helper =
          match inner with
          | Ast.CStr -> "mml_ffi_opt_cstr"
          | Ast.CPtr -> "mml_ffi_opt_ptr"
          | Ast.CNamed _ -> "mml_ffi_opt_ptr"
          | _ -> failwith "`nullable` applies only to a pointer-like C type (cstr / ptr / a declared `extern type` handle)" in
        add_extern ctx helper "ptr" ("i64" :: []);
        Some ("ptr", Ir_emit.emit_call ctx.ir "ptr" helper (("i64", v) :: []))
      | _ -> None
    end
  -- Marshal a MiniML record value into a C struct laid out in `buf` at byte
  -- `base`: read each field from its sorted record slot and write it at the field's
  -- C offset. A nested-struct field is written INLINE (recurse), not as a pointer.
  and emit_struct_into ctx rec_val buf base fields =
    let rp = Ir_emit.emit_inttoptr ctx.ir rec_val in
    let sorted_names = List.sort String.compare (List.map (fn pr -> let (n, _) = pr in n) fields) in
    let (placed, _total) = struct_layout fields in
    List.iter (fn t ->
      let (fname, fcty, o) = t in
      let fv = Ir_emit.emit_load ctx.ir "i64" (Ir_emit.emit_gep ctx.ir "i64" rp (field_pos sorted_names fname)) in
      match fcty with
      | Ast.CStruct ((_, nested)) -> emit_struct_into ctx fv buf (base + o) nested
      | _ ->
        let (clty, cv) = (match marshal_ffi_arg ctx fcty fv with Some pr -> pr | None -> ("i64", "0")) in
        Ir_emit.emit_store ctx.ir clty cv (Ir_emit.emit_gep ctx.ir "i8" buf (base + o))
    ) placed
  -- Marshal a C return value back into a MiniML i64.
  and marshal_ffi_ret ctx (c : Ast.cty) (raw : string) : string =
    if cty_is_int c do
      let lty = cty_llvm c in
      let widened = if lty = "i64" do raw
        else if cty_is_unsigned c do Ir_emit.emit_zext ctx.ir lty raw "i64"
        else Ir_emit.emit_sext ctx.ir lty raw "i64" in
      Ir_emit.emit_binop ctx.ir "or" "i64" (Ir_emit.emit_binop ctx.ir "shl" "i64" widened "1") "1"
    else do
      match c with
      | Ast.CVoid -> "1"
      | Ast.CBool ->
        Ir_emit.emit_binop ctx.ir "or" "i64" (Ir_emit.emit_binop ctx.ir "shl" "i64" (Ir_emit.emit_zext ctx.ir "i1" raw "i64") "1") "1"
      | Ast.CF64 -> emit_box_float ctx raw
      | Ast.CF32 -> emit_box_float ctx (Ir_emit.emit_fpext ctx.ir raw)
      | Ast.CStr ->
        add_extern ctx "mml_string_from_cstr" "i64" ("ptr" :: []);
        Ir_emit.emit_call ctx.ir "i64" "mml_string_from_cstr" (("ptr", raw) :: [])
      | Ast.CPtr -> Ir_emit.emit_ptrtoint ctx.ir raw
      | Ast.CNamed _ -> Ir_emit.emit_ptrtoint ctx.ir raw
      | Ast.CStruct _ -> failwith "returning a C struct by value is not supported"
      | Ast.CNullable _ -> failwith "`nullable` is only supported in parameter position (a nullable RETURN is not yet supported — use a plain `ptr` and test it against 0)"
      | _ -> "1"
    end
  -- Read a C struct the callee filled (in `buf` at byte `base`) into a fresh MiniML
  -- record: load each field at its C offset, marshal it to a MiniML value, store it
  -- at the field's sorted record slot. A nested-struct field becomes a nested
  -- record (recurse). Returns the record value (an i64).
  and emit_struct_readback ctx buf fields = emit_struct_readback_at ctx buf 0 fields
  and emit_struct_readback_at ctx buf base fields =
    let (placed, _total) = struct_layout fields in
    let sorted_names = List.sort String.compare (List.map (fn pr -> let (n, _) = pr in n) fields) in
    let n = List.length fields in
    let rec_ptr = emit_alloc ctx (n * 8) (make_header n mml_hdr_record) in
    List.iter (fn t ->
      let (fname, fcty, o) = t in
      let mml = (match fcty with
        | Ast.CStruct ((_, nested)) -> emit_struct_readback_at ctx buf (base + o) nested
        | _ -> marshal_ffi_ret ctx fcty (Ir_emit.emit_load ctx.ir (cty_llvm fcty) (Ir_emit.emit_gep ctx.ir "i8" buf (base + o)))) in
      Ir_emit.emit_store ctx.ir "i64" mml (Ir_emit.emit_gep ctx.ir "i64" rec_ptr (field_pos sorted_names fname))
    ) placed;
    Ir_emit.emit_ptrtoint ctx.ir rec_ptr
  -- A saturated typed-FFI call: marshal each MiniML arg to its C type, declare the
  -- C symbol with the marshalled signature, call it, and marshal the result back.
  and emit_ffi_call ctx c_symbol c_params c_ret arg_vals =
    let pairs = List.map2 (fn c v -> (c, v)) c_params arg_vals in
    -- OUT params (`out <cty>`): the MiniML arg is a Ref; allocate the C scalar,
    -- pass its pointer, and remember (ref_value, cell_ptr, inner_cty) so the value
    -- the callee wrote can be boxed back into the Ref AFTER the call.
    let writebacks = Ref.create [] in
    -- C buffers (from array marshalling) to free AFTER the call
    let frees = Ref.create [] in
    -- array args marshal into a reusable scratch arena; save its offset before
    -- marshalling and restore it after the call (instead of malloc/free per call)
    let arena_saved = (if List.exists (fn c -> match c with Ast.CArray _ -> true | _ -> false) c_params do
        add_extern ctx "mml_ffi_arena_save" "i64" [];
        Some (Ir_emit.emit_call ctx.ir "i64" "mml_ffi_arena_save" [])
      else None) in
    let cargs = List.filter_map (fn pair ->
      let (c, v) = pair in
      match c with
      | Ast.COut inner ->
        -- a scalar OUT cell, or (for `out <struct>`) a struct buffer the callee fills
        let cell = (match inner with
          | Ast.CStruct ((_, fields)) -> let (_, total) = struct_layout fields in Ir_emit.emit_alloca_array ctx.ir "i8" total
          | _ -> Ir_emit.emit_alloca ctx.ir (cty_llvm inner)) in
        Ref.set writebacks ((v, cell, inner) :: Ref.get writebacks);
        Some ("ptr", cell)
      | Ast.CArray elem ->
        -- marshal the MiniML array into a malloc'd C buffer (freed after the call)
        -- array of structs: build a compile-time layout descriptor
        -- [nfields, struct_size, (record_slot, c_offset, kind) * nfields] in a
        -- (fixed-size, hoisted) stack alloca, then call the struct-array helper.
        -- struct-array descriptor: [n_leaves, struct_size] then per leaf
        -- [path_len, slot…, c_offset, kind] — slot-path handles nested-struct fields.
        let buf = (match elem with
          | Ast.CStruct ((_, fields)) ->
            let (_placed, total) = struct_layout fields in
            let leaves = struct_leaves fields in
            let desc_len = List.fold (fn acc lf -> let (path, _, _) = lf in (acc + (List.length path)) + 3) 2 leaves in
            let desc = Ir_emit.emit_alloca_array ctx.ir "i64" desc_len in
            let idx = Ref.create 0 in
            let put n = (Ir_emit.emit_store ctx.ir "i64" (string_of_int n) (Ir_emit.emit_gep ctx.ir "i64" desc (Ref.get idx)); Ref.set idx ((Ref.get idx) + 1)) in
            put (List.length leaves); put total;
            List.iter (fn lf ->
              let (path, off, k) = lf in
              put (List.length path);
              List.iter (fn s -> put s) path;
              put off; put k
            ) leaves;
            add_extern ctx "mml_ffi_struct_array_to_c" "ptr" ("i64" :: ("ptr" :: []));
            Ir_emit.emit_call ctx.ir "ptr" "mml_ffi_struct_array_to_c" (("i64", v) :: (("ptr", desc) :: []))
          | _ ->
            add_extern ctx "mml_ffi_array_to_c" "ptr" ("i64" :: ("i64" :: []));
            Ir_emit.emit_call ctx.ir "ptr" "mml_ffi_array_to_c" (("i64", v) :: (("i64", string_of_int (cty_kind elem)) :: []))) in
        Ref.set frees (buf :: Ref.get frees);
        Some ("ptr", buf)
      | _ -> marshal_ffi_arg ctx c v
    ) pairs in
    let param_tys = List.map (fn pair -> let (ty, _) = pair in ty) cargs in
    add_extern ctx c_symbol (cty_llvm c_ret) param_tys;
    let result = (match c_ret with
      | Ast.CVoid -> (Ir_emit.emit_call_void ctx.ir c_symbol cargs; "1")
      | _ -> marshal_ffi_ret ctx c_ret (Ir_emit.emit_call ctx.ir (cty_llvm c_ret) c_symbol cargs)) in
    List.iter (fn wb ->
      let (refv, cell, ic) = wb in
      let mml = (match ic with
        | Ast.CStruct ((_, fields)) -> emit_struct_readback ctx cell fields
        | _ -> marshal_ffi_ret ctx ic (Ir_emit.emit_load ctx.ir (cty_llvm ic) cell)) in
      Ir_emit.emit_store ctx.ir "i64" mml (Ir_emit.emit_inttoptr ctx.ir refv)
    ) (List.rev (Ref.get writebacks));
    (match Ref.get frees with
     | [] -> ()
     | fs -> add_extern ctx "mml_ffi_free" "void" ("ptr" :: []);
       List.iter (fn buf -> Ir_emit.emit_call_void ctx.ir "mml_ffi_free" (("ptr", buf) :: [])) fs);
    (match arena_saved with
     | None -> ()
     | Some s -> add_extern ctx "mml_ffi_arena_restore" "void" ("i64" :: []);
       Ir_emit.emit_call_void ctx.ir "mml_ffi_arena_restore" (("i64", s) :: []));
    result
  and emit_fold_with_break_check ctx fold_expr =
    let result = emit_expr ctx fold_expr in
    add_extern ctx "mml_check_fold_broken" "i64" [];
    add_extern ctx "mml_consume_fold_break" "i64" [];
    let was_broken = Ir_emit.emit_call ctx.ir "i64" "mml_check_fold_broken" [] in
    let is_broken = Ir_emit.emit_icmp ctx.ir "ne" "i64" was_broken "0" in
    let broken_label = fresh_label ctx "fold_was_broken" in
    let ok_label = fresh_label ctx "fold_ok" in
    let merge_label = fresh_label ctx "fold_merge" in
    Ir_emit.emit_condbr ctx.ir is_broken broken_label ok_label;
    Ir_emit.emit_label ctx.ir broken_label;
    ctx.current_label := broken_label;
    let break_val = Ir_emit.emit_call ctx.ir "i64" "mml_consume_fold_break" [] in
    Ir_emit.emit_br ctx.ir merge_label;
    Ir_emit.emit_label ctx.ir ok_label;
    ctx.current_label := ok_label;
    Ir_emit.emit_br ctx.ir merge_label;
    Ir_emit.emit_label ctx.ir merge_label;
    ctx.current_label := merge_label;
    Ir_emit.emit_phi ctx.ir "i64" ((break_val, broken_label) :: (result, ok_label) :: [])
  and emit_for_loop_expr ctx fold_expr =
    match fold_expr.expr with
    | TELetMut ((name, init, body)) -> emit_let_value emit_for_loop_expr ctx name init body true
    | TELet ((name, _scheme, init, body)) -> emit_let_value emit_for_loop_expr ctx name init body false
    | _ -> emit_for_loop_app ctx fold_expr

  and emit_for_loop_app ctx fold_expr =
    let rec extract_fold_app e =
      match e.expr with
      | TEApp ((f, arg)) -> 
        let (base, args) = extract_fold_app f in
        (base, List.concat args (arg :: []))
      | _ -> (e, [])
     in
    let (_base, args) = extract_fold_app fold_expr in
    if (List.length args) = 3 do
      do
        let callback = List.nth args 0 in
        let init = List.nth args 1 in
        let coll = List.nth args 2 in
        let coll_ty = Types.repr coll.ty in
        let cb_elem_matches_list =
          match coll_ty with
          | Types.TList elem_ty -> 
            do
              let cb_ty = Types.repr callback.ty in
              match cb_ty with
              | Types.TArrow ((_, _, ret)) -> 
                do
                  match Types.repr ret with
                  | Types.TArrow ((cb_elem, _, _)) -> (Types.repr elem_ty) = (Types.repr cb_elem)
                  | _ -> true

                end
              | _ -> true

            end
          | _ -> true
         in
        let rt_fn =
          match coll_ty with
          | Types.TList _ when cb_elem_matches_list -> Some "mml_list_fold_breakable"
          | Types.TArray _ -> Some "mml_array_fold_breakable"
          | _ -> None
         in
        match rt_fn with
        | Some fn_name -> 
          let cb_val = emit_expr ctx callback in
          let init_val = emit_expr ctx init in
          let coll_val = emit_expr ctx coll in
          add_extern ctx fn_name "i64" ("i64" :: "i64" :: "i64" :: []);
          Ir_emit.emit_call ctx.ir "i64" fn_name (("i64", cb_val) :: ("i64", init_val) :: ("i64", coll_val) :: [])
        | None -> 
          ctx.fold_guard_pending := true;
          let r = emit_fold_with_break_check ctx fold_expr in
          ctx.fold_guard_pending := false;
          r

      end
    else
      emit_fold_with_break_check ctx fold_expr
  and emit_app ctx fn_expr arg_expr =
    let (f, args) = flatten_app fn_expr arg_expr in
    match f.expr with
    | TEVar name when is_print_name name -> emit_print_call ctx arg_expr
    | TEVar name -> emit_named_call ctx name f args
    | _ -> 
      let closure_val = emit_expr ctx f in
      let arg_vals = List.map (emit_expr ctx) args in
      emit_closure_apply ctx closure_val arg_vals

  and is_print_name =
    fn
      | ("print" | "Stdlib.print") -> true
      | _ -> false

  and flatten_app fn_expr arg_expr =
    let rec collect fn_ args =
      match fn_.expr with
      | TEApp ((f, a)) -> collect f (a :: args)
      | _ -> (fn_, args)
     in
    collect fn_expr (arg_expr :: [])
  and emit_print_call ctx arg_expr =
    let arg_val = emit_expr ctx arg_expr in
    let ty = Types.repr arg_expr.ty in
    ctx.has_print_output := true;
    let is_compound =
      match ty with
      | ((((Types.TInt | Types.TBool) | Types.TString) | Types.TFloat) | Types.TUnit) -> false
      | (((((((Types.TTuple _ | Types.TRecord _) | Types.TVariant _) | Types.TList _) | Types.TPolyVariant _) | Types.TArray _) | Types.TByte) | Types.TRune) -> true
      | _ -> false
     in
    if is_compound do
      emit_format_value ctx arg_val ty;
      add_extern ctx "mml_fmt_newline" "void" [];
      Ir_emit.emit_call_void ctx.ir "mml_fmt_newline" []
    else do
      let fn_name =
        match ty with
        | Types.TInt -> "mml_print_int"
        | Types.TBool -> "mml_print_bool"
        | Types.TString -> "mml_print_string"
        | Types.TFloat -> "mml_print_float"
        | Types.TUnit -> "mml_print_unit"
        | _ -> "mml_print_value"
       in
      add_extern ctx fn_name "i64" ("i64" :: []);
      (Ir_emit.emit_call ctx.ir "i64" fn_name (("i64", arg_val) :: []); ())
    end;
    unit_value
  and emit_named_call ctx name f_expr args =
    match name with
    | ("string_of_int" | "Stdlib.string_of_int") -> 
      let arg_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_string_of_int" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_of_int" (("i64", arg_val) :: [])
    | ("string_of_float" | "Stdlib.string_of_float") -> 
      let arg_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_string_of_float" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_of_float" (("i64", arg_val) :: [])
    | ("string_of_bool" | "Stdlib.string_of_bool") -> 
      let arg_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_string_of_bool" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_of_bool" (("i64", arg_val) :: [])
    | ("float_of_int" | "Stdlib.float_of_int") -> 
      let arg_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_float_of_int" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_float_of_int" (("i64", arg_val) :: [])
    | ("int_of_float" | "Stdlib.int_of_float") -> 
      let arg_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_int_of_float" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_int_of_float" (("i64", arg_val) :: [])
    | "String.length" -> 
      let arg_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_string_length" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_length" (("i64", arg_val) :: [])
    | "failwith" -> 
      let arg_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_panic_mml" "void" ("i64" :: []);
      Ir_emit.emit_call_void ctx.ir "mml_panic_mml" (("i64", arg_val) :: []);
      Ir_emit.emit_unreachable ctx.ir;
      let dead = fresh_label ctx "dead" in
      Ir_emit.emit_label ctx.ir dead;
      ctx.current_label := dead;
      unit_value
    | ("phys_equal" | "Stdlib.phys_equal") -> 
      let a = emit_expr ctx (List.nth args 0) in
      let b = emit_expr ctx (List.nth args 1) in
      let cmp = Ir_emit.emit_icmp ctx.ir "eq" "i64" a b in
      Ir_emit.emit_select ctx.ir cmp "i64" true_value false_value
    | "String.of_byte" -> 
      let arg_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_string_of_byte" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_of_byte" (("i64", arg_val) :: [])
    | "Byte.of_int" -> emit_expr ctx (List.hd args)
    | "Byte.to_int" -> emit_expr ctx (List.hd args)
    | "Byte.to_string" -> 
      let arg_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_string_of_byte" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_string_of_byte" (("i64", arg_val) :: [])
    | "Ref.create" -> 
      let init_val = emit_expr ctx (List.hd args) in
      let ptr = emit_alloc ctx 8 (make_header 0 mml_hdr_ref) in
      Ir_emit.emit_store ctx.ir "i64" init_val ptr;
      Ir_emit.emit_ptrtoint ctx.ir ptr
    | "Ref.get" -> 
      let ref_val = emit_expr ctx (List.hd args) in
      let ptr = Ir_emit.emit_inttoptr ctx.ir ref_val in
      Ir_emit.emit_load ctx.ir "i64" ptr
    | "Ref.set" -> 
      let ref_val = emit_expr ctx (List.nth args 0) in
      let new_val = emit_expr ctx (List.nth args 1) in
      let ptr = Ir_emit.emit_inttoptr ctx.ir ref_val in
      Ir_emit.emit_store ctx.ir "i64" new_val ptr;
      unit_value
    | "List.hd" -> 
      let list_val = emit_expr ctx (List.hd args) in
      let ptr = Ir_emit.emit_inttoptr ctx.ir list_val in
      let hd_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 0 in
      Ir_emit.emit_load ctx.ir "i64" hd_ptr
    | "List.tl" -> 
      let list_val = emit_expr ctx (List.hd args) in
      let ptr = Ir_emit.emit_inttoptr ctx.ir list_val in
      let tl_ptr = Ir_emit.emit_gep ctx.ir "i64" ptr 1 in
      Ir_emit.emit_load ctx.ir "i64" tl_ptr
    | "List.rev" -> 
      let list_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_list_rev" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_rev" (("i64", list_val) :: [])
    | "List.length" -> 
      let list_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_list_length" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_length" (("i64", list_val) :: [])
    | "List.map" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_map" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_map" (("i64", fn_val) :: ("i64", list_val) :: [])
    | ("List.fold" | "List.fold_left") -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let acc_val = emit_expr ctx (List.nth args 1) in
      let list_val = emit_expr ctx (List.nth args 2) in
      add_extern ctx "mml_list_fold" "i64" ("i64" :: "i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_fold" (("i64", fn_val) :: ("i64", acc_val) :: ("i64", list_val) :: [])
    | "List.filter" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_filter" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_filter" (("i64", fn_val) :: ("i64", list_val) :: [])
    | "List.find" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_find" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_find" (("i64", fn_val) :: ("i64", list_val) :: [])
    | "List.find_map" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_find_map" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_find_map" (("i64", fn_val) :: ("i64", list_val) :: [])
    | "List.exists" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_exists" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_exists" (("i64", fn_val) :: ("i64", list_val) :: [])
    | "List.forall" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_forall" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_forall" (("i64", fn_val) :: ("i64", list_val) :: [])
    | "List.iter" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_iter" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_iter" (("i64", fn_val) :: ("i64", list_val) :: [])
    | "List.mapi" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_mapi" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_mapi" (("i64", fn_val) :: ("i64", list_val) :: [])
    | "List.concat" -> 
      let a = emit_expr ctx (List.nth args 0) in
      let b = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_concat" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_concat" (("i64", a) :: ("i64", b) :: [])
    | "List.flatten" -> 
      let list_val = emit_expr ctx (List.hd args) in
      add_extern ctx "mml_list_flatten" "i64" ("i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_flatten" (("i64", list_val) :: [])
    | "List.sort" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      add_extern ctx "mml_list_sort" "i64" ("i64" :: "i64" :: []);
      Ir_emit.emit_call ctx.ir "i64" "mml_list_sort" (("i64", fn_val) :: ("i64", list_val) :: [])
    | "List.fold_right" -> 
      let fn_val = emit_expr ctx (List.nth args 0) in
      let list_val = emit_expr ctx (List.nth args 1) in
      let acc_val = emit_expr ctx (List.nth args 2) in
      add_extern ctx "mml_list_fold_right" "i64" ("i64" :: "i64" :: "i64" :: []);
