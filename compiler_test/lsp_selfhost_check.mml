-- Behavioral self-check for self_host/lsp.mml's protocol layer (gate stage
-- `lsp-selfhost`). Concatenated after the full compiler (minus main.mml) + json +
-- diagnostic + analysis + lsp and run on the OCaml VM + native; must print "OK".
-- Drives Lsp.handle_message with real JSON-RPC messages and checks the response
-- JSON structurally. make_analysis_ctx reads stdlib/*.mml (run from repo root).
let () =
  let srv = Lsp.create () in
  let first lst = (match lst with x :: _ -> x | [] -> Json.JNull) in
  let send s = first (Lsp.handle_message srv (Json.parse s)) in
  -- initialize → capabilities
  let initr = send "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{}}" in
  let caps = Json.member "capabilities" (Json.member "result" initr) in
  -- didOpen a doc with a type error → publishDiagnostics with a "type" diagnostic
  let openerr = send "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"file:///a.mml\",\"text\":\"let x = 1 + true\"}}}" in
  let errdiags = Json.as_list (Json.member "diagnostics" (Json.member "params" openerr)) in
  -- didOpen a clean doc → empty diagnostics
  let openclean = send "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"file:///b.mml\",\"text\":\"let n = 42\"}}}" in
  let cleandiags = Json.as_list (Json.member "diagnostics" (Json.member "params" openclean)) in
  -- hover on the 42 literal (line 0, char 8) → int
  let hov = send "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"textDocument/hover\",\"params\":{\"textDocument\":{\"uri\":\"file:///b.mml\"},\"position\":{\"line\":0,\"character\":8}}}" in
  let hovval = Json.to_str (Json.member "value" (Json.member "contents" (Json.member "result" hov))) in
  -- completion → a non-empty item list including a stdlib name
  let comp = send "{\"jsonrpc\":\"2.0\",\"id\":3,\"method\":\"textDocument/completion\",\"params\":{\"textDocument\":{\"uri\":\"file:///b.mml\"}}}" in
  let items = Json.as_list (Json.member "result" comp) in
  let has_label lst q = List.exists (fn it -> (Json.to_str (Json.member "label" it)) = q) lst in
  -- inlay hints on the clean doc (b.mml = "let n = 42") → one ": int" hint
  let inlay = send "{\"jsonrpc\":\"2.0\",\"id\":4,\"method\":\"textDocument/inlayHint\",\"params\":{\"textDocument\":{\"uri\":\"file:///b.mml\"},\"range\":{}}}" in
  let inlays = Json.as_list (Json.member "result" inlay) in
  -- shutdown → null result; unknown method with an id → null result
  let shut = send "{\"jsonrpc\":\"2.0\",\"id\":9,\"method\":\"shutdown\"}" in
  -- document symbols on b.mml ("let n = 42") → one symbol "n"
  let dsym = send "{\"jsonrpc\":\"2.0\",\"id\":10,\"method\":\"textDocument/documentSymbol\",\"params\":{\"textDocument\":{\"uri\":\"file:///b.mml\"}}}" in
  let dsyms = Json.as_list (Json.member "result" dsym) in
  -- formatting a messy buffer → one whole-document edit with formatted text
  let _ = send "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"file:///fmt.mml\",\"text\":\"let   x=1\"}}}" in
  let fmt = send "{\"jsonrpc\":\"2.0\",\"id\":11,\"method\":\"textDocument/formatting\",\"params\":{\"textDocument\":{\"uri\":\"file:///fmt.mml\"}}}" in
  let fmts = Json.as_list (Json.member "result" fmt) in
  -- semantic tokens: a doc exercising every inference-aware class — `g`/`length`
  -- are functions, `x`/`z` variables, `Some` an enumMember, `List` a namespace,
  -- `'a` a typeParameter. semanticTokens/full returns the delta-encoded flat int
  -- array (5 ints/token); the token-type code is every 5th int starting at idx 3.
  let semsrc = "let g (x : 'a) = Some x\nlet z = List.length [1]" in
  let _ = send ("{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"file:///sem.mml\",\"text\":" ^ ((Json.to_string (Json.JString semsrc)) ^ "}}}")) in
  let semr = send "{\"jsonrpc\":\"2.0\",\"id\":12,\"method\":\"textDocument/semanticTokens/full\",\"params\":{\"textDocument\":{\"uri\":\"file:///sem.mml\"}}}" in
  let semdata = Json.as_list (Json.member "data" (Json.member "result" semr)) in
  let typecodes =
    let (_, rev) = List.fold (fn acc v -> let (i, cs) = acc in (i + 1, (if (i mod 5) = 3 do (Json.as_int v) :: cs else cs))) (0, []) semdata in
    List.rev rev in
  let hascode c = List.exists (fn x -> x = c) typecodes in
  -- incremental sync: open an erroring doc, then a RANGE edit splices it clean
  -- ("let x = 1 + true" → replace `true` at chars 12..16 with "2" → "let x = 1 + 2")
  let openinc = send "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"file:///inc.mml\",\"text\":\"let x = 1 + true\"}}}" in
  let inc_err = Json.as_list (Json.member "diagnostics" (Json.member "params" openinc)) in
  let chg = send "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didChange\",\"params\":{\"textDocument\":{\"uri\":\"file:///inc.mml\"},\"contentChanges\":[{\"range\":{\"start\":{\"line\":0,\"character\":12},\"end\":{\"line\":0,\"character\":16}},\"text\":\"2\"}]}}" in
  let inc_diags = Json.as_list (Json.member "diagnostics" (Json.member "params" chg)) in
  -- scope-resolved document highlight: a LOCAL `total` (let-bound in f, decl +
  -- two uses) shadowing an unrelated TOP-LEVEL `total`. Highlighting a use must
  -- return exactly the 3 local occurrences and EXCLUDE the line-3 top-level one.
  let occsrc = "let f n =\n  let total = n + n in\n  total + total\nlet total = 5" in
  let _ = send ("{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"file:///occ.mml\",\"text\":" ^ ((Json.to_string (Json.JString occsrc)) ^ "}}}")) in
  let hl = send "{\"jsonrpc\":\"2.0\",\"id\":13,\"method\":\"textDocument/documentHighlight\",\"params\":{\"textDocument\":{\"uri\":\"file:///occ.mml\"},\"position\":{\"line\":2,\"character\":2}}}" in
  let hlranges = Json.as_list (Json.member "result" hl) in
  let hl_line r = Json.as_int (Json.member "line" (Json.member "start" (Json.member "range" r))) in
  -- references on the same local are single-file scoped (no root → open doc only)
  let rf = send "{\"jsonrpc\":\"2.0\",\"id\":14,\"method\":\"textDocument/references\",\"params\":{\"textDocument\":{\"uri\":\"file:///occ.mml\"},\"position\":{\"line\":2,\"character\":2}}}" in
  let rfranges = Json.as_list (Json.member "result" rf) in
  let checks = [
    ("highlight-local-scoped-count", List.length hlranges = 3);
    ("highlight-decl-on-let-line", (List.length (List.filter (fn r -> (hl_line r) = 1) hlranges)) = 1);
    ("highlight-uses-on-body-line", (List.length (List.filter (fn r -> (hl_line r) = 2) hlranges)) = 2);
    ("highlight-excludes-toplevel", not (List.exists (fn r -> (hl_line r) = 3) hlranges));
    ("references-local-scoped-count", List.length rfranges = 3);
    ("init-semanticTokensProvider", (match Json.member "semanticTokensProvider" caps with Json.JNull -> false | _ -> true));
    ("init-sync-incremental", Json.as_int (Json.member "textDocumentSync" caps) = 2);
    ("semtok-multiple-of-5", ((List.length semdata) mod 5) = 0);
    ("semtok-nonempty", List.length semdata >= 5);
    ("semtok-has-function", hascode Analysis.st_function);
    ("semtok-has-variable", hascode Analysis.st_variable);
    ("semtok-has-enummember", hascode Analysis.st_enum_member);
    ("semtok-has-namespace", hascode Analysis.st_namespace);
    ("semtok-has-typeparam", hascode Analysis.st_type_parameter);
    ("incsync-open-has-error", List.length inc_err >= 1);
    ("incsync-range-edit-fixes", List.length inc_diags = 0);
    ("init-hoverProvider", (match Json.member "hoverProvider" caps with Json.JBool true -> true | _ -> false));
    ("init-inlayHintProvider", (match Json.member "inlayHintProvider" caps with Json.JBool true -> true | _ -> false));
    ("init-documentSymbolProvider", (match Json.member "documentSymbolProvider" caps with Json.JBool true -> true | _ -> false));
    ("init-formattingProvider", (match Json.member "documentFormattingProvider" caps with Json.JBool true -> true | _ -> false));
    ("docsym-one", List.length dsyms = 1);
    ("docsym-name", (match dsyms with d :: _ -> Json.to_str (Json.member "name" d) = "n" | [] -> false));
    ("docsym-kind-variable", (match dsyms with d :: _ -> Json.as_int (Json.member "kind" d) = 13 | [] -> false));
    ("format-one-edit", List.length fmts = 1);
    ("format-newtext", (match fmts with e :: _ -> Json.to_str (Json.member "newText" e) <> "" | [] -> false));
    ("inlay-one-hint", List.length inlays = 1);
    ("inlay-label-int", (match inlays with h :: _ -> Json.to_str (Json.member "label" h) = ": int" | [] -> false));
    ("init-has-id", Json.as_int (Json.member "id" initr) = 1);
    ("open-type-error", List.length errdiags >= 1);
    ("open-type-code", (match errdiags with d :: _ -> Json.to_str (Json.member "code" d) = "type" | [] -> false));
    ("open-clean-empty", List.length cleandiags = 0);
    ("hover-int", hovval = "int");
    ("completion-nonempty", List.length items >= 1);
    ("completion-has-stdlib", has_label items "print");
    ("completion-has-local", has_label items "n");
    ("shutdown-null", (match Json.member "result" shut with Json.JNull -> true | _ -> false));
    ("is-exit", Lsp.is_exit (Json.parse "{\"method\":\"exit\"}"))
  ] in
  match List.find (fn pair -> let (_, ok) = pair in not ok) checks with
  | None -> print "OK"
  | Some pair -> let (label, _) = pair in print ("FAIL: " ^ label)
