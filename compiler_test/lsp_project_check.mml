-- Behavioral self-check for project-aware analysis (gate stage `lsp-project`):
-- self_host/lsp.mml's project_ctx_for + Driver.load_modules_into. Concatenated
-- after the full compiler + json/diagnostic/analysis + the pkg chain
-- (semver…project) + lsp, and run on the OCaml VM + native; must print "OK".
-- Writes two sibling modules to /tmp, opens one through the LSP, and checks that
-- references to the other resolve (no "unknown" diagnostics; hover/go-to-def work).
let () =
  let dir = "/tmp/mml_lspproj_check" in
  let _ = if Fs.is_directory dir do () else Fs.make_dir dir in
  IO.write_file (dir ^ "/foo.mml")
    "module Foo =\n  pub type t = A | B of int\n  pub let mk = A\n  pub let label = \"hi\"\nend\n";
  IO.write_file (dir ^ "/bar.mml")
    "module Bar =\n  pub let x = Foo.mk\n  pub let y = Foo.B 3\n  pub let z = Foo.label\nend\n";
  -- a FLAT sibling that redefines a base type (`option`). It must be SKIPPED when
  -- building a file's project ctx — loading it would clobber the base Some/None
  -- (the stdlib/option_type.mml bug). user.mml uses Some/None and must stay clean.
  IO.write_file (dir ^ "/redef.mml") "type 'a option = None | Some of 'a\n";
  IO.write_file (dir ^ "/user.mml")
    "module User =\n  pub let f xs = match List.find (fn _ -> true) xs with Some v -> v | None -> 0\nend\n";
  -- an UNRELATED module with a member ALSO spelled `mk` (+ a use of it). Precise
  -- references for Foo.mk must EXCLUDE these (canonical name "Baz.mk" ≠ "Foo.mk");
  -- a by-name search would wrongly count all 4 `mk` tokens.
  IO.write_file (dir ^ "/baz.mml")
    "module Baz =\n  pub let mk = 0\n  pub let use_mk = mk + 1\nend\n";
  let bar_uri = "file://" ^ dir ^ "/bar.mml" in
  let foo_path = dir ^ "/foo.mml" in
  let srv = Lsp.create () in
  let first lst = (match lst with x :: _ -> x | [] -> Json.JNull) in
  let send s = first (Lsp.handle_message srv (Json.parse s)) in
  -- initialize with the temp dir as the root (for cross-file go-to-def)
  let _ = send ("{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"rootUri\":\"file://" ^ dir ^ "\"}}") in
  let bar = IO.read_file (dir ^ "/bar.mml") in
  let open_msg =
    "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\",\"text\":"
    ^ (Json.to_string (Json.JString bar)) ^ "}}}" in
  let published = send open_msg in
  let diags = Json.as_list (Json.member "diagnostics" (Json.member "params" published)) in
  -- hover on Foo.label use (line 3, char 14 = on 'label') → string
  let hov = send ("{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"textDocument/hover\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\"},\"position\":{\"line\":3,\"character\":14}}}") in
  let hov_ty = Json.to_str (Json.member "value" (Json.member "contents" (Json.member "result" hov))) in
  -- go-to-def of Foo.mk (line 1, char 18) and the constructor Foo.B (line 2, char 18)
  let def_uri q = (match q with Json.JNull -> "" | _ -> Json.to_str (Json.member "uri" q)) in
  let defmk = def_uri (Json.member "result" (send ("{\"jsonrpc\":\"2.0\",\"id\":3,\"method\":\"textDocument/definition\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\"},\"position\":{\"line\":1,\"character\":18}}}"))) in
  let defB = def_uri (Json.member "result" (send ("{\"jsonrpc\":\"2.0\",\"id\":4,\"method\":\"textDocument/definition\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\"},\"position\":{\"line\":2,\"character\":18}}}"))) in
  -- a lone file with no siblings still analyzes (stdlib ctx) — clean source → []
  let lone = Lsp.handle_message srv (Json.parse "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"file:///tmp/mml_lspproj_check_lone/solo.mml\",\"text\":\"let a = 1 + 2\"}}}") in
  let lone_diags = (match lone with d :: _ -> Json.as_list (Json.member "diagnostics" (Json.member "params" d)) | [] -> Json.JString "x" :: []) in
  let ends_with s suf = let ls = String.length s in let lf = String.length suf in (ls >= lf) && ((String.sub s (ls - lf) lf) = suf) in
  -- open user.mml: a flat sibling redefines `option`, but it must be skipped, so
  -- the Some/None match stays clean (the option_type clobber regression).
  let user_uri = "file://" ^ dir ^ "/user.mml" in
  let user = IO.read_file (dir ^ "/user.mml") in
  let user_open =
    "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"" ^ user_uri ^ "\",\"text\":"
    ^ (Json.to_string (Json.JString user)) ^ "}}}" in
  let user_pub = send user_open in
  let user_diags = Json.as_list (Json.member "diagnostics" (Json.member "params" user_pub)) in
  -- stdlib-file duplicate suppression: a file under <root>/stdlib whose
  -- instances are already in the base ctx must NOT report "duplicate instance"
  -- (it's a self-collision); the SAME content elsewhere must still report it.
  let sroot = "/tmp/mml_lspstd_check" in
  let _ = if Fs.is_directory (sroot ^ "/stdlib") do () else (if Fs.is_directory sroot do () else Fs.make_dir sroot; Fs.make_dir (sroot ^ "/stdlib")) in
  let _ = if Fs.is_directory (sroot ^ "/other") do () else Fs.make_dir (sroot ^ "/other") in
  let showsrc = IO.read_file "stdlib/show.mml" in   -- declares instances the base already has
  IO.write_file (sroot ^ "/stdlib/dup.mml") showsrc;
  IO.write_file (sroot ^ "/other/dup.mml") showsrc;
  let srv2 = Lsp.create () in
  let send2 s = first (Lsp.handle_message srv2 (Json.parse s)) in
  let _ = send2 ("{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"rootUri\":\"file://" ^ sroot ^ "\"}}") in
  let open_at uri = send2 ("{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"" ^ uri ^ "\",\"text\":" ^ (Json.to_string (Json.JString showsrc)) ^ "}}}") in
  let dupcount r = List.length (List.filter (fn d -> String.starts_with "duplicate " (Json.to_str (Json.member "message" d))) (Json.as_list (Json.member "diagnostics" (Json.member "params" r)))) in
  let in_stdlib_dups = dupcount (open_at ("file://" ^ sroot ^ "/stdlib/dup.mml")) in
  let elsewhere_dups = dupcount (open_at ("file://" ^ sroot ^ "/other/dup.mml")) in
  -- navigation (srv has root=dir, bar.mml open; foo.mml defines mk, bar uses Foo.mk)
  let nres q = List.length (Json.as_list (Json.member "result" q)) in
  -- workspace/symbol "mk" → Foo.mk
  let ws = nres (send "{\"jsonrpc\":\"2.0\",\"id\":20,\"method\":\"workspace/symbol\",\"params\":{\"query\":\"mk\"}}") in
  -- documentHighlight on `Foo` in bar.mml (line 1 `pub let x = Foo.mk`, char 14) → Foo occurs 3× in bar
  let dh = nres (send ("{\"jsonrpc\":\"2.0\",\"id\":21,\"method\":\"textDocument/documentHighlight\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\"},\"position\":{\"line\":1,\"character\":14}}}")) in
  -- references of `mk` (cursor on Foo.mk, char 18): PRECISE by canonical name —
  -- foo.mml def + bar.mml use = 2, EXCLUDING baz.mml's unrelated `mk` (def + use);
  -- a by-name search would have returned 4.
  let rf = nres (send ("{\"jsonrpc\":\"2.0\",\"id\":22,\"method\":\"textDocument/references\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\"},\"position\":{\"line\":1,\"character\":18}}}")) in
  -- cross-module RENAME of Foo.mk → "renamed": a WorkspaceEdit touching foo.mml
  -- (the def) and bar.mml (the use), and EXCLUDING baz.mml (canonical "Baz.mk" ≠
  -- "Foo.mk"). Per-file edit counts + baz exclusion + newText prove precision.
  let rn = send ("{\"jsonrpc\":\"2.0\",\"id\":23,\"method\":\"textDocument/rename\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\"},\"position\":{\"line\":1,\"character\":18},\"newName\":\"renamed\"}}") in
  let changes = Json.member "changes" (Json.member "result" rn) in
  let foo_uri = "file://" ^ dir ^ "/foo.mml" in
  let baz_uri = "file://" ^ dir ^ "/baz.mml" in
  let edits_in u = List.length (Json.as_list (Json.member u changes)) in
  let first_newtext u = (match Json.as_list (Json.member u changes) with e :: _ -> Json.to_str (Json.member "newText" e) | [] -> "") in
  -- prepareRename on the Foo.mk member token → placeholder = current name "mk"
  let pr = send ("{\"jsonrpc\":\"2.0\",\"id\":24,\"method\":\"textDocument/prepareRename\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\"},\"position\":{\"line\":1,\"character\":18}}}") in
  let pr_placeholder = Json.to_str (Json.member "placeholder" (Json.member "result" pr)) in
  -- FRESHNESS: the whole-program index must not be frozen at first use. Edit
  -- bar.mml (via didChange) to add a SECOND Foo.mk use, then re-query references.
  -- A stale index (wfiles/wp_ctx cached from the open) would still report 2; with
  -- per-edit invalidation the new use is picked up → 3 (foo def + 2 bar uses).
  let bar2 = "module Bar =\n  pub let x = Foo.mk\n  pub let y = Foo.B 3\n  pub let z = Foo.label\n  pub let w = Foo.mk\nend\n" in
  let _ = send ("{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didChange\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\"},\"contentChanges\":[{\"text\":" ^ (Json.to_string (Json.JString bar2)) ^ "}]}}") in
  let rf2 = nres (send ("{\"jsonrpc\":\"2.0\",\"id\":25,\"method\":\"textDocument/references\",\"params\":{\"textDocument\":{\"uri\":\"" ^ bar_uri ^ "\"},\"position\":{\"line\":1,\"character\":18}}}")) in
  -- CROSS-FILE DIAGNOSTIC PROPAGATION: editing a file's declaration surface
  -- re-publishes its open DEPENDENTS, but a body-only edit does not. Fresh server.
  let pdir = "/tmp/mml_lsppropagate" in
  let _ = if Fs.is_directory pdir do () else Fs.make_dir pdir in
  IO.write_file (pdir ^ "/pfoo.mml") "module Pfoo =\n  pub let mk = 0\nend\n";
  IO.write_file (pdir ^ "/pbar.mml") "module Pbar =\n  pub let x = Pfoo.mk\nend\n";
  let pbar_uri = "file://" ^ pdir ^ "/pbar.mml" in
  let pfoo_uri = "file://" ^ pdir ^ "/pfoo.mml" in
  let srv3 = Lsp.create () in
  let all3 s = Lsp.handle_message srv3 (Json.parse s) in
  let _ = all3 ("{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"rootUri\":\"file://" ^ pdir ^ "\"}}") in
  let opn u t = all3 ("{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",\"params\":{\"textDocument\":{\"uri\":\"" ^ u ^ "\",\"text\":" ^ (Json.to_string (Json.JString t)) ^ "}}}") in
  let _ = opn pfoo_uri "module Pfoo =\n  pub let mk = 0\nend\n" in
  let _ = opn pbar_uri "module Pbar =\n  pub let x = Pfoo.mk\nend\n" in
  let chg u t = all3 ("{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didChange\",\"params\":{\"textDocument\":{\"uri\":\"" ^ u ^ "\"},\"contentChanges\":[{\"text\":" ^ (Json.to_string (Json.JString t)) ^ "}]}}") in
  -- find pbar's published diagnostic count in a returned message list (-1 = absent)
  let bar_diags msgs = List.fold (fn acc m ->
    if (Json.to_str (Json.member "uri" (Json.member "params" m))) = pbar_uri
    do List.length (Json.as_list (Json.member "diagnostics" (Json.member "params" m))) else acc) (0 - 1) msgs in
  -- surface change: remove mk → pbar must be re-published WITH an unbound diag
  let break_msgs = chg pfoo_uri "module Pfoo =\n  pub let other = 0\nend\n" in
  let propagated = bar_diags break_msgs in
  -- body-only edit: pbar must NOT be re-published (stays absent from the list)
  let body_msgs = chg pfoo_uri "module Pfoo =\n  pub let other = 9\nend\n" in
  let body_touched_bar = bar_diags body_msgs <> (0 - 1) in
  -- restore mk → pbar re-published CLEAN (error clears)
  let fix_msgs = chg pfoo_uri "module Pfoo =\n  pub let mk = 7\nend\n" in
  let cleared = bar_diags fix_msgs in
  let checks = [
    ("xfile-propagate-error", propagated = 1);
    ("xfile-body-edit-skips-dependents", not body_touched_bar);
    ("xfile-propagate-clear", cleared = 0);
    ("references-fresh-after-edit", rf2 = 3);
    ("rename-foo-mk-def", edits_in foo_uri = 1);
    ("rename-foo-mk-use", edits_in bar_uri = 1);
    ("rename-foo-mk-excludes-baz", edits_in baz_uri = 0);
    ("rename-newtext", first_newtext bar_uri = "renamed");
    ("prepare-rename-placeholder", pr_placeholder = "mk");
    ("workspace-symbol-finds", ws >= 1);
    ("document-highlight-foo", dh = 3);
    ("references-mk-workspace", rf = 2);
    ("xmodule-no-unknown-diags", List.length diags = 0);
    ("redef-sibling-skipped-some-none-ok", List.length user_diags = 0);
    ("stdlib-dup-suppressed", in_stdlib_dups = 0);
    ("nonstdlib-dup-reported", elsewhere_dups >= 1);
    ("xmodule-hover", hov_ty = "string");
    ("xfile-def-fn", ends_with defmk "foo.mml");
    ("xfile-def-ctor", ends_with defB "foo.mml");
    ("lone-file-clean", List.length lone_diags = 0)
  ] in
  match List.find (fn pair -> let (_, ok) = pair in not ok) checks with
  | None -> print "OK"
  | Some pair -> let (label, _) = pair in print ("FAIL: " ^ label)
