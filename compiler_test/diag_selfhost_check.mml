-- Behavioral self-check for self_host/diagnostic.mml (gate stage `diag-selfhost`).
-- Concatenated after token.mml + lexer.mml + diagnostic.mml and run on the OCaml
-- VM + native; must print "OK". ASCII-only so every backend agrees.
let () =
  let src = "let x = 1\nlet y = foo bar\nlet z = 3" in
  -- pos_of_offset: byte 10 is the start of line 2
  let p = Diagnostic.pos_of_offset src 10 in
  -- the 'foo' identifier starts at byte 18 (line 2, col 9), spans 3 bytes
  let foo_loc = ({line = 2; col = 9; offset = 18} : Token.loc) in
  let d = Diagnostic.make "type" (Diagnostic.span_at src foo_loc) "unbound foo" in
  -- a locationless error → empty caret span at file start
  let d0 = Diagnostic.make "type" (Diagnostic.span_at src ({line = 0; col = 0; offset = 0} : Token.loc)) "no loc" in
  -- a warning over line 3 ("let z = 3" — 9 bytes, cols 1..10)
  let w = Diagnostic.make_sev Diagnostic.Warning "warning" (Diagnostic.line_span src 3) "unused" in
  -- clamping: an offset past the end clamps to the end position
  let pend = Diagnostic.pos_of_offset src 9999 in
  let checks = [
    ("pos-line", p.line = 2);
    ("pos-col", p.col = 1);
    ("pos-offset", p.offset = 10);
    ("span-covers-token", Diagnostic.to_string d = "[type] error 2:9-2:12: unbound foo");
    ("locationless-caret", Diagnostic.to_string d0 = "[type] error 1:1-1:1: no loc");
    ("warning-line-span", Diagnostic.to_string w = "[warning] warning 3:1-3:10: unused");
    ("clamp-offset", pend.offset = String.length src);
    ("severity-name", Diagnostic.severity_name Diagnostic.Hint = "hint")
  ] in
  match List.find (fn pair -> let (_, ok) = pair in not ok) checks with
  | None -> print "OK"
  | Some pair -> let (label, _) = pair in print ("FAIL: " ^ label)
