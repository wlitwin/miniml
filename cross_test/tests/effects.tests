--- test: effect row variable sharing in annotation
effect Log =
  log : string -> unit
end
let apply_and_log (f : int -> int / Log, 'e) (x : int) : int / Log, 'e =
  let r = f x in
  perform log (show r);
  r
in
let mut logged = "" in
handle
  apply_and_log (fn x -> perform log "calling"; x * 2) 21
with
| return x -> logged ^ " => " ^ show x
| log msg k -> logged := logged ^ msg ^ " "; resume k ()
--- expect: calling 42  => 42

--- test: effect row variable sharing constrains effects
effect Tick =
  tick : unit -> unit
end
effect Tock =
  tock : unit -> unit
end
let both (f : unit -> unit / Tick, Tock, 'e) (g : unit -> unit / Tick, Tock, 'e) : unit / Tick, Tock, 'e =
  f (); g ()
in
let mut count = 0 in
handle
  handle
    both (fn () -> perform tick ()) (fn () -> perform tock ());
    count
  with
  | return x -> x
  | tock () k -> count := count + 10; resume k ()
with
| return x -> x
| tick () k -> count := count + 1; resume k ()
--- expect: 11

--- test: continuation captured in closure and resumed later
effect E =
  op : unit -> unit
end
let mut saved = [] in
let mut trace = "" in
let _ =
  handle
    trace := trace ^ "a"; perform op (); trace := trace ^ "c"
  with
  | return x -> x
  | op () k -> trace := trace ^ "b"; saved := [(fn () -> resume k ())]
in
let _ = (match saved with [] -> () | t :: _ -> t ()) in
trace
--- expect: abc

--- test: yielding scheduler with list queue
effect Sched =
  yield : unit -> unit
  fork  : (unit -> unit) -> unit
end
let mut q = [] in
let mut trace = "" in
let enqueue t = q := List.concat q [t] in
let dequeue () = match q with [] -> () | t :: rest -> q := rest; t () in
let rec spawn task =
  handle task ()
  with
  | return _ -> dequeue ()
  | yield () k -> enqueue (fn () -> resume k ()); dequeue ()
  | fork f k -> enqueue (fn () -> resume k ()); spawn f
in
let worker name n =
  let rec loop i =
    if i > n do ()
    else (trace := trace ^ name ^ show i; perform yield (); loop (i + 1))
  in loop 1
in
let _ =
  spawn (fn () ->
    perform fork (fn () -> worker "A" 2);
    worker "B" 2)
in
trace
--- expect: A1B1A2B2

--- test: gc scans suspended fiber stack
effect E =
  ping : unit -> int
end
let mut saved = []
let mut result = ""
let _ =
  handle
    let a = "a" ^ show 1 in let b = "b" ^ show 2 in let c = "c" ^ show 3 in
    let d = "d" ^ show 4 in let e = "e" ^ show 5 in let f = "f" ^ show 6 in
    let g = "g" ^ show 7 in let h = "h" ^ show 8 in let i = "i" ^ show 9 in
    let j = "j" ^ show 10 in let k = "k" ^ show 11 in let l = "l" ^ show 12 in
    let _ = perform ping () in
    result := a^b^c^d^e^f^g^h^i^j^k^l
  with
  | return x -> x
  | ping () k -> saved := [(fn () -> resume k 0)]
let mut junk = []
let _ = for n = 0; n < 300000; n + 1 do junk := show n :: junk end
let _ = match saved with [] -> () | t :: _ -> t ()
let final = result
;;
final
--- expect: a1b2c3d4e5f6g7h8i9j10k11l12

