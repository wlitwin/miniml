    let b = perform choose () in
    let g = perform get () in
    if b do g else g * 10
  with
  | return v -> v
  | choose () k -> let k2 = copy_continuation k in (resume k true) + (resume k2 false)
with
| return v -> v
| get () k -> resume k 7
