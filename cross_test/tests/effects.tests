--- test: resume as a match scrutinee (non-tail) in a handler arm
effect E2 = ask2 : unit -> int end
let f () =
  handle (let x = perform ask2 () in if x > 0 do Ok x else Err "neg") with
  | return r -> r
  | ask2 () k -> match resume k 5 with Ok v -> Ok (v + 100) | Err e -> Err e
;;
match f () with
| Ok v -> v
| Err _ -> 0
--- expect: 105

--- test: multishot resume in a recursive helper matched non-tail
effect Re = att : unit -> int end
let run () =
  handle (let b = perform att () in if b < 3 do Err "low" else Ok b) with
  | return r -> r
  | att () k ->
      let rec go n =
        match resume (copy_continuation k) n with
        | Ok v -> Ok v
        | Err _ -> if n < 5 do go (n + 1) else Err "give up"
      in go 1
;;
match run () with
| Ok v -> v
| Err _ -> 0
--- expect: 3

# ============================================================================
# Mixed-Handler Abort
# ============================================================================
# A handler mixing an ABORTING op (an arm that never resumes) with a RESUMING
# op (provide- or full-style). Performing the aborting op discards the current
# computation under the handler and makes the arm's value the result. The abort
# must unwind to the NEAREST ACTIVE handle delimiter: the handle body for a
# perform reached during direct body evaluation, but a full op's RESUME for a
# perform reached inside that resume's continuation. emit-js lowers the abort to
# a tagged throw caught at BOTH the body and each non-tail resume's trampoline.
# (Found by the differential fuzzer, seed 920517626 / 293047163.)

--- test: abort through a List.map callback in the body
effect E = op0 : int -> int; op1 : int -> int end
handle (List.length (List.map (fn e -> perform op0 e) [1; 2; 3])) with
| op0 arg k -> 0
| op1 arg k -> resume k arg
--- expect: 0

--- test: abort through a List.fold callback in the body
effect E = op0 : int -> int; op1 : int -> int end
handle (List.fold (fn acc e -> acc + (perform op0 e)) 0 [1; 2; 3]) with
| op0 arg k -> 0
| op1 arg k -> resume k arg
--- expect: 0

--- test: abort directly in body alongside a full op (CPS body)
effect E = op0 : int -> int; op1 : int -> int end
handle ((perform op1 5) + (perform op0 99) + 1000) with
| op0 arg k -> arg
| op1 arg k -> resume k arg
--- expect: 99

--- test: abort bypasses the return arm
effect E = op0 : int -> int; op1 : int -> int end
handle (100 + (perform op0 5)) with
| return x -> x * 2
| op0 arg k -> arg + 1
| op1 arg k -> resume k arg
--- expect: 6

--- test: single-shot abort performed inside a resumed continuation
effect E = op0 : int -> int; op1 : int -> int end
handle (perform op0 (perform op1 11)) with
| return x -> x
| op0 arg k -> arg
| op1 arg k -> resume k arg
--- expect: 11

--- test: multishot abort performed inside a resumed continuation
effect E = op0 : int -> int; op1 : int -> int end
handle (perform op0 (perform op1 11)) with
| return x -> x
| op0 arg k -> arg
| op1 arg k -> let k2 = copy_continuation k in (resume k arg) + (resume k2 100)
--- expect: 111

--- test: abort through a HOF callback inside a multishot resume
effect E = op0 : int -> int; op1 : int -> int end
handle
  (let x = perform op1 0 in List.length (List.map (fn e -> perform op0 e) [1; 2; x]))
with
| op0 arg k -> 0
| op1 arg k -> let k2 = copy_continuation k in (resume k arg) + (resume k2 5)
--- expect: 0

--- test: abort from inside an inner multishot resume caught by the outer handler
effect E = a : int -> int; b : int -> int end
handle
  (handle (perform b (perform a 1)) with
   | b arg k -> let k2 = copy_continuation k in (resume k arg) + (resume k2 10))
with
| a arg k -> 7
--- expect: 7

# ============================================================================
# Return Through a Tail-Resume
# ============================================================================
# A tail-resumptive (provide-style) handler lifts its op marker off the handler
# stack while the arm runs and reinstalls it when the arm returns. If the arm's
# value tail-calls a function that exits via `return`, that `return` unwinds
# THROUGH the arm's (reused) frame back to the perform site — the OCaml VM's
# FUNC_RETURN path must reinstall the lifted marker (like a normal arm return),
# else a later perform of the same op is "unhandled". (VM-only bug found by the
# differential fuzzer, seed 20458; minimal repro vb2.)

--- test: return inside a function called in a tail-resume value
effect E = op0 : int -> int end
let fn0 x = (if true do return 9 else x)
;;
handle ((perform op0 (perform op0 8)) mod 2) with
| return x -> x
| op0 arg k -> resume k (fn0 arg)
--- expect: 1

--- test: conditional return in a resumed function across two performs
effect E = op0 : int -> int end
let fn0 x = (if x > 5 do return 100 else x)
;;
handle ((perform op0 8) + (perform op0 2)) with
| return v -> v
| op0 arg k -> resume k (fn0 arg)
--- expect: 102

--- test: return out of a for-in loop inside a tail-resumed function
effect E = tick : int -> int end
let f x = (for i in [1; 2; 3] with a = 0 do (if i = 2 do return (x * 10) else a + i) end)
;;
handle (perform tick 3) with
| return v -> v
| tick n k -> resume k (f n)
--- expect: 30

# A try-only handler at a MODULE's top level lowers into that module's unit
# initializer mml_init_m_<mod>, which the native backend types as `void`. The
# handler's early-return path emitted `ret i64 <v>` there — invalid LLVM in a
# void function (clang rejected it). Regression for the self-host bootstrap:
# main.mml's `module Main` has exactly this shape. The early return must
# `ret void` (discarding the value) inside a void unit-init.
--- test: top-level handler in a module unit-init (native void-init early return)
effect E =
  fail : string -> unit
end
;;
module Main =
  pub let result =
    handle
      perform fail "boom";
      7
    with
    | return x -> x
    | fail msg _k -> 99
end
;;
Main.result
--- expect: 99

=== Effect-polymorphic recursion ===

--- test: recursive call inside a handler needs an effect-row variable annotation
effect Log =
  log : int -> unit
end
let rec sum n : int / 'e =
  if n <= 0 do 0
  else handle n + sum (n - 1) with
    | return x -> x
    | log _ k -> resume k ()
;;
sum 4
--- expect: 10

--- test: a (type 'a) binder also enables effect-polymorphic recursion
effect Log =
  log : int -> unit
end
let rec (type 'a) sum n : int =
  if n <= 0 do 0
  else handle n + sum (n - 1) with
    | return x -> x
    | log _ k -> resume k ()
;;
sum 4
--- expect: 10

--- test: recursion inside a handler without the effect-var annotation is rejected
effect Log =
  log : int -> unit
end
let rec sum n =
  if n <= 0 do 0
  else handle n + sum (n - 1) with
    | return x -> x
    | log _ k -> resume k ()
;;
sum 4
--- expect-type-error: infinite effect row

--- test: effect-var annotation in a module member enables effect-poly recursion
effect Log =
  log : int -> unit
end
module M =
  pub let rec sum n : int / 'e =
    if n <= 0 do 0
    else handle n + sum (n - 1) with
      | return x -> x
      | log _ k -> resume k ()
end
;;
M.sum 5
--- expect: 15

--- test: mutually-recursive functions can both be effect-polymorphic
effect Log =
  log : int -> unit
end
let rec ev n : int / 'e =
  if n <= 0 do 1
  else handle od (n - 1) with | return x -> x | log _ k -> resume k ()
and od n : int / 'e =
  if n <= 0 do 0
  else handle ev (n - 1) with | return x -> x | log _ k -> resume k ()
;;
ev 4
--- expect: 1

--- test: effect-row variable does NOT grant value-polymorphic recursion (sound)
effect Log =
  log : int -> unit
end
let rec f n : int / 'e =
  if n <= 0 do 0
  else
    let _ = f "string" in   -- a wrong-typed self-call: must be a COMPILE error,
    n + f (n - 1)            -- not accepted-then-crash. `: t / 'e` is effect-only.
;;
f 3
--- expect-type-error
