=== Algebraic Effects Tests ===

--- test: basic effect handle return
effect Greeting =
  greet : unit -> string
end
handle
  42
with
| return x -> x
--- expect: 42

--- test: perform and handle
effect Ask =
  ask : unit -> string
end
handle
  perform ask ()
with
| return x -> x
| ask () k -> resume k "hello"
--- expect: hello

--- test: continue with value
effect Val =
  get_val : unit -> int
end
handle
  let x = perform get_val () in
  x + 1
with
| return x -> x
| get_val () k -> resume k 10
--- expect: 11

--- test: multiple performs
effect Val =
  get_val : int -> int
end
handle
  let a = perform get_val 1 in
  let b = perform get_val 2 in
  a + b
with
| return x -> x
| get_val n k -> resume k (n + 10)
--- expect: 23

--- test: state effect get/put
effect State =
  get : unit -> int
  put : int -> unit
end
handle
  let x = perform get () in
  perform put (x + 1);
  perform get ()
with
| return x -> x
| get () k -> resume k 10
| put v k -> resume k ()
--- expect: 10

--- test: handler without continue
effect Abort =
  abort : int -> unit
end
handle
  perform abort 42;
  0
with
| return x -> x
| abort v k -> v
--- expect: 42

--- test: nested handles
effect Inner =
  inner_op : unit -> int
end
effect Outer =
  outer_op : unit -> int
end
handle
  handle
    let a = perform inner_op () in
    let b = perform outer_op () in
    a + b
  with
  | return x -> x
  | inner_op () k -> resume k 10
with
| return x -> x
| outer_op () k -> resume k 20
--- expect: 30

--- test: continue result
effect Eff =
  op : unit -> int
end
handle
  perform op ()
with
| return x -> x + 100
| op () k -> resume k 42
--- expect: 142

--- test: unhandled effect error
effect Unhandled =
  boom : unit -> int
end
perform boom ()
--- expect-type-error

--- test: one-shot continuation error
effect Eff =
  op : unit -> int
end
handle
  perform op ()
with
| return x -> x
| op () k ->
  let _ = resume k 1 in
  resume k 2
--- expect-runtime-error: already resumed

--- test: effect with computed arg
effect Math =
  double : int -> int
end
handle
  perform double (3 + 4)
with
| return x -> x
| double n k -> resume k (n * 2)
--- expect: 14

--- test: copy continuation multi-shot
let rec append xs ys = match xs with
  | [] -> ys
  | x :: rest -> x :: append rest ys
effect Choice =
  choose : unit -> bool
end
handle
  let x = perform choose () in
  let y = perform choose () in
  if x && y do 1 else 0
with
| return x -> [x]
| choose () k ->
  let k2 = copy_continuation k in
  let a = resume k true in
  let b = resume k2 false in
  append a b
--- expect: [1; 0; 0; 0]

--- test: copy continuation simple
let rec append xs ys = match xs with
  | [] -> ys
  | x :: rest -> x :: append rest ys
effect Pick =
  pick : unit -> int
end
handle
  perform pick ()
with
| return x -> [x]
| pick () k ->
  let k2 = copy_continuation k in
  let a = resume k 1 in
  let b = resume k2 2 in
  append a b
--- expect: [1; 2]

--- test: multishot resume of continuation captured inside for-in loop
effect Step =
  step : int -> int
end
handle
  (for i in [1; 2] with acc = 0 do (perform step i) end)
with
| return x -> x
| step arg k -> let k2 = copy_continuation k in ((resume k arg) + (resume k2 arg))
--- expect: 8

--- test: multishot resume inside while loop with shared mutable state
effect Tick =
  tick : unit -> int
end
let mut total = 0
;;
handle
  (let mut i = 0 in
   (for i < 2 do
     total := (total + (perform tick ()));
     i := (i + 1)
   end);
   total)
with
| return x -> x
| tick () k -> let k2 = copy_continuation k in ((resume k 1) + (resume k2 10))
--- expect: 23

--- test: single-shot resume of continuation captured inside for-in loop
effect Get =
  get : int -> int
end
handle
  (for i in [1; 2; 3] with acc = 0 do (acc + (perform get i)) end)
with
| return x -> x
| get arg k -> let r = resume k (arg * 10) in r
--- expect: 60

--- test: non-tail perform with non-tail resume uses the arm value as handle result
effect NtP =
  ntp : int -> int
end
handle
  (283 + (perform ntp 0))
with
| return x -> x
| ntp arg k -> let r = resume k arg in arg
--- expect: 0

--- test: non-tail perform with aborting arm discards the body
effect Abort =
  abort_op : int -> int
end
let f2 a b = 99
;;
handle
  (f2 (perform abort_op 0) 443)
with
| return x -> 1
| abort_op arg k -> 7
--- expect: 7

=== Non-Tail Perform Lowering Tests (BUG-6 regression suite) ===

--- test: non-tail perform in tuple element
effect E = op : int -> int end
handle
  (1, (perform op 2), 3)
with
| return x -> x
| op arg k -> let r = resume k (arg * 10) in r
--- expect: (1, 20, 3)

--- test: non-tail perform in constructor payload
type opt = MyNone | MySome of int
effect E = op : int -> int end
handle
  MySome (perform op 5)
with
| return x -> x
| op arg k -> let r = resume k (arg + 1) in r
--- expect: MySome 6

--- test: perform as match scrutinee
effect E = op : int -> int end
handle
  (match (perform op 3) with
   | 0 -> 100
   | n -> n * 2)
with
| return x -> x
| op arg k -> let r = resume k (arg * 10) in r
--- expect: 60

--- test: perform as if condition
effect E = op : bool -> bool end
handle
  (if (perform op true) do 111 else 222)
with
| return x -> x
| op arg k -> let r = resume k false in r
--- expect: 222

--- test: non-tail perform in function arguments
effect E = op : int -> int end
let add3 a b c = a + b + c
;;
handle
  (add3 10 (perform op 5) 100)
with
| return x -> x
| op arg k -> let r = resume k (arg * 2) in r
--- expect: 120

--- test: short-circuit and-operator does not evaluate performing rhs
effect E = op : bool -> bool end
let mut performed = false
;;
let r = handle
  (false && (performed := true; perform op true))
with
| return x -> x
| op arg k -> resume k arg
;;
(r, performed)
--- expect: (false, false)

--- test: short-circuit and-operator evaluates performing rhs when lhs true
effect E = op : bool -> bool end
handle
  (true && (perform op false))
with
| return x -> x
| op arg k -> let r = resume k true in r
--- expect: true

--- test: aborting arm with perform inside binop discards body and return arm
effect E = op : int -> int end
handle
  (1 + (perform op 2))
with
| return x -> x + 1000
| op arg k -> 42
--- expect: 42

--- test: multishot resume of perform inside binop
effect E = op : int -> int end
handle
  (100 + (perform op 1))
with
| return x -> x
| op arg k -> let k2 = copy_continuation k in ((resume k arg) + (resume k2 (arg * 2)))
--- expect: 203

--- test: mutable read before perform is captured in the continuation
effect E = op : unit -> int end
let mut cell = 5
;;
handle
  (cell + (perform op ()))
with
| return x -> x
| op arg k ->
  let k2 = copy_continuation k in
  let a = resume k 100 in
  cell := 1000;
  let b = resume k2 100 in
  a + b
--- expect: 210

--- test: perform whose argument is itself a perform
effect E =
  inner : int -> int
  outer : int -> int
end
handle
  perform outer (perform inner 3)
with
| return x -> x
| inner arg k -> let r = resume k (arg * 10) in r
| outer arg k -> let r = resume k (arg + 1) in r
--- expect: 31

--- test: sequential non-tail performs with arm post-processing
effect E = op : int -> int end
handle
  (let a = perform op 10 in
   let b = perform op 20 in
   a + b)
with
| return x -> x * 2
| op arg k -> let r = resume k (arg + 1) in r + 1
--- expect: 66


=== Deep Handler Arm-Value Chaining Tests (BUG-13 regression suite) ===

--- test: nested performs in a while loop chain arm values across iterations
effect E =
  op0 : int -> int
  op1 : int -> int
end
handle
  (let mut i = 0 in
   let mut s = 7 in
   (for i < 3 do
     i := (i + 1);
     s := (perform op0 (let v = perform op1 0 in 398))
   end);
   s)
with
| return x -> x
| op0 arg k -> ((resume k 2) + arg)
| op1 arg k -> resume k arg
--- expect: 1196

--- test: arm value chaining when the while body performs from inside a for-in
effect E =
  op0 : int -> int
  op1 : int -> int
end
handle
  (let mut i = 0 in
   let mut s = 7 in
   (for i < 3 do
     i := (i + 1);
     s := (for x in [18] with acc = 149 do (perform op0 (let v = perform op1 0 in 398)) end)
   end);
   s)
with
| return x -> x
| op0 arg k -> ((resume k 2) + arg)
| op1 arg k -> resume k arg
--- expect: 1196

--- test: arm value chaining across for-in iterations
effect E = op : int -> int end
handle
  (for x in [1; 2] with acc = 0 do (perform op x) end) + 100
with
| return x -> x
| op arg k -> (resume k 0) + 1000
--- expect: 2100

=== Loop Control Crossing Handler Boundaries (BUG-10/BUG-12 regression suite) ===

--- test: break out of a for-in loop inside a try-classified handler body
effect E = op : int -> int end
handle
  (for i in [1; 2] with acc = 0 do (break 5) end)
with
| return x -> x
| op arg k -> arg
--- expect: 5

--- test: break after a tail resume inside a provide-classified handler body
effect Ask = ask : int -> int end
handle
  (for i in [1; 2; 3] with acc = 0 do
    (if ((perform ask i) > 2) do break 99 else (acc + i)) end)
with
| return x -> x
| ask arg k -> resume k arg
--- expect: 99

--- test: continue inside a while loop wrapped by a try-classified handler
effect E = op : int -> int end
let mut total = 0
;;
handle
  (let mut i = 0 in
   (for i < 5 do
     i := (i + 1);
     (if i = 2 do continue else ());
     total := (total + i)
   end);
   total)
with
| return x -> x
| op arg k -> arg
--- expect: 13

--- test: break out of a handler nested inside a loop drops only that handler marker
effect E = op : int -> int end
(for i in [1; 2; 3] with acc = 0 do
  (acc + (handle (if i = 2 do break 50 else i) with
          | return x -> x
          | op arg k -> arg))
end)
--- expect: 50

--- test: break inside nested loops each wrapped by try handlers
effect E =
  op1 : int -> int
  op2 : int -> int
end
handle
  (for i in [1; 2] with outer = 0 do
    (outer + (handle
      (for j in [10; 20] with inner = 0 do
        (if j = 20 do break 7 else (inner + j)) end)
    with
    | return x -> x
    | op2 arg k -> arg))
  end)
with
| return x -> x
| op1 arg k -> arg
--- expect: 14

=== Mixed Provide/Full Arm and For-In Argument Tests (BUG-14 regression suite) ===

--- test: full-op perform nested inside a provide-op perform argument
effect E =
  simple : int -> int
  full : int -> int
end
handle
  (perform simple (11 + (perform full 0)))
with
| return x -> 1
| simple arg k -> resume k arg
| full arg k -> let r = resume k 804 in 0
--- expect: 0

--- test: full-op perform nested in provide-op argument resumes with chained value
effect E =
  simple : int -> int
  full : int -> int
end
handle
  (perform simple (11 + (perform full 100)))
with
| return x -> x
| simple arg k -> resume k arg
| full arg k -> let r = resume k arg in r
--- expect: 111

--- test: perform in the accumulator init of a for-in loop
effect E = op : int -> int end
handle
  (for x in [1; 2; 3] with acc = (perform op 10) do (acc + x) end)
with
| return x -> x
| op arg k -> let r = resume k (arg * 2) in r
--- expect: 26

--- test: aborting arm with perform in for-in accumulator init discards the loop
effect E = op : int -> int end
let mut ran = false
;;
let r = handle
  (for x in [1; 2; 3] with acc = (perform op 10) do (ran := true; acc + x) end)
with
| return x -> 0 - 1
| op arg k -> 777
;;
(r, ran)
--- expect: (777, false)

--- test: perform in the collection expression of a for-in loop
effect E = op : int -> int end
handle
  (for x in (List.map (fn i -> i) ((perform op 5) :: [2; 3])) with acc = 0 do (acc + x) end)
with
| return x -> x
| op arg k -> let r = resume k (arg * 100) in r
--- expect: 505

=== Optional Return Arm Tests (BUG-4 regression suite) ===

--- test: handle without return arm produces the body value
effect E = op : int -> int end
handle
  42
with
| op arg k -> resume k arg
--- expect: 42

--- test: handle without return arm with tail resume
effect E = op : int -> int end
handle
  perform op 1
with
| op arg k -> resume k arg
--- expect: 1

--- test: handle without return arm with non-tail resume uses arm value
effect E = op : int -> int end
handle
  (perform op 5) + 100
with
| op arg k -> let r = resume k arg in arg
--- expect: 5

--- test: handle without return arm with aborting arm
effect E = op : int -> int end
handle
  (perform op 3) * 2
with
| op arg k -> 99
--- expect: 99

--- test: handle without return arm with multishot resume
effect E = op : int -> int end
handle
  (perform op 10) + 1
with
| op arg k -> let k2 = copy_continuation k in ((resume k arg) + (resume k2 (arg * 2)))
--- expect: 32

--- test: nested handles without return arms
effect E =
  inner_op : int -> int
  outer_op : int -> int
end
handle
  (handle (perform inner_op 1) + (perform outer_op 10) with
   | inner_op arg k -> resume k (arg * 2))
with
| outer_op arg k -> resume k (arg * 3)
--- expect: 32

=== Match Return Arm Type Propagation Tests (BUG-5 regression suite) ===

--- test: match expression as handle return arm with multishot resume
effect E = op : int -> int end
handle perform op 1 with
| return x -> (match x with | 0 -> 0 | n -> n)
| op arg k -> let k2 = copy_continuation k in ((resume k arg) + (resume k2 arg))
--- expect: 2

--- test: constructor match as handle return arm with multishot resume
effect E = op : int -> int end
handle perform op 1 with
| return x -> (match Some x with | Some o -> o | None -> 0)
| op arg k -> let k2 = copy_continuation k in ((resume k arg) + (resume k2 arg))
--- expect: 2

--- test: bool match return arm with multishot resume arithmetic
effect E = op : int -> int end
handle
  (perform op 10) * 3
with
| return x -> (match x > 20 with | true -> x | false -> 0)
| op arg k -> let k2 = copy_continuation k in ((resume k arg) + (resume k2 (arg + 1)))
--- expect: 63

--- test: list match as handle return arm
effect E = op : int -> int end
handle
  [perform op 1; perform op 2]
with
| return xs -> (match xs with | [] -> 0 | h :: _ -> h)
| op arg k -> let r = resume k (arg * 10) in r
--- expect: 10

=== Copy-Before-Resume Tests (BUG-15 regression suite) ===

--- test: copying an already-resumed continuation is an error
effect E = op : int -> int end
handle
  (perform op 10) * 3
with
| return x -> x
| op arg k -> ((resume k arg) + (resume (copy_continuation k) (arg + 1)))
--- expect-runtime-error: already resumed

--- test: explicit copy after resume is an error
effect E = op : int -> int end
handle
  perform op 1
with
| return x -> x
| op arg k ->
  let a = resume k arg in
  let k2 = copy_continuation k in
  a + (resume k2 arg)
--- expect-runtime-error: already resumed

--- test: copy of a copy before any resume is fine
effect E = op : int -> int end
handle
  perform op 5
with
| return x -> x
| op arg k ->
  let k2 = copy_continuation k in
  let k3 = copy_continuation k2 in
  (resume k arg) + (resume k2 (arg * 10)) + (resume k3 (arg * 100))
--- expect: 555

=== For-In CPS Lowering Tests (BUG-11 for-in slice) ===

--- test: multishot resume of for-in over an array
effect E = op : int -> int end
handle
  (for x in #[1; 2] with acc = 0 do (perform op x) end)
with
| return x -> x
| op arg k -> let k2 = copy_continuation k in ((resume k arg) + (resume k2 arg))
--- expect: 8

--- test: for-in with perform and break
effect E = op : int -> int end
handle
  (for x in [1; 2; 3; 4] with acc = 0 do
    (if (perform op x) > 2 do break 99 else (acc + x)) end)
with
| return x -> x
| op arg k -> resume k arg
--- expect: 99

--- test: for-in with perform and continue
effect E = op : int -> int end
handle
  (for x in [1; 2; 3] with acc = 0 do
    (if (perform op x) = 2 do continue acc else (acc + x)) end)
with
| return x -> x
| op arg k -> let r = resume k arg in r
--- expect: 4

--- test: aborting arm discards remaining for-in iterations
effect E = op : int -> int end
let mut count = 0
;;
let r = handle
  (for x in [1; 2; 3] with acc = 0 do
    (count := count + 1; acc + (perform op x)) end)
with
| return x -> 0 - 1
| op arg k -> (if arg = 2 do 777 else (let v = resume k arg in v))
;;
(r, count)
--- expect: (777, 2)

--- test: nested for-in loops both with performs
effect E = op : int -> int end
handle
  (for x in [1; 2] with outer = 0 do
    (outer + (for y in [10; 20] with inner = 0 do
      (inner + (perform op (x * y))) end)) end)
with
| return x -> x
| op arg k -> let r = resume k arg in r
--- expect: 90

--- test: multishot for-in over a map
effect E = op : int -> int end
handle
  (for kv in #{"a": 1; "b": 2} with acc = 0 do
    (match kv with | (_, v) -> acc + (perform op v)) end)
with
| return x -> x
| op arg k -> let r = resume k (arg * 10) in r
--- expect: 30

=== Break-Value-Performs in a Full Handler (break-perform regression) ===
# A `break` whose VALUE performs, with a NON-tail resume in a FULL (THOp)
# handler arm: the loop's break must return the loop result through the resume,
# not escape past the handler via a thrown _break the loop's catch intercepts.

--- test: break value performs, non-tail resume returns arm value
effect E = op0 : int -> int end
handle
  (let v0 = (for i in [1; 2] with a = 0 do break (perform op0 i) end) in 16)
with
| return x -> x
| op0 arg k -> let r3 = resume k arg in 99
--- expect: 99

--- test: break value performs, resume result used by the arm
effect E = op : int -> int end
handle
  (let v0 = (for i in [1; 2; 3] with a = 0 do break (perform op i) end) in v0 * 10)
with
| return x -> x
| op arg k -> let r = resume k arg in r + 1
--- expect: 11

--- test: multishot break value performs sums both resumptions
effect E = pick : int -> int end
handle
  (let v0 = (for i in [1; 2; 3] with a = 0 do break (perform pick i) end) in v0 * 10)
with
| return x -> x
| pick arg k -> let k2 = copy_continuation k in (resume k arg) + (resume k2 (arg + 100))
--- expect: 1020

--- test: break value performs guarded by a non-tail predicate
effect E = op : int -> int end
handle
  (for x in [1; 2; 3; 4] with acc = 0 do
    (if (perform op x) > 2 do break (acc * 100) else (acc + x)) end)
with
| return x -> x
| op arg k -> resume k arg
--- expect: 300

=== Continue-Value-Performs (continue-perform regression) ===
# A `continue EXPR` whose VALUE itself performs: the perform's reified
# continuation ends in the control transfer (_throw_fold_cont), which surfaces
# OUT of the iteration's trampoline when the handler resumes the continuation —
# so the fold callback's _fold_cont catch must wrap the trampoline from outside.

--- test: continue value performs under a tail-resumptive handler
effect E = op : int -> int end
handle
  (for i in [1; 2; 3] with a = 0 do (if i = 2 do continue (perform op a) else (a + i)) end)
with
| return x -> x
| op arg k -> resume k (arg + 10)
--- expect: 14

--- test: continue value performs under a multishot handler
effect E = op : int -> int end
handle
  (for i in [1; 2; 3] with a = 0 do (if i = 2 do continue (perform op a) else (a + i)) end)
with
| return x -> x
| op arg k -> let k2 = copy_continuation k in (resume k (arg + 10)) + (resume k2 (arg + 20))
--- expect: 38

=== Try/With Tests ===

--- test: try/with basic return
effect Exn =
  raise : string -> 'a
end
try 42 with
| raise msg -> 0
--- expect: 42

--- test: try/with catch exception
effect Exn =
  raise : string -> 'a
end
try
  perform raise "oops"
with
| raise msg -> msg
--- expect: oops

--- test: try/with no continuation
effect Exn =
  raise : string -> 'a
end
try
  let x = 10 in
  if x > 5 do perform raise "too big"
  else x
with
| raise msg -> 0
--- expect: 0

--- test: try/with multiple operations
effect IO =
  file_not_found : string -> 'a
end
effect Validation =
  invalid_input : string -> 'a
end
try
  perform invalid_input "bad data"
with
| file_not_found path -> "missing: " ^ path
| invalid_input msg -> "invalid: " ^ msg
--- expect: invalid: bad data

--- test: try/with value passes through
effect Exn =
  raise : string -> 'a
end
try "hello" with
| raise msg -> "caught"
--- expect: hello

--- test: try/with unit arg
effect Exn =
  fail : unit -> 'a
end
try
  perform fail ()
with
| fail () -> 99
--- expect: 99

=== Effect Typing Tests ===

--- test: unhandled effect at top level
effect MyEff =
  my_op : unit -> int
end
perform my_op ()
--- expect-type-error

--- test: handled effect at top level
effect MyEff =
  my_op : unit -> int
end
handle
  perform my_op ()
with
| return x -> x
| my_op () k -> resume k 42
--- expect: 42

--- test: effectful function handled by caller
effect Ask =
  ask : unit -> int
end
let f () = perform ask () + 1
handle
  f ()
with
| return x -> x
| ask () k -> resume k 10
--- expect: 11

--- test: multiple effects partial handle
effect E1 =
  op1 : unit -> int
end
effect E2 =
  op2 : unit -> int
end
handle
  handle
    perform op1 () + perform op2 ()
  with
  | return x -> x
  | op1 () k -> resume k 10
with
| return x -> x
| op2 () k -> resume k 20
--- expect: 30

--- test: nested handlers
effect Outer =
  get_outer : unit -> int
end
effect Inner =
  get_inner : unit -> int
end
handle
  handle
    perform get_outer () + perform get_inner ()
  with
  | return x -> x
  | get_inner () k -> resume k 5
with
| return x -> x
| get_outer () k -> resume k 10
--- expect: 15

--- test: effectful callback in higher-order function
effect Counter =
  inc : unit -> unit
end
let apply f x = f x
handle
  let mut n = 0 in
  apply (fn x -> perform inc (); x + 1) 10;
  n
with
| return x -> x
| inc () k -> resume k ()
--- expect: 0

--- test: immediately-applied effectful lambda
effect Ask =
  get : unit -> int
end
handle
  let x = (fn b -> b + perform get ()) 10 in
  x + 1
with
| return v -> v
| get () k -> resume k 5
--- expect: 16

--- test: multishot resume across immediately-applied lambda
effect Choose =
  pick : unit -> bool
end
handle
  let x = (fn u -> if perform pick () do 10 else 20) () in
  x + 1
with
| return v -> v
| pick () k ->
    let a = resume (copy_continuation k) true in
    let b = resume k false in
    a + b
--- expect: 32

--- test: immediately-applied lambda perform in body not argument
effect Ask2 =
  ask : int -> int
end
handle
  (fn n -> (perform ask n) * 2) 7
with
| return v -> v
| ask n k -> resume k (n + 100)
--- expect: 214

--- test: multishot resume across a directly-effectful named function call
effect Choose =
  pick : unit -> bool
end
let helper u = perform pick ()
handle
  let a = helper () in
  if a do 10 else 20
with
| pick () k -> let k2 = copy_continuation k in ((resume k true) + (resume k2 false))
--- expect: 30

