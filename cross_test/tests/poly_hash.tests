=== Poly Hash Tests ===

--- test: hash int
__poly_hash 42
--- expect-type: int

--- test: hash string
__poly_hash "hello"
--- expect-type: int

--- test: hash bool true
__poly_hash true
--- expect-type: int

--- test: hash bool false
__poly_hash false
--- expect-type: int

--- test: hash unit
__poly_hash ()
--- expect-type: int

--- test: hash byte
__poly_hash #41
--- expect-type: int

--- test: hash consistency int
__poly_hash 42 = __poly_hash 42
--- expect: true

--- test: hash consistency string
__poly_hash "hello" = __poly_hash "hello"
--- expect: true

--- test: hash consistency bool
__poly_hash true = __poly_hash true
--- expect: true

--- test: hash different ints differ
__poly_hash 1 = __poly_hash 2
--- expect: false

--- test: hash different strings differ
__poly_hash "abc" = __poly_hash "xyz"
--- expect: false

--- test: hash tuple
__poly_hash (1, 2, 3) = __poly_hash (1, 2, 3)
--- expect: true

--- test: hash different tuples differ
__poly_hash (1, 2) = __poly_hash (1, 3)
--- expect: false

--- test: hash list
__poly_hash [1; 2; 3] = __poly_hash [1; 2; 3]
--- expect: true

--- test: hash different lists differ
__poly_hash [1; 2] = __poly_hash [1; 3]
--- expect: false

--- test: hash variant
type color = Red | Green | Blue
__poly_hash Red = __poly_hash Red
--- expect: true

--- test: hash different variants differ
type color = Red | Green | Blue
__poly_hash Red = __poly_hash Blue
--- expect: false

--- test: hash variant with payload
type wrapper = Empty | Val of int;;
__poly_hash (Val 42) = __poly_hash (Val 42)
--- expect: true

--- test: hash record
__poly_hash {x = 1; y = 2} = __poly_hash {x = 1; y = 2}
--- expect: true

--- test: hash different records differ
__poly_hash {x = 1; y = 2} = __poly_hash {x = 1; y = 3}
--- expect: false

--- test: hash array
__poly_hash #[1; 2; 3] = __poly_hash #[1; 2; 3]
--- expect: true

--- test: hash nested structure
__poly_hash (1, [2; 3], "hi") = __poly_hash (1, [2; 3], "hi")
--- expect: true

--- test: hash used in custom Hash instance
type point = { x: int; y: int }
instance Hash point =
  let hash p = __poly_hash (p.x, p.y)
end
let tbl = Hashtbl.create 4 in
Hashtbl.set tbl {x = 1; y = 2} "origin-ish";
match Hashtbl.get tbl {x = 1; y = 2} with
| Some v -> v
| None -> "not found"
--- expect: origin-ish

--- test: hash float
__poly_hash 3.14 = __poly_hash 3.14
--- expect: true

--- test: hash different floats differ
__poly_hash 1.0 = __poly_hash 2.0
--- expect: false

--- test: hash empty list
__poly_hash ([] : int list) = __poly_hash ([] : int list)
--- expect: true
