=== Record Field Resolution ===

--- test: field access on ambiguous record resolves with second field
type loc = { line: int; col: int; offset: int }
type span = { line: int; end_line: int }
;;
let get_col r =
  let _ = r.line in
  r.col
;;
get_col { line = 1; col = 2; offset = 3 }
--- expect: 2

--- test: multiple field accesses disambiguate record type
type point = { x: int; y: int }
type rect = { x: int; y: int; w: int; h: int }
;;
let area r =
  r.x + r.y + r.w + r.h
;;
area { x = 1; y = 2; w = 3; h = 4 }
--- expect: 10

--- test: single candidate resolves immediately
type color = { r: int; g: int; b: int }
;;
let get_r c = c.r
;;
get_r { r = 255; g = 0; b = 0 }
--- expect: 255

--- test: mutable field assign on ambiguous record
type counter = { mut count: int; name: string }
type stat = { mut count: int; total: int }
;;
let bump c =
  let _ = c.name in
  c.count := c.count + 1;
  c.count
;;
bump { count = 0; name = "test" }
--- expect: 1

=== Field Access Precedence ===

--- test: not with field access
type game = { game_over: bool }
;;
let check g = not g.game_over
;;
check { game_over = false }
--- expect: true

--- test: negation with field access
type point = { x: int }
;;
let neg_x p = 0 - p.x
;;
neg_x { x = 5 }
--- expect: -5

--- test: not with nested field access and application
type state = { active: bool; count: int }
;;
let f s = if not s.active do 0 else s.count
;;
f { active = true; count = 42 }
--- expect: 42

# A row-polymorphic function that ASSIGNS a mutable field (`s.count := ...`) must
# store at the caller-supplied evidence index, exactly like a field read. The
# native backend resolved the write via the static sorted index of the visible
# row — which holds only `count`, giving index 0 — so any field past index 0 in
# the concrete record was never updated (the read used evidence and was correct,
# so the mismatch was silent). `count` sorts to index 1 here. Regression for the
# native self-host bootstrap: Compiler.allocate_local mutates s.num_locals /
# s.locals / s.max_locals (indices >0) on a row-poly state, which underflowed
# free_local ("no locals to free").
--- test: row-polymorphic mutable field assignment at non-zero index
type ra = { alpha: int; mut count: int; gamma: int }
;;
type rb = { alpha: int; mut count: int; delta: bool }
;;
let bump s = s.count := s.count + 1; s.count
;;
let force () = let b = { alpha = 0; count = 0; delta = true } in bump b
;;
let go () =
  let a = { alpha = 1; count = 0; gamma = 2 } in
  let _ = bump a in
  let _ = bump a in
  a.count
;;
let () =
  let _ = force () in
  print (string_of_int (go ()))
--- expect: 2

# A nested closure that reads a field of a ROW-POLYMORPHIC record must capture
# the enclosing scope's evidence param __ev_<field>_r<N> — the offset is known
# only via that evidence (the concrete record's sorted index). Native's
# free_vars_of_fun captured only explicit TEVars, so the implicitly-used evidence
# was dropped and the closure fell back to its own visible-row static index
# ({loc,tenv} -> 0,1) instead of the concrete indices (4,9), reading wrong fields.
# This was the native self-host bootstrap's resolve_inst_tys SEGV.
--- test: row-poly field read inside a nested closure (evidence capture)
type ca = { f0:int; f1:int; f2:int; f3:int; loc:int; f5:int; f6:int; f7:int; f8:int; tenv:int; vars:int }
;;
type cb = { f0:int; f1:int; f2:int; f3:int; loc:int; f5:int; f6:int; f7:int; f8:int; tenv:int; other:bool }
;;
let outer ctx =
  let inner annot = ctx.tenv + ctx.loc + annot in
  List.map inner [10; 20]
;;
let force2 () =
  let b = { f0=0;f1=1;f2=2;f3=3;loc=99;f5=5;f6=6;f7=7;f8=8;tenv=100;other=true } in
  outer b
;;
let _ = force2 ()
;;
let a = { f0=0;f1=1;f2=2;f3=3;loc=99;f5=5;f6=6;f7=7;f8=8;tenv=100;vars=10 }
;;
match outer a with
| x :: y :: _ -> x + y
| _ -> 0
--- expect: 428
